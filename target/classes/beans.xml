	<!-- 配置自动完结分账 -->
	<bean id="finishOrderID" class="hy.ea.finance.action.NewPhoneOrders.PhoneOrdersAction_Buyers"/>
	<bean id="finishOrderJobDetail"
		  class="org.springframework.scheduling.quartz.MethodInvokingJobDetailFactoryBean">
		<property name="targetObject" ref="finishOrderID" />
		<property name="targetMethod" value="finishOrder" />
	</bean>
	<!--  配置自完结分账 时间  -->
	<bean id="finishOrderTrigger"
		  class="org.springframework.scheduling.quartz.CronTriggerBean">
		<property name="jobDetail" ref="finishOrderJobDetail" />
		<!-- 	每天00凌晨重复运行  -->
		<property name="cronExpression" value="0 0 4 * * ?" />
	</bean>
	<!-- 开启完结分账任务-->
	<bean class="org.springframework.scheduling.quartz.SchedulerFactoryBean">
		<property name="triggers">
			<list>
				<ref bean="finishOrderTrigger" />
			</list>
		</property>
	</bean>


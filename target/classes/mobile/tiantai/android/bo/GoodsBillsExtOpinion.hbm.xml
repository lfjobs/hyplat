<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
    <class name="mobile.tiantai.android.bo.GoodsBillsExtOpinion" table="DTGOODSBILLSEXTOPINION">
        <comment>明细审核表</comment>
        <id name="id">
            <column length="50" name="ID">
                <comment>主键id</comment>
            </column>
        </id>
        <property name="cashierBillsID">
            <column length="50" name="CASHIERBILLSID">
                <comment>预算单id</comment>
            </column>
        </property>
        <property name="goodsBillsID">
            <column length="50" name="GOODSBILLSID">
                <comment>预算单明细id</comment>
            </column>
        </property>
        <property name="reviewerId">
            <column length="50" name="REVIEWERID">
                <comment>审核人id</comment>
            </column>
        </property>
        <property name="reviewerName">
            <column length="50" name="REVIEWERNAME">
                <comment>审核人姓名</comment>
            </column>
        </property>
        <property name="reviewerNameCode">
            <column length="50" name="REVIEWERNAMECODE">
                <comment>审核人编号</comment>
            </column>
        </property>
        <property name="reviewTime">
            <column length="50" name="REVIEWTIME">
                <comment>审核时间</comment>
            </column>
        </property>
        <property name="reviewOpinion">
            <column length="50" name="REVIEWOPINION">
                <comment>审核意见</comment>
            </column>
        </property>
        <property name="reviewNameSource">
            <column length="50" name="REVIEWNAMESOURCE">
                <comment>审核人来源</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

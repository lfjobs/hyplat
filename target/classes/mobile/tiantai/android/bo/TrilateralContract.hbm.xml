<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="mobile.tiantai.android.bo">
    <class name="TrilateralContract" table="TRILATERAL_CONTRACT">
        <id length="50" name="key">
            <column length="50" name="key"/>
            <generator class="uuid"/>
        </id>
        <property name="templateId" type="java.lang.String">
            <column name="templateId" length="50"/>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId" length="50"/>
        </property>
        <property name="templateName" type="java.lang.String">
            <column name="templateName" length="50"/>
        </property>
        <property name="templatePath" type="java.lang.String">
            <column name="templatePath" length="256"/>
        </property>
        <property name="ext" type="java.lang.String">
            <column name="ext" length="10"/>
        </property>
        <property name="templateType" type="java.lang.String">
            <column name="templateType" length="2"/>
        </property>
        <property name="fileType" type="java.lang.String">
            <column name="fileType" length="50"/>
        </property>
        <property name="fileShowName" type="java.lang.String">
            <column name="fileShowName" length="50"/>
        </property>
        <property name="fileSaveName" type="java.lang.String">
            <column name="fileSaveName" length="50"/>
        </property>
        <property name="time" type="java.util.Date">
            <column name="time" length="7"/>
        </property>
        <property name="createrID" type="java.lang.String">
            <column name="createrID" length="50"/>
        </property>
        <property name="receiptType" type="java.lang.String">
            <column name="receiptType" length="50"/>
        </property>
        <property name="pdfpath" type="java.lang.String">
            <column name="pdfpath" length="200"/>
        </property>
        <property name="sysSet" type="java.lang.String">
            <column name="sysSet" length="2"/>
        </property>

        <property name="temptId" type="java.lang.String">
            <column name="temptId" length="50"/>
        </property>
        <property name="pdfTime" type="java.util.Date">
            <column name="pdfTime"/>
        </property>
        <property name="seq" type="java.lang.Integer">
            <column name="seq"/>
        </property>
        <property name="module" type="java.lang.String">
            <column name="module" length="50"/>
        </property>
        <property name="contractType" type="java.lang.String">
            <column name="contractType" length="2"/>
        </property>
        <property name="contractTypeName" type="java.lang.String">
            <column name="contractTypeName" length="50"/>
        </property>
        <property name="trilateralDataId" type="java.lang.String">
            <column name="trilateralDataId" length="50"/>
        </property>
    </class>
</hibernate-mapping>

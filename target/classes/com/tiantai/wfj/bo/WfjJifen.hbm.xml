<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.tiantai.wfj.bo">
    <class name="WfjJifen" table="DT_WFJ_JIFEN" schema="HYPLAT"
           dynamic-insert="true">
        <comment>积分表</comment>
        <id length="50" name="wfjJifenKey" type="java.lang.String">
            <column length="50" name="WFJ_JIFEN_KEY">
                <comment>key</comment>
            </column>
            <generator class="uuid"/>
        </id>
        <property name="wfjJifenId" type="java.lang.String">
            <column length="50" name="WFJ_JIFEN_ID">
                <comment>id</comment>
            </column>
        </property>
        <property name="staffId" type="java.lang.String">
            <column length="50" name="STAFF_ID">
                <comment>人员id</comment>
            </column>
        </property>
        <property name="wfjJifenScore" type="java.lang.String">
            <column length="9" name="WFJ_JIFEN_SCORE">
                <comment>金币量</comment>
            </column>
        </property>
        <property name="wfjJifenState" type="java.lang.Integer">
            <column length="1" name="WFJ_JIFEN_STATE" default="0">
                <comment>状态</comment>
            </column>
        </property>
        <property name="sccid" type="java.lang.String">
            <column length="50" name="sccid">
                <comment>人员帐号id</comment>
            </column>
        </property>
        <property name="envelopescore" type="java.lang.String">
            <column length="50" name="envelopescore">
                <comment>红包金币汇总</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

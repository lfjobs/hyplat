<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.tiantai.wfj.bo">
	<class name="PresetKey" table="DT_PresetKey" schema="HYPLAT" dynamic-insert="true">
	<comment>电子秤预置键</comment>
		<id length="50" name="prKey" type="java.lang.String">
			<column length="50" name="prKey" />
			<generator class="uuid" />
		</id>
		<property name="prId" type="java.lang.String">
			<column length="50" name="prId" >
			</column>
		</property>
		<property name="scpId" type="java.lang.String">
			<column length="50" name="scpId" >
			</column>
		</property>
		<property name="keyNo" type="java.lang.String">
			<column  length="10"  name="keyNo" >
			<comment>键号</comment>
			</column>
		</property>
		<property name="rowx" type="java.lang.String">
			<column  length="10"  name="rowx" >
				<comment>行</comment>
			</column>
		</property>
		<property name="columns" type="java.lang.String">
			<column  length="10"  name="columns" >
				<comment>列</comment>
			</column>
		</property>
		<property name="title" type="java.lang.String">
			<column  length="10"  name="title" >
				<comment>名称</comment>
			</column>
		</property>
		<property name="plu" type="java.lang.Integer" >
			<column   name="plu" ><comment>商品号只有称重的有</comment></column>
		</property>
		<property name="companyID" type="java.lang.String">
			<column length="50" name="companyID" >
				<comment>公司ID</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>

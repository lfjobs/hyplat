<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
 <class name="com.tiantai.wfj.bo.HgResult" schema="HYPLAT" table="dt_HgResult">
  <id name="hrkey" type="java.lang.String">
   <column length="50" name="hrkey"/>
   <generator class="uuid"/>
  </id>
  <property  name="hrId" type="java.lang.String">
   <column length="50" name="hrId"/>
  </property>
  <property  name="sccId" type="java.lang.String">
   <column length="50" name="sccId"/>
  </property>
  <property  name="hgCode" type="java.lang.String">
   <column length="50" name="hgCode"/>
  </property>
  <property  name="journalNum" type="java.lang.String">
   <column length="50" name="journalNum"/>
  </property>
  <property  name="createDate" type="java.util.Date">
   <column name="createDate"/>
  </property>
 </class>
</hibernate-mapping>

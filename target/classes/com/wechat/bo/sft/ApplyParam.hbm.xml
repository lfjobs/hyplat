<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.wechat.bo.sft">
	<class name="ApplyParam" table="dt_sft_ApplyParam">
	<comment>二级商户进件</comment>
		<id length="50" name="applyKey">
			<column length="50" name="applyKey" ><comment></comment></column>
			<generator class="uuid" />
		</id>
		<property name="applyID">
			<column length="50" name="applyID" ><comment>业务主键</comment></column>
		</property>
		<property name="out_request_no">
			<column length="50" name="out_request_no" ><comment>业务申请编号</comment></column>
		</property>
		<property name="organization_type">
			<column length="50" name="organization_type" ><comment>主体类型</comment></column>
		</property>
		<property name="qualifications">
			<column length="2500" name="qualifications" ><comment>特殊资质</comment></column>
		</property>
		<many-to-one  name="business_license_info" class="com.wechat.bo.sft.BusinessLicenseInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="bliKey" length="50"  ><comment>营业执照/登记证书信息</comment></column>
		</many-to-one>
		<many-to-one  name="organization_cert_info" class="com.wechat.bo.sft.OrganizationCertInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="ociKey" length="50"  ><comment>组织机构代码证信息</comment></column>
		</many-to-one>

		<property name="id_doc_type">
			<column length="50" name="id_doc_type" ><comment>经营者/法人证件类型</comment></column>
		</property>
		<many-to-one  name="id_card_info" class="com.wechat.bo.sft.IdCardInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="cardKey" length="50"  ><comment>经营者/法人身份证信息</comment></column>
		</many-to-one>
		<many-to-one  name="id_doc_info" class="com.wechat.bo.sft.IdDocInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="docKey" length="50"  ><comment> 经营者/法人其他类型证件信息 </comment></column>
		</many-to-one>

		<many-to-one  name="account_info" class="com.wechat.bo.sft.AccountInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="acKey" length="50"  ><comment> 结算账户信息</comment></column>
		</many-to-one>

		<many-to-one  name="contact_info" class="com.wechat.bo.sft.ContactInfo"  cascade="save-update" fetch="join" lazy="false">
		<column name="coKey" length="50"  ><comment> 超级管理员信息</comment></column>
	   </many-to-one>
		<many-to-one  name="sales_scene_info" class="com.wechat.bo.sft.SalesSceneInfo"  cascade="save-update" fetch="join" lazy="false">
			<column name="ssKey" length="50"  ><comment> 店铺信息</comment></column>
		</many-to-one>
		<property name="merchant_shortname">
			<column length="50" name="merchant_shortname" ><comment>商户简称 </comment></column>
		</property>

		<property name="business_addition_pics">
			<column length="2500" name="business_addition_pics" ><comment>补充材料 </comment></column>
		</property>
		<property name="business_addition_desc">
			<column length="500" name="business_addition_desc" ><comment>补充说明</comment></column>
		</property>

		<property name="staffID">
			<column length="50" name="staffID" ><comment>同步操作人</comment></column>
		</property>
		<property name="applydate">
			<column length="50" name="applydate" ><comment>同步操作人日期</comment></column>
		</property>
	</class>
</hibernate-mapping>

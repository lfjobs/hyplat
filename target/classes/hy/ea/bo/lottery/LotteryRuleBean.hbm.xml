<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.lottery.LotteryRuleBean" table="DT_LOTTERY_RULE" schema="HYPLAT">
        <comment>抽奖规则</comment>
        <id name="ruleId">
            <column name="RULE_ID" sql-type="varchar2(50)" length="50"/>
            <generator class="uuid"></generator>
        </id>
        <property name="lotteryMode">
            <column name="LOTTERY_MODE" sql-type="char(10)" length="10" not-null="true">
                <comment>抽奖模型</comment>
            </column>
        </property>
        <property name="lotteryStyle">
            <column name="LOTTERY_STYLE" sql-type="char(2)" length="2" not-null="true">
                <comment>抽奖方式</comment>
            </column>
        </property>
        <property name="freeNum">
            <column name="FREE_NUM" sql-type="number(*)" precision="2147483646" not-null="true">
                <comment>免费次数</comment>
            </column>
        </property>
        <property name="activityId">
            <column name="ACTIVITY_ID" sql-type="varchar2(50)" length="50" not-null="true">
                <comment>活动ID</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>
<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.lottery.PrizeCouponBean" table="DT_PRIZE_COUPON" schema="HYPLAT">
        <comment>优惠券</comment>
        <id name="couponId">
            <column name="COUPON_ID" sql-type="varchar2(50)" length="50"/>
            <generator class="uuid"></generator>
        </id>
        <property name="couponName">
            <column name="COUPON_NAME" sql-type="varchar2(400)" length="400" not-null="true">
                <comment>优惠券名称</comment>
            </column>
        </property>
        <property name="couponFaceVal">
            <column name="COUPON_FACE_VAL" sql-type="varchar2(20)" length="20" not-null="true">
                <comment>优惠券面值</comment>
            </column>
        </property>
        <property name="staringTime">
            <column name="STARING_TIME" sql-type="timestamp(6)" not-null="true">
                <comment>开始时间</comment>
            </column>
        </property>
        <property name="endTime">
            <column name="END_TIME" sql-type="timestamp(6)" not-null="true">
                <comment>结束时间</comment>
            </column>
        </property>
        <property name="limitMoney">
            <column name="LIMIT_MONEY" sql-type="varchar2(20)" length="20" not-null="true">
                <comment>限满金额</comment>
            </column>
        </property>
        <property name="couponNum">
            <column name="COUPON_NUM" sql-type="number(*)" precision="2147483646" not-null="true">
                <comment>数量</comment>
            </column>
        </property>
        <property name="companyId">
            <column name="COMPANY_ID" sql-type="varchar2(50)" length="50" not-null="true">
                <comment>公司ID</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>
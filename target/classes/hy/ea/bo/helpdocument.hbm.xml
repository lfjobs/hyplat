<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo">
	<class name="HelpDocument" table="dtHelpDocument">
	<id length="50" name="hdKey">
			<column length="50" name="hdKey" />
			<generator class="uuid" />
		</id>
		<property name="hdID">
			<column length="50" name="hdID" />
		</property>
		<property name="hdName">
			<column length="100" name="hdName"/>
		</property>
		<property name="hdUrl">
			<column name="hdUrl" length="500"></column>
		</property>
		<property name="hdDate">
			<column name="hdDate" sql-type="Date"></column>
		</property>
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.tao">
	<class name="AttrSize" table="tao_attrsize">
		<id length="50" name="asKey">
			<column length="50" name="asKey" />
			<generator class="uuid" />
		</id>
		<property name="asID">
			<column length="50" name="asID" not-null="true" />
		</property>
		 <property name="asvalue">
        	<column name="asvalue" length="50" />
        </property>
         <property name="astype">
        	<column name="astype" length="10" />
        </property>
         <property name="orders">
        	<column name="orders" length="10" />
        </property>
        	
	</class>
</hibernate-mapping>

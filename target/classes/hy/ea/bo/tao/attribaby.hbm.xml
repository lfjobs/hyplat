<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.tao">
	<class name="AttriBaby" table="tao_attribaby">
		<id length="50" name="abKey">
			<column length="50" name="abKey" />
			<generator class="uuid" />
		</id>
		<property name="abID">
			<column length="50" name="abID" not-null="true" />
		</property>
		<property name="attriname">
			<column length="50" name="attriname" />
		</property>
		 <property name="attrvalue">
        	<column name="attrvalue" length="50" />
        </property>
         <property name="acID">
        	<column name="acID" length="50" />
        </property>
         <property name="orders">
        	<column name="orders" length="10" />
        </property>
         <property name="babyID">
        	<column name="babyID" length="50" />
        </property>
        	
	</class>
</hibernate-mapping>

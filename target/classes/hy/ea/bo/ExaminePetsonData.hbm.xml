<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo">
	<class name="ExaminePersonData" table="DT_EXAMINE_PERSON_DATA">
		<id name="examinePersonKey" length="50">
			<column name="EXAMINE_PERSON_KEY" length="50" />
			<generator class="uuid" />
		</id>
		<property name="examinePersonId">
			<column name="EXAMINE_PERSON_ID" length="50" not-null="true" />
		</property>
		<property name="processAssociationId">
			<column name="PROCESS_ASSOCIATION_ID" length="50" not-null="true" />
		</property>
		<property name="examineDataId">
			<column name="EXAMINE_DATA_ID" length="50"/>
		</property>
		<property name="examineDataName">
			<column name="EXAMINE_DATA_Name" length="50"/>
		</property>
		<property name="examineProcessId">
			<column name="EXAMINE_PROCESS_ID" length="50"  />
		</property>
		<property name="companyId">
			<column name="COMPANY_ID" length="50"  />
		</property>


	</class>
</hibernate-mapping>

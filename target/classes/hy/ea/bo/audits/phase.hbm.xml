<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.audits">
    <class name="Phase" table="dt_au_Phase">
        <id name="phaseKey" length="50">
        	<column name="phaseKey" length="50"/>
        	<generator class="uuid" />
        </id>
         <property name="phaseId">
        	<column name="phaseId" length="50" unique="true" not-null="true"/>
        </property>
          <property name="phaseName">
        	<column name="phaseName" length="50"  />
        </property>
          <property name="orderNum">
        	<column name="orderNum" length="50"  />
        </property>
         <property name="auditType" >
        	<column name="auditType" length="3"/>
        </property>
         <property name="proID" >
        	<column name="proID" length="50"/>
        </property>
         <property name="createDate" >
        	<column name="createDate" length="7" />
        </property>
        <property name="creatorID" >
        	<column name="creatorID" length="50"  />
        </property>
          <property name="companyID">
        	<column name="companyID" length="50" />
        </property>
          <property name="organizationID">
        	<column name="organizationID" length="50" />
        </property>
           <property name="terminal">
        	<column name="terminal" length="3" />
        </property>
    </class>
</hibernate-mapping>

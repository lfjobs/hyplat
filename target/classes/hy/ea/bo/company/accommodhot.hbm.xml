<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.company">
	<class name="AccommodHot" table="DT_AccommodHot">
		<id length="50" name="accommodHotKey">
			<column length="50" name="accommodHotKey" />
			<generator class="uuid" />
		</id>
		<property name="accommodHotID">
			<column length="50" name="accommodHotID" />
		</property>
		<property name="companyID">
			<column length="50" name="companyID" />
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID" />
		</property>
		<property name="accommodID">
			<column length="250" name="accommodID" />
		</property>
		<property name="staffID">
			<column length="250" name="staffID" />
		</property>
		<property name="roomDisPrice">
			<column length="250" name="roomDisPrice" />
		</property>
		<property name="roomAgrPrice">
			<column length="250" name="roomAgrPrice" />
		</property>
		<property name="roomNum">
			<column length="250" name="roomNum" />
		</property>
		<property name="remarks">
			<column length="250" name="remarks" />
		</property>
		<property name="createName">
			<column length="250" name="createName" />
		</property>
		<property name="createDate">
			<column length="250" name="createDate" />
		</property>
		<property name="updateName">
			<column length="250" name="updateName" />
		</property>
		<property name="updateDate">
			<column length="250" name="updateDate" />
		</property>		
		
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.invoicing.voucher">
	<class name="endAccount" table="dt_inv_endAccount">
		<id length="50" name="endaKey">
			<column length="50" name="endaKey" />
			<generator class="uuid" />
		</id>
		<property name="endaID">
			<column length="50" name="endaID" />
		</property>
		<property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
        <property name="companyName">
			<column length="250" name="companyName" />
		</property>
		<property name="endTime">
        	<column sql-type="Date" name="endTime"/>
        </property>
	</class>
</hibernate-mapping>

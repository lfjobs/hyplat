<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                         "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.invoicing">
	<class name="ProjectMCar" table="dt_projectMCar">
		<id length="50" name="mcKey">
			<column length="50" name="mcKey" />
			<generator class="uuid" /> 
		</id>
		<property name="mcID">
			<column length="50" name="mcID" />
		</property>
		<property name="carID">
			<column length="50" name="carID" />
		</property>
		<property name="carCode">
			<column length="50" name="carCode" />
		</property>
		<property name="carNum">
			<column length="50" name="carNum"/>
		</property>
		<property name="engineNum">
        	<column name="engineNum" length="50" />
        </property>
		<property name="carFrameNum">
			<column length="50" name="carFrameNum" />
		</property>
		<property  name="projectID">
			<column length="50" name="projectID" />
		</property>
		
	</class>
</hibernate-mapping>

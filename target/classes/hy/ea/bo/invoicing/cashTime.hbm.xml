<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.invoicing">
	<class name="cashTime" table="dt_cashTime">
		<id length="50" name="cashKey">
			<column length="50" name="cashKey" />
			<generator class="uuid" />
		</id>
		<property name="cashID">
			<column length="50" name="cashID" />
		</property>
		<property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
        <property name="companyName">
			<column length="250" name="companyName" />
		</property>
		<property name="stime">
        	<column sql-type="Date" name="sTime"/>
        </property>
         <property name="num">
			<column length="250" name="num" />
		</property>
	</class>
</hibernate-mapping>

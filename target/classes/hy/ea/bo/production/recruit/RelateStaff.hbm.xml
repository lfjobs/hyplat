<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.production.recruit">
	<class name="RelateStaff" table="dtRelateStaff">
		<id length="50" name="rskey">
			<column length="50" name="rskey" />
			<generator class="uuid" />
		</id>
		<property name="rsId">
			<column length="50" name="rsId"><comment>ID</comment></column>
		</property>
		<property name="staffID">
			<column length="50" name="staffID"><comment>人员ID</comment></column>
		</property>
		<property name="companyID">
			<column  length="50" name="companyID"><comment>公司ID</comment></column>
		</property>
		<property name="createDate">
			<column   name="createDate"><comment>创建时间</comment></column>
		</property>
	</class>
</hibernate-mapping>

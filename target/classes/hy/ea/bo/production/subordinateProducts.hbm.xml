<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
                            
<hibernate-mapping package="hy.ea.bo.production">
	<class name="SubordinateProducts"  table="dtSubordinateProducts">
		<id length="50" name="subProductKey">
			<column length="50" name="subProductKey" />
			<generator class="uuid" />
		</id>
		<property name="subProductID">
			<column length="50" name="subProductID" not-null="true"><comment>逻辑主键</comment></column>
		</property>
		<property name="fieldConID">
			<column length="50" name="fieldConID"><comment>信息字段ID </comment></column>
		</property>
		<property  name="fieldPpID">
			<column length="50" name="fieldPpID"><comment>所属字段ID</comment></column>
		</property>
		<property  name="fieldPpName">
			<column length="250" name="fieldPpName"><comment>所属字段名称</comment></column>
		</property>
		<property  name="textID">
			<column length="50" name="textID"><comment>内容ID</comment></column>
		</property>
		<property  name="content">
			<column length="250" name="content"><comment>内容</comment></column>
		</property>
		<property name="primaryField">
			<column length="50" name="primaryField" ><comment>一级格式</comment></column>
		</property>
		<property name="twoLevelField">
			<column length="50" name="twoLevelField" ><comment>二级格式</comment></column>
		</property>
	</class>
</hibernate-mapping>

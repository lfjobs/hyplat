<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.DrivingSchool.elyc">

    <class name="TbElycTeacherEvaPic" table="Tb_Elyc_TeacherEva_Pic">
        <id length="50" name="etpKey">
            <column length="50" name="etpKey" />
            <generator class="uuid" />
        </id>
        <property name="etpId" type="java.lang.String">
            <column name="etpId"  length="50" ><comment>逻辑ID</comment></column>
        </property>
        <property name="eacherEvaluatetId" type="java.lang.String">
            <column name="eacherEvaluatetId"  length="50" ><comment>/教练评价表ID</comment></column>
        </property>
        <property name="picpath" type="java.lang.String">
            <column name="picpath"  length="250" ><comment>图片路径</comment></column>
        </property>
    </class>
</hibernate-mapping>
<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.DrivingSchool.elyc.TbElycOrderDetailTime" table="Tb_Elyc_Order_Detail_Time" schema="HYPLAT">
        <id length="50" name="odtKey">
            <column length="50" name="odtKey" />
            <generator class="uuid" />
        </id>
        <property name="odtId" type="java.lang.String">
            <column name="odtId"  length="50" ><comment>逻辑ID</comment></column>
        </property>
        <property name="teacherId" type="java.lang.String">
            <column name="teacherId"  length="50" ><comment>关联教练ID</comment></column>
        </property>
        <property name="status" type="java.lang.String">
            <column name="status"  length="1" ><comment>1.已约 2.未约 3.教练员请假</comment></column>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId"  length="50" ><comment>驾校ID</comment></column>
        </property>
        <property name="hours" type="java.lang.Double">
            <column name="hours"  length="50" ><comment>时长</comment></column>
        </property>
        <property name="lessionStartTime" type="java.util.Date">
            <column name="lessionStartTime" length="16" ><comment>课程开始时间</comment></column>
        </property>
        <property name="lessionEndTime" type="java.util.Date">
            <column name="lessionEndTime"  length="50" ><comment>课程结束时间</comment></column>
        </property>
        <property name="createdate" type="java.util.Date">
            <column name="createdate"  ><comment>创建时间</comment></column>
        </property>
        <property name="updatedate" type="java.util.Date">
            <column name="updatedate" length="16" ><comment>更新时间</comment></column>
        </property>
        <property name="createperson" type="java.lang.String">
            <column name="createperson"  length="50" ><comment>创建人ID</comment></column>
        </property>
        <property name="updateperson" type="java.lang.String">
            <column name="updateperson"  length="50" ><comment>修改人</comment></column>
        </property>

    </class>
</hibernate-mapping>
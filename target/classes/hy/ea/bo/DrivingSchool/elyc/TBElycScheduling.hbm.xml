<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="hy.ea.bo.DrivingSchool.elyc.TbElycScheduling" table="tb_elyc_scheduling" schema="HYPLAT">
        <id length="50" name="slKey">
            <column length="50" name="slKey" />
            <generator class="uuid" />
        </id>
        <property name="classId" type="java.lang.String">
            <column name="classId"  length="50" ><comment>逻辑ID</comment></column>
        </property>
        <property name="className" type="java.lang.String">
            <column name="className"  length="50" ><comment>班次名称</comment></column>
        </property>
        <property name="rotateMode" type="java.lang.String">
            <column name="rotateMode"  length="１" ><comment>轮询方式，日，周，目前只做日的</comment></column>
        </property>
        <property name="status" type="java.lang.String">
            <column name="status"  ><comment>启用状态00未启用；01启用</comment></column>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId"  ><comment>公司驾校</comment></column>
        </property>
        <property name="createdate" type="java.util.Date">
            <column name="createdate"><comment>创建时间</comment></column>
        </property>
        <property name="updatedate" type="java.util.Date">
            <column name="updatedate" ><comment>更新时间</comment></column>
        </property>
        <property name="createperson" type="java.lang.String">
            <column name="createperson"  length="50" ><comment>创建人ID</comment></column>
        </property>
        <property name="updateperson" type="java.lang.String">
            <column name="updateperson"  length="50" ><comment>修改人</comment></column>
        </property>

    </class>
</hibernate-mapping>
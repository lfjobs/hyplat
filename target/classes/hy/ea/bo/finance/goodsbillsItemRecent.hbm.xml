<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
    <class name="hy.ea.bo.finance.GoodsBillsItemRecent" table="DTGOODSBILLSITEMRECENT">
        <id length="50" name="key">
            <column length="50" name="KEY"/>
            <generator class="uuid"/>
        </id>
        <property name="id">
            <column name="ID" length="50"/>
        </property>
        <property name="barCode">
            <column name="BARCODE" length="50"/>
        </property>
        <property name="goodsbillsId">
            <column name="GOODSBILLSID" length="50">
                <comment>关联条目id</comment>
            </column>
        </property>
        <property name="flag">
            <column name="FLAG" length="50">
                <comment>添加类型</comment>
            </column>
        </property>
        <property name="staffId">
            <column name="STAFFID" length="50">
                <comment>最近联系人id</comment>
            </column>
        </property>
        <property name="staffName">
            <column name="STAFFNAME" length="50">
                <comment>最近联系人姓名</comment>
            </column>
        </property>
        <property name="createDate">
            <column name="CREATEDATE" length="50">
                <comment>时间</comment>
            </column>
        </property>
        <property name="goodsName">
            <column name="GOODSNAME" length="50">
                <comment>物品名称</comment>
            </column>
        </property>
        <property name="goodsId">
            <column name="GOODSID" length="50">
                <comment>物品id</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

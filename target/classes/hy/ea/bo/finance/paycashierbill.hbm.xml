<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="PayCashierBill" table="dtPayCashierBill">
		<id length="50" name="pcbKey">
			<column length="50" name="gnKey" />
			<generator class="uuid" />
		</id>
		 <property name="pcbID">
        	<column name="pcbID" length="50"/>
        </property>
        <property name="payJournalNum">
        	<column name="payJournalNum" length="50">
        	<comment>支付订单号</comment>
        	</column>
        </property>
         <property name="oriJournalNum">
        	<column name="oriJournalNum" length="50">
        	<comment>原订单号</comment>
        	</column>
        </property>
          <property name="trade_no">
        	<column name="trade_no" length="50">
        	<comment>第三方交易号</comment>
        	</column>
        </property>
		<property name="dtype">
			<column name="dtype" length="10">
				<comment>佣金总金额</comment>
			</column>
		</property>
	</class> 
	
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="CSubjectsRule" table="dtCSubjectsRule">
		<id length="50" name="ruleKey">
			<column length="50" name="ruleKey" />
			<generator class="uuid" />
		</id>
		<property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
		 <property name="ruleID">
        	<column name="ruleID" length="50"/>
        </property>
        <property name="rules">
        	<column name="rules" length="250"/>
        </property>
		 <property name="usableLevel">
        	<column name="usableLevel" length="250"/>
        </property>
         <property name="usedLevel">
        	<column name="usedLevel" length="250"/>
        </property>
	</class>
</hibernate-mapping>

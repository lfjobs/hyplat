<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="hy.ea.bo.finance.brokerage.PActivity" table="dt_pro_activity">
        <id name="activityKey" type="java.lang.String">
            <column name="activityKey" length="50"/>
            <generator class="uuid"/>
        </id>
        <property name="activityId" type="java.lang.String">
            <column name="activityId" length="50">
            </column>
        </property>
        <property name="activityName" type="java.lang.String">
            <column name="activityName" length="50">
                <comment>活动名称</comment>
            </column>
        </property>
        <property name="activityDescribe" type="java.lang.String">
            <column name="activityDescribe" length="200">
                <comment>活动描述</comment>
            </column>
        </property>
        <property name="activityPicture" type="java.lang.String">
            <column name="activityPicture" length="200">
                <comment>活动图片url</comment>
            </column>
        </property>

        <property name="startTime" type="java.util.Date">
            <column name="startTime" length="50">
                <comment>活动起始时间</comment>
            </column>
        </property>
        <property name="endTime" type="java.util.Date">
            <column name="endTime" length="50">
                <comment>活动结束时间</comment>
            </column>
        </property>
        <property name="principal" type="java.lang.String">
            <column name="principal" length="50">
                <comment>设置活动责任人</comment>
            </column>
        </property>
        <property name="addTimes" type="java.util.Date">
            <column name="addTimes" length="50">
                <comment>设置[添加]时间</comment>
            </column>
        </property>
        <property name="updateTimes" type="java.util.Date">
            <column name="updateTimes" length="50">
                <comment>修改时间</comment>
            </column>
        </property>
        <property name="state" type="java.lang.String">
            <column name="state" length="50">
                <comment>活动状态[00:初始 01:已开启 02:暂停 03:结束 04:删除]</comment>
            </column>
        </property>
        <property name="type" type="java.lang.String">
            <column name="type" length="50">
                <comment>活动类型  [00:普通活动  01:特价活动]</comment>
            </column>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId" length="50">
                <comment>公司id</comment>
            </column>
        </property>

    </class>
</hibernate-mapping>

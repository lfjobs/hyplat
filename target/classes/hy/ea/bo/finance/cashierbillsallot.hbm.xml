<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="CashierBillsAllot" table="dtCashierBillsAllot">
		<id length="50" name="cashierBillsAllotKey">
			<column length="50" name="cashierBillsAllotKey" />
			<generator class="uuid" />
		</id>
		 <property name="cashierBillsID">
        	<column name="cashierBillsID" length="50"/>
        </property>
        <property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
         <property name="companyName">
        	<column name="companyName" length="250"/>
        </property>
        <property name="departmentID">
        	<column name="departmentID" length="50"/>
        </property>
        <property name="departmentName">
        	<column name="departmentName" length="250"/>
        </property>
         <property name="staffID">
        	<column name="staffID" length="50"/>
        </property>
        <property name="staffName">
        	<column name="staffName" length="250"/>
        </property>
	</class> 
	
</hibernate-mapping>

<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.finance.BenDis.ProSetupSub" table="DT_PRO_SETUP_SUB" schema="HYPLAT">
        <id name="suskey">
            <column name="SUSKEY" sql-type="varchar2(50)" length="50"/>
            <generator class="uuid"/>
        </id>
        <property name="susid">
            <column name="SUSID" sql-type="varchar2(50)" length="50" not-null="true"/>
        </property>
        <property name="ppid">
            <column name="PPID" sql-type="varchar2(50)" length="50">
                <comment>产品id</comment>
            </column>
        </property>
        <property name="amount">
            <column name="AMOUNT" sql-type="number(10,4)" precision="10">
                <comment>代理佣金</comment>
            </column>
        </property>
        <property name="sjdate">
            <column name="SJDATE" sql-type="date">
                <comment>时间</comment>
            </column>
        </property>
        <property name="suid">
            <column name="SUID" sql-type="varchar2(50)" length="50">
                <comment>产品代理id</comment>
            </column>
        </property>
        <property name="typePpid">
            <column name="TYPE_PPID" sql-type="varchar2(50)" length="50">
                <comment>代理类别id</comment>
            </column>
        </property>
        <property name="agentType">
            <column name="agentType" length="10">
                <comment>招商类型 00贴牌01设备安装02省级代理03县级代理04村级代理</comment>
            </column>
        </property>
        <property name="investComId">
            <column name="investComId" length="50">
                <comment>招商公司id</comment>
            </column>
        </property>
        <property name="agentState">
            <column name="agentState" length="10">
                <comment>招商状态00招商中01招商结束</comment>
            </column>
        </property>
        <property name="textUrl">
            <column name="textUrl" length="200">
                <comment>招商要求</comment>
            </column>
        </property>
        <property name="state">
            <column name="state" length="10">
                <comment>招商抢购状态 00未被抢购；01被已抢购</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>
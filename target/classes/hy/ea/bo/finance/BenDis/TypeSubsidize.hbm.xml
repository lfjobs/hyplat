<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.finance.BenDis.TypeSubsidize" table="DT_TYPE_SUBSIDIZE" schema="HYPLAT">
        <id name="stkey">
            <column name="STKEY" sql-type="varchar2(50)" length="50"/>
        </id>
        <property name="stid">
            <column name="STID" sql-type="varchar2(50)" length="50" not-null="true"/>
        </property>
        <property name="stname">
            <column name="STNAME" sql-type="varchar2(50)" length="50" not-null="true"/>
        </property>
        <property name="stnum">
            <column name="STNUM" sql-type="number(3)" precision="3" not-null="true"/>
        </property>
    </class>
</hibernate-mapping>
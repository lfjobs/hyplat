<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="StaffContact" table="dt_hr_staff_contact">
		<id length="50" name="contactKey">
			<column length="50" name="contactKey" />
			<generator class="uuid" />
		</id>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="staffID">
			<column length="50" name="staffID" not-null="true"/>
		</property>
		<property name="contactID">
			<column length="50" name="contactID" not-null="true"/>
		</property>
		<property name="contactName">
			<column length="250" name="contactName"/>
		</property>
		<property name="contactDate">
			<column length="250" name="contactDate" />
		</property>
		<property  name="contactWay">
			<column length="250" name="contactWay" />
		</property>
		<property  name="contactType">
			<column length="250" name="contactType" />
		</property>
		<property  name="assessor">
			<column length="250" name="assessor" />
		</property>
		<property  name="assessorCode">
			<column length="250" name="assessorCode" />
		</property>
		<property  name="assessorDate">
			<column  name="assessorDate" />
		</property>
		<property  name="contactDesc">
			<column length="250" name="contactDesc" />
		</property>
	</class>
</hibernate-mapping>

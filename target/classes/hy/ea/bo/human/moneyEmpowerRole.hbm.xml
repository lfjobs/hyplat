<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">

	<class name="hy.ea.bo.human.MoneyEmpowerRole" table="DT_MONEY_EMPOWER_ROLE">
		<id length="50" name="empowerRoleKey" >
			<column length="50" name="EMPOWER_ROLE_KEY" />
			<generator class="uuid" />
		</id>
		<property name="empowerId" >
			<column length="50" name="EMPOWER_ID" not-null="true"/>
		</property>
		<property name="roleId" >
			<column length="50" name="ROLE_ID" not-null="true"/>
		</property>
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human.question">
	<class name="ExamAnswer" table="dt_q_ExamAnswer">
		<id length="50" name="eaKey">
			<column length="50" name="eaKey" />
			<generator class="uuid" />
		</id>
		<property name="eaId">
			<column length="50" name="eaId"><comment>ID</comment></column>
		</property>
		<property name="erId">
			<column length="50" name="erId"><comment>关联的考试</comment></column>
		</property>
		<property name="qreID">
			<column length="50" name="qreID"><comment>关联的题目</comment></column>
		</property>
		<property name="qrID">
			<column length="50" name="qrID"><comment>关联的题目</comment></column>
		</property>
		<property name="answer">
			<column length="50" name="answer"><comment>/考生答案 多选用逗号隔开</comment></column>
		</property>
		<property name="score">
			<column length="10" name="score"><comment>得分</comment></column>
		</property>
		<property name="staffID">
			<column length="50" name="staffID"><comment>考生ID</comment></column>
		</property>
		<property name="isCorrect">
			<column length="2" name="isCorrect"><comment>是否正确00正确 01错误</comment></column>
		</property>
		<property name="auditID">
			<column length="50" name="auditID"><comment>审批人员</comment></column>
		</property>
		<property name="auditName">
			<column length="50" name="auditName"><comment>审批人姓名</comment></column>
		</property>
		<property name="auditDate">
			<column  name="auditDate"><comment>审批时间</comment></column>
		</property>
	</class>
</hibernate-mapping>

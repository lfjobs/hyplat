<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human.question">
	<class name="Questions" table="dt_q_Questions">
		<id length="50" name="qrKey">
			<column length="50" name="qrKey" />
			<generator class="uuid" />
		</id>
		<property name="qrID">
			<column length="50" name="qrID"><comment>ID</comment></column>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"><comment>题库类别名称</comment></column>
		</property>
		<property name="staffID">
			<column length="50" name="staffID"><comment>创建人</comment></column>
		</property>
		<property name="staffName">
			<column length="50" name="staffName"><comment>创建人姓名</comment></column>
		</property>
		<property name="seq">
			<column  length="10" name="seq"><comment>序号</comment></column>
		</property>
		<property name="title">
			<column  length="500" name="title"><comment>标题</comment></column>
		</property>
		<property name="correctAnswer">
			<column  length="500" name="correctAnswer"><comment>正确答案</comment></column>
		</property>
		<property name="picpath">
			<column  length="500"  name="picpath"><comment>图片</comment></column>
		</property>
		<property name="quesType">
			<column length="2"  name="quesType"><comment>00 单选 01 多选 02 判断 03 简答题</comment></column>
		</property>
		<property name="score">
			<column  length="10" name="score"><comment>分值</comment></column>
		</property>
		<property name="tqID">
			<column  length="50" name="tqID"><comment>题库ID</comment></column>
		</property>
		<property name="tqeID">
			<column length="50" name="tqeID"><comment>考试ID</comment></column>
		</property>
		<property name="status">
			<column length="2" name="status"><comment>状态</comment></column>
		</property>
		<property name="createDate">
			<column  name="createDate"><comment>时间</comment></column>
		</property>
		<property name="qreID">
			<column length="50" name="qreID"><comment>考试ID</comment></column>
		</property>

	</class>
</hibernate-mapping>

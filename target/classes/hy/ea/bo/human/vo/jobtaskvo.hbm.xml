<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human.vo">
	<class name="COSJobTaskVO" table="dtCOSJobTaskvo">
		<id length="50" name="jobTaskKey">
			<column length="50" name="jobTaskKey" />
			<generator class="uuid" />
		</id>
		<property  name="companyName">
			<column length="250" name="companyName" />
		</property>
		<property  name="organizationName">
			<column length="250" name="organizationName" />
		</property>
		<property name="jobTaskID">
			<column length="50" name="jobTaskID" not-null="true"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID" />
		</property>
		<property name="staffID">
			<column length="50" name="staffID" not-null="true"/>
		</property>
		<property name="neededTime">
			<column length="250" name="neededTime"/>
		</property>
		<property name="taskNumber">
			<column length="250" name="taskNumber"/>
		</property>
		<property name="taskName">
			<column length="250" name="taskName"/>
		</property>
		<property name="startDate">
			<column length="50" name="startDate" />
		</property>
		<property  name="endDate">
			<column length="50" name="endDate" />
		</property>
		<property  name="bonusPoint">
			<column length="250" name="bonusPoint" />
		</property>
		<property  name="penaltyPoint">
			<column length="250" name="penaltyPoint" />
		</property>
		<property  name="checkUpTime">
			<column length="250" name="checkUpTime" />
		</property>
		<property  name="actualperformance">
			<column length="250" name="actualperformance" />
		</property>
		<property  name="actualBonusPoint">
			<column length="250" name="actualBonusPoint" />
		</property>
		<property  name="actualPenaltyPoint">
			<column length="250" name="actualPenaltyPoint" />
		</property>
		<property  name="status">
			<column length="50" name="status" />
		</property>
		<property  name="staffName">
			<column length="250" name="staffName" />
		</property>
		<property  name="staffCode">
			<column length="250" name="staffCode" />
		</property>
		<property  name="codeID">
			<column length="50" name="codeID" />
		</property>
		<property  name="codeValue">
			<column length="50" name="codeValue" />
		</property>
	</class>
</hibernate-mapping>

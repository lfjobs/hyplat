<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="COPayResearch" table="DTCOPayResearch" >
		<id length="50" name="payResearchKey">
			<column length="50" name="payResearchKey" />
			<generator class="uuid" />
		</id>
		<property name="payResearchID">
			<column length="50" name="payResearchID" />
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID" />
		</property>
		<property name="companyID">
			<column length="50" name="companyID" />
		</property>
		<property name="industryCategory">
			<column length="250" name="industryCategory" />
		</property>
		
		<property name="post">
			<column length="250" name="post" />
		</property>
		<property name="salaryRange">
			<column length="250" name="salaryRange" />
		</property>
		
		<property name="workingTenure">
			<column length="250" name="workingTenure"/>
		</property>
		<property name="jobRequirement">
			<column length="250" name="jobRequirement"/>
		</property>
		<property name="remarks">
			<column length="250" name="remarks"/>
		</property>
	</class>
</hibernate-mapping>

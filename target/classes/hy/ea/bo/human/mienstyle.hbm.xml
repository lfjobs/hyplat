<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="MienStyle" table="dtMienStyle">
		<id length="50" name="mienStyleKey">
			<column length="50" name="mienStyleKey" />
			<generator class="uuid" />
		</id>
		<property name="mienStyleID">
			<column length="50" name="mienStyleID" />
		</property>
		<property name="relateID">
			<column length="50" name="relateID" />
		</property>
		<property name="materialID">
			<column length="50" name="materialID" />
		</property>
	</class>
</hibernate-mapping>

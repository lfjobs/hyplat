<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">

	<class name="hy.ea.bo.human.RoleStandard" table="DT_ROLE_STANDARD">
		<id length="50" name="roleKey" >
			<column length="50" name="ROLE_KEY" />
			<generator class="uuid" />
		</id>
		<property name="roleId" >
			<column length="50" name="ROLE_ID" not-null="true"/>
		</property>
		<property name="roleName" >
			<column length="50" name="ROLE_NAME" not-null="true"/>
		</property>
		<property name="roleDesc" >
			<column length="50" name="ROLE_DESC"/>
		</property>
		<property name="createStaffId" >
			<column length="50" name="CREATE_STAFF_ID" />
		</property>
		<property  name="createDate">
			<column length="256" name="CREATE_DATE" />
		</property>
		<property  name="updateDate">
			<column length="256" name="UPDATE_DATE" />
		</property>
	</class>
</hibernate-mapping>

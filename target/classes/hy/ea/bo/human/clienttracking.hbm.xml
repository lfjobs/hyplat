<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="ClientTracking" table="dtClientTracking" >
		<id length="50" name="clientTrackingKey">
			<column length="50" name="clientTrackingKey" />
			<generator class="uuid" />
		</id>
		 <property name="clientTrackingID">
        	<column name="clientTrackingID" length="50"/>
        </property>
		 <property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
		<property name="organizationID">
			<column length="50" name="organizationID" />
		</property>
		<property name="clientCode">
			<column length="250" name="clientCode" />
		</property>
		<property name="clientName">
			<column length="250" name="clientName" />
		</property>
		<property name="clientBespeak">
			<column length="250" name="clientBespeak"/>
		</property>
		<property name="clientAnnal">
			<column length="250" name="clientAnnal"/>
		</property>
		<property name="clientContent">
			<column length="250" name="clientContent"/>
		</property>
		<property name="clientDate">
			<column  name="clientDate" />
		</property>
		<property  name="clientResult">
			<column length="250" name="clientResult" />
		</property>
		<property name="clientEvaluate">
			<column length="250" name="clientEvaluate"/>
		</property>
		<property name="clientFeedback">
			<column length="250" name="clientFeedback"/>
		</property>
		<property name="remark">
			<column  length="256" name="remark" />
		</property>
	</class>
</hibernate-mapping>

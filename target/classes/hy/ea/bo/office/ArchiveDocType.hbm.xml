<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="ArchiveDocType" table="DT_OA_ArchiveDocType">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="adtId" type="java.lang.String">
			<column name="adtId" length="50" />
		</property>

		<property name="typeName" type="java.lang.String">
			<column name="typeName" length="50" />
		</property>

		<property name="time" type="java.util.Date">
			<column name="time" length="7" />
		</property>
		<property name="createrID" type="java.lang.String">
			<column name="createrID" length="50" />
		</property>
		<property name="companyID" type="java.lang.String">
			<column name="companyID" length="50" />
		</property>
		<property name="companyName" type="java.lang.String">
			<column name="companyName" length="50" />
		</property>
		<property name="parentId" type="java.lang.String">
			<column name="parentId" length="50" />
		</property>
		<property name="seq" type="java.lang.Integer">
			<column name="seq" />
		</property>
		<property name="module" type="java.lang.String">
			<column name="module" length="50" />
		</property>
		<property name="createrName" type="java.lang.String">
			<column name="createrName" length="50" />
		</property>
		<property name="arnum" type="java.lang.String">
			<column name="arnum" length="10" />
		</property>
		<property name="barCode" type="java.lang.String">
			<column name="barCode" length="50" />
		</property>
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="carSeat" table="dt_car_seat">
		<id length="50" name="seatKey">
			<column length="50" name="seatKey" />
			<generator class="uuid" />
		</id>
		<property name="seatID">
			<column length="50" name="seatID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="quasiID">
			<column length="50" name="quasiID"/>
		</property>
		<property name="seatNum">
			<column length="250" name="seatNum"/>
		</property>
	</class>
</hibernate-mapping>

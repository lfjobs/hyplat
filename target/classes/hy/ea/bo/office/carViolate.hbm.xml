<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="carViolate" table="DT_CAR_CARVIOLATE">
		<id length="50" name="carviolateKey">
			<column length="50" name="carviolateKey" />
			<generator class="uuid" />
		</id>
		<property name="carviolateID">
			<column length="50" name="carviolateID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID" />
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID" />
		</property>
		<property name="carID">
			<column length="50" name="carID"/>
		</property>
		<property name="carType">
			<column length="250" name="carType"/>
		</property>
		<property name="carNum">
			<column length="250" name="carNum"/>
		</property>
		<property name="violatePeople">
			<column length="250" name="violatePeople"/>
		</property>
		<property  name="violateDate">
			<column  name="violateDate" />
		</property>
		<property  name="violateReason">
			<column length="250"  name="violateReason" />
		</property>
		<property  name="treatment">
			<column length="250"  name="treatment" />
		</property>
		<property  name="remark">
			<column length="250"  name="remark" />
		</property>
		<property  name="engineNum">
			<column length="250" name="engineNum" />
		</property>
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="MeetingRoomOrder" table="dtMeetingRoomOr">
		<id length="50" name="mroomoKey">
			<column length="50" name="mroomoKey" />
			<generator class="uuid" />
		</id>
		<property name="mroomoID">
			<column length="50" name="mroomoID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="meetingName">
			<column length="50" name="meetingName"/>
		</property>
		<property name="meetingTheme">
			<column length="250" name="meetingTheme"/>
		</property>
			<property name="staffID">
			<column length="50" name="staffID"/>
		</property>
		<property name="staffName">
			<column length="50" name="staffName"/>
		</property>
			<property name="orderTel">
			<column length="50" name="orderTel"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
			<property name="organizationName">
			<column length="50" name="organizationName"/>
		</property>
		<property name="mroomID">
			<column length="50" name="mroomID"/>
		</property>
			<property name="startDate">
			<column length="50" name="startDate"/>
		</property>
		<property name="endDate">
			<column length="50" name="endDate"/>
		</property>
		
		<property name="startDates">
			<column length="50" name="startDates"/>
		</property>
			<property name="endDates">
			<column length="50" name="endDates"/>
		</property>
			<property name="startTime">
			<column length="50" name="startTime"/>
		</property>
			<property name="endTime">
			<column length="50" name="endTime"/>
		</property>
			<property name="dates">
			<column length="50" name="dates"/>
		</property>
	    <property name="startDay">
			<column length="17" name="startDay"/>
		</property>
		<property name="endDay">
			<column length="17" name="endDay"/>
		</property>
					<property name="startDays">
			<column length="50" name="startDays"/>
		</property>
			<property name="endDays">
			<column length="50" name="endDays"/>
		</property>
	<property name="cancel">
			<column length="5" name="cancel"/>
		</property>
	<property name="quote">
			<column length="5" name="quote"/>
		</property>
	</class>
</hibernate-mapping>

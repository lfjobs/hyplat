<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="ComplaintDealer" table="DT_OA_COMPLAINTDEALER">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="Id" type="java.lang.String">
			<column name="Id" length="50" />
		</property>
		<property name="dealerID" type="java.lang.String">
			<column name="dealerID" length="50" />
		</property>
		<property name="dealerName" type="java.lang.String">
			<column name="dealerName" length="50" />
		</property>
		<property name="companyID" type="java.lang.String">
			<column name="companyID" length="50" />
		</property>
		<property name="createTime" type="java.util.Date">
			<column name="createTime" length="50" />
		</property>
		<property name="updateTime" type="java.util.Date">
			<column name="updateTime" length="50" />
		</property>

	</class>
</hibernate-mapping>

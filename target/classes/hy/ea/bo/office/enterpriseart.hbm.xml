<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="EnterpriseArt" table="dtEnterpriseArt">
		<id length="50" name="enterpriseArtKey">
			<column length="50" name="enterpriseArtKey" />
			<generator class="uuid" />
		</id>
		<property name="enterpriseArtID">
			<column length="50" name="enterpriseArtID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property> 
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="enPerson">
			<column length="250" name="enPerson"/>
		</property>
		<property name="enName">
			<column length="250" name="enName"/>
		</property>
		<property name="enSubject">
			<column length="250" name="enSubject" />
		</property>
		<property name="enType">
			<column length="24" name="enType" />
		</property>
		<property name="enDiscuss">
			<column length="250" name="enDiscuss" />
		</property>
		<property  name="artFilePath">
			<column   name="artFilePath" />
		</property>
		<property  name="mark">
			<column length="250"  name="mark" />
		</property> 
	</class>
</hibernate-mapping>

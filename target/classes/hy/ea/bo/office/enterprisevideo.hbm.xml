<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="EnterpriseVideo" table="dtEnterpriseVideo">
		<id length="50" name="enterpriseVideoKey">
			<column length="50" name="enterpriseVideoKey" />
			<generator class="uuid" />
		</id>
		<property name="enterpriseVideoID">
			<column length="50" name="enterpriseVideoID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="enName">
			<column length="250" name="enName"/>
		</property>
		<property name="enSubject">
			<column length="250" name="enSubject" />
		</property>
		<property name="enDate">
			<column   name="enDate" />
		</property>
		<property  name="videoPath">
			<column   name="videoPath" />
		</property>
		<property  name="mark">
			<column length="250"  name="mark" />
		</property> 
	</class>
</hibernate-mapping>

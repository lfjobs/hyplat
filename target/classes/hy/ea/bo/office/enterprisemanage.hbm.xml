<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="EnterpriseManage" table="dtEnterpriseManage">
		<id length="50" name="manageKey">
			<column length="50" name="manageKey" />
			<generator class="uuid" />
		</id>
		<property name="manageID">
			<column length="50" name="manageID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="manageContent">
			<column length="256" name="manageContent" />
		</property>
		<property  name="manageIdea">
			<column length="250" name="manageIdea" />
		</property>
		<property  name="manageNote">
			<column length="250" name="manageNote" />
		</property>
	</class>
</hibernate-mapping>

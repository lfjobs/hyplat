<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="FeeScale" table="DT_FEESCALE">
		<id length="50" name="feeckey">
			<column length="50" name="feeckey" />
			<generator class="uuid" />
		</id>
		<property name="feecID">
			<column length="50" name="feecID">
				<comment>主键</comment>
			</column>
		</property>
		<property  name="siteId">
			<column length="50" name="siteId">
				<comment>场地id</comment>
			</column>
		</property>
		<property  name="staffID">
			<column length="50" name="staffID">
				<comment>责任人ID</comment>
			</column>
		</property>
		<property  name="staffName">
			<column length="50" name="staffName">
				<comment>责任人</comment>
			</column>
		</property>
		<property  name="CompanyID">
			<column length="50" name="CompanyID">
				<comment>公司ID</comment>
			</column>
		</property>
		<property  name="chargeNumber">
			<column length="50" name="chargeNumber">
				<comment>收费编号</comment>
			</column>
		</property>
		<property  name="goodsID">
			<column length="50" name="goodsID">
				<comment>收费物品id</comment>
			</column>
		</property>
		<property  name="startUsing">
			<column length="10" name="startUsing">
				<comment>00:启用,01:未启用,02:已删除</comment>
			</column>
		</property>
		<property  name="timeUnits">
			<column length="1" name="timeUnits">
				<comment>时间单位  0小时 1：天 2：月 3:年</comment>
			</column>
		</property>
		<property  name="feeMini">
			<column length="10" name="feeMini">
				<comment>免费时长单位分钟</comment>
			</column>
		</property>
		<property  name="carType">
			<column length="1" name="carType">
				<comment>车类型 p：私家车  c:教练车</comment>
			</column>
		</property>
		<property  name="timeType">
			<column length="2" name="timeType">
				<comment>小时制 如果是包天 是几小时制度  24小时 8小时等，或者当天</comment>
			</column>
		</property>
		<property  name="tripTime">
			<column length="20" name="tripTime">
				<comment>超过多长时间跳价位</comment>
			</column>
		</property>
		<property  name="isTotalPct">
			<column length="1" name="isTotalPct">
				<comment>0未使用 1使用 是否使用消费红包</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>

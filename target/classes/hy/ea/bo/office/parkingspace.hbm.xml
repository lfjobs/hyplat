<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
                                   
<hibernate-mapping package="hy.ea.bo.office">
	<class name="ParkingSpace" table="DT_ParkingSpace">
		<id length="50" name="parkskey">
			<column length="50" name="parkskey" />
			<generator class="uuid" />
		</id>
		<property name="parksId">
			<column length="50" name="parksId">
				<comment>主键</comment>
			</column>
		</property>
		<property name="siteId">
			<column length="50" name="siteId">
				<comment>场地id</comment>
			</column>
		</property>
		<property name="companyId">
			<column length="50" name="companyId">
				<comment>所属公司id</comment>
			</column>
		</property>
		<property name="parkingCode">
			<column length="50" name="parkingCode">
				<comment>停车位编号 自动生成</comment>
			</column>
		</property>
		<property name="parkingName">
			<column length="50" name="parkingName">
				<comment>停车位人工命名</comment>
			</column>
		</property>
		<property name="createDate">
			<column  name="createDate">
				<comment>创建时间</comment>
			</column>
		</property>
		<property name="staffId">
			<column length="50" name="staffId">
				<comment>创建人id</comment>
			</column>
		</property>
		<property name="staffName">
			<column length="50" name="staffName">
				<comment>创建人姓名</comment>
			</column>
		</property>
		<property name="status">
			<column length="2" name="status">
				<comment>00 没有占用  01 已占用址</comment>
			</column>
		</property>

		<property name="carType">
			<column length="50" name="carType">
				<comment>适用车型</comment>
			</column>
		</property>
		<property name="parkingLength">
			<column length="10" name="parkingLength">
				<comment>车位长度</comment>
			</column>
		</property>
		<property name="parkingWidth">
			<column length="10" name="parkingWidth">
				<comment>车位宽度</comment>
			</column>
		</property>

		
		

	</class>
</hibernate-mapping>

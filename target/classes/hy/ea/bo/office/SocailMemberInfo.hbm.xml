<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="SocialMemberInfo" table="DT_OA_DOC_SMI">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="smId" type="java.lang.String">
			<column name="smId" length="50" />
		</property>
		<property name="companyName" type="java.lang.String">
			<column name="companyName" length="50" />
		</property>
		<property name="smName" type="java.lang.String">
			<column name="smName" length="255" />
		</property>
		<property name="telphone" type="java.lang.String">
			<column name="telphone" length="50" />
		</property>
		<property name="creatorID" type="java.lang.String">
			<column name="creatorID" length="50" />
		</property>
		<property name="createTime" type="java.util.Date">
			<column name="createTime" length="7" />
		</property>
	</class>
</hibernate-mapping>

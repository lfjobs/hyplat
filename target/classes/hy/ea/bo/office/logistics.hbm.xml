<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="Logistics" table="dtLogistics">
		<id length="50" name="logisticsKey">
			<column length="50" name="logisticsKey" />
			<generator class="uuid" />
		</id>
		<property name="logisticsID">
			<column length="50" name="logisticsID"/>
		</property>
		<property name="staffName">
			<column length="250" name="staffName"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="penskelogistics">
			<column length="250" name="penskelogistics" />
		</property>
		<property  name="principal">
			<column length="250" name="principal" />
		</property>
		<property  name="goodsName">
			<column length="250" name="goodsName" />
		</property>
		<property  name="waybillNum">
			<column length="250" name="waybillNum" />
		</property>
		<property  name="quantity">
			<column length="250" name="quantity" />
		</property>
		<property  name="carrier">
			<column  length="250" name="carrier" />
		</property>
		<property  name="startDate">
			<column  name="startDate" />
		</property>
		<property  name="endDate">
			<column  name="endDate" />
		</property>
		<property  name="remark">
			<column length="256" name="remark" />
		</property>
		<property  name="state">
			<column length="2" name="state" />
		</property>
	</class>
</hibernate-mapping>

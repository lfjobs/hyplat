<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo">
	<class name="ExamineProcessData" table="DT_EXAMINE_PROCESS_DATA">
		<id name="examineProcessKey" length="50">
			<column name="EXAMINE_PROCESS_KEY" length="50" />
			<generator class="uuid" />
		</id>
		<property name="examineProcessId">
			<column name="EXAMINE_PROCESS_ID" length="50" not-null="true" />
		</property>
		<property name="processType">
			<column name="PROCESS_TYPE" length="50"/>
		</property>
		<property name="processAssociationId">
			<column name="PROCESS_ASSOCIATION_ID" length="50" />
		</property>
		<property name="examineStatus">
			<column name="EXAMINE_STATUS" length="1" />
		</property>
		<property name="examineStaffId">
			<column name="EXAMINE_STAFF_ID" length="50" />
		</property>
		<property name="examineStaffName">
			<column name="EXAMINE_STAFF_NAME" length="50" />
		</property>
		<property name="examineDate">
		   <column name="EXAMINE_DATE" length="50"/>
		</property>
		<property name="examineRemark">
			<column name="EXAMINE_REMARK" length="250" />
		</property>
		<property name="companyId">
			<column name="COMPANY_ID" length="50" />
		</property>

	</class>
</hibernate-mapping>

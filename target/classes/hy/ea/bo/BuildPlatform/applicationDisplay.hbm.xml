<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.BuildPlatform">
	<class name="ApplicationDisplay" table="dt_ApplicationDisplay">
		<id length="50" name="appDisKey">
			<column length="50" name="appDisKey" />
			<generator class="uuid" />
		</id>
		<property name="appDisId">
			<column length="50" name="appDisId" not-null="true" />
		</property>
		 <property name="staffId">
        	<column name="staffId" length="50"  not-null="true"/>
        </property>
        	<property name="ppId">
        	<column name="ppId" length="50" not-null="true"/>
        </property>	
	</class>
</hibernate-mapping>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>	
	<package strict-method-invocation="false" name="organization-token" namespace="/ea/organization"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.human.action.COrganizationAction" method="{1}">
			<result name="list">/page/ea/main/human/organization/organization_list.jsp</result>
			<result name="to_allot">/page/ea/main/human/organization/organization.jsp</result>
			<result name="invalid.token" type="redirectAction">ea_getOrganizationListAll</result>
		    <result name="organizationlist">/page/ea/main/human/organization/organization_list.jsp</result>
		    <result name="subordinateList">/page/ea/main/human/organization/organization_subordinate_list.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="organization-ntoken" namespace="/ea/organization"   extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.COrganizationAction" method="{1}">
		
			<result name="subordinateList">/page/ea/main/human/organization/organization_subordinate_list.jsp</result>
			<result name="subordinateToAdd">/page/ea/main/human/organization/organization_subordinate_add.jsp</result>
			<result name="sortchildren">/page/ea/main/human/organization/organization_sortchildren.jsp</result>
			<result name="list">/page/ea/main/human/organization/organization.jsp</result>
			<result name="add">/page/ea/main/human/organization/organization_add.jsp</result>
			<result name="organizationlist">/page/ea/main/human/organization/organization_list.jsp</result>
			<result name="mylist">/page/ea/main/human/organization/excelshow.jsp</result>
			<result name="staffForCashier">/page/ea/main/finance/personal_department/cashierbills_jqm_cstaffs.jsp</result>
			<result name="registAlllist">/page/ea/main/office_ea/companyRegist/comRegist_search.jsp</result>
		<!-- 导出EXCEL -->
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="organization.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>		
	</package>
	<package strict-method-invocation="false" name="organization-jsonajax" namespace="/ea/organization" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.COrganizationAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

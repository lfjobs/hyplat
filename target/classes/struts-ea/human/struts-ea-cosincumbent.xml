<?xml version="1.0" encoding="UTF-8" ?>
<!-- 人事-正式员工管理 --> 
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="cosincumbent-token" namespace="/ea/cosincumbent"
		extends="ea-token">
		<action name="t_ea_*"
			class="hy.ea.human.action.SEmploymentAction" method="{1}">
		</action>
	</package>
	<package strict-method-invocation="false" name="cosincumbent-ntoken" namespace="/ea/cosincumbent"
		extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.SEmploymentAction" method="{1}">
			<param name="args">99_10_50_50_50_50</param>
			<result name="to_employment">
				/page/ea/main/human/office/personal_department/personal_incumbent.jsp
			</result>
			<result name="to_incumbents">
				/page/ea/main/human/office/personal_department/personal_incumbents.jsp
			</result>
			<result name="staffForCashier">/page/ea/main/finance/personal_department/cashierbills_jqm_cstaffs.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="staff.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cosincumbent-jsonajax" namespace="/ea/cosincumbent"
		extends="ea-sajax">
		<action name="sajax_ea_*"
			class="hy.ea.human.action.SEmploymentAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cosincumbent-njsonajax" namespace="/ea/cosincumbent"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.human.action.SEmploymentAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>




<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="goldticket-ntoken"  namespace="/ea/goldticket"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.GoldTicketAction" method="{1}">
			<result name="goldTicketList">/page/ea/main/office_ea/GoldTicket.jsp</result>
			<result name="account">/page/ea/main/finance/personal_department/goldticket_cstaffs.jsp</result>
			<result name="details">/page/ea/main/office_ea/GoldTicketDetails.jsp</result>
			<result name="print">/page/ea/main/office_ea/GoldTicketPrint.jsp</result>
			<result name="syserror">/page/ea/sys_error.jsp</result>
			
			<result name="showrankexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="RankPublicreceipts.xls"
				</param>

			</result>
				
			<result name="showoverexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="OverPublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
					
			<result name="showleaveexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="LeavePublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result> 
			
			<result name="showrewardexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="OverPublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>			
		</action>
	</package>
	<package strict-method-invocation="false" name="goldticket-jsonajax" namespace="/ea/goldticket" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.GoldTicketAction" method="{1}">
		<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>
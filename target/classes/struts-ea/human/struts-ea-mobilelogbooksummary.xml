<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="mobilelogbooksummary-token" namespace="/ea/mobilelogbooksummary"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.human.action.MobileLogBookSummaryAction" method="{1}">
		     <result name="list">/page/mobile/main/human/office/production/LogBookSummary.jsp</result>
		     <result name="clist">/page/ea/main/human/office/company/companyLogBookSummary.jsp</result>
		     <result name="logBookPing">/page/ea/main/human/office/production/C.jsp</result>
		</action>
	</package>
	<!-- <package strict-method-invocation="false" name="mobilelogbooksummary-ntoken" namespace="/ea/mobilelogbooksummary"  extends="ea-ntoken"> -->
	<package strict-method-invocation="false" name="mobilelogbooksummary-ntoken" namespace="/ea/mobilelogbooksummary"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.MobileLogBookSummaryAction" method="{1}">
			 <result name="list">/page/mobile/main/human/office/production/LogBookSummary.jsp</result>
			  <result name="LogBookIntegral">/page/ea/main/human/office/production/SalaryIntergral.jsp</result>
			  <result name="cIntegral">/page/ea/main/human/office/company/companySalaryIntergral.jsp</result>
			  <result name="clist">/page/ea/main/human/office/company/companyLogBookSummary.jsp</result>
			  <result name="logBookPing">/page/ea/main/human/office/production/printLogbookSummary.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilitiessummary.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="mobilelogbooksummary-jsonajax" namespace="/ea/mobilelogbooksummary" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.human.action.LogBookSummaryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="mobilelogbooksummary-njsonajax" namespace="/ea/mobilelogbooksummary"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.human.action.MobileLogBookSummaryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

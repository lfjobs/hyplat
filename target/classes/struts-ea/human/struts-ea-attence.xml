<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="attence-ntoken" namespace="/ea/attence"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.attence.AttenceMangeAction" method="{1}">
			<result name="grouplist">/page/ea/main/human/attence/attenceGrouplist.jsp</result>
			<result name="rulelist">/page/ea/main/human/attence/attenceRulelist.jsp</result>
			<result name="classlist">/page/ea/main/human/attence/ruleClasseslist.jsp</result>
			<result name="recordlist">/page/ea/main/human/attence/attenceRecordlist.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			 <result name="excelnormal" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="xcelnormal".xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			 <result name="excelcate" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="excelcate.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="attence-jsonajax" namespace="/ea/attence" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.attence.AttenceMangeAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

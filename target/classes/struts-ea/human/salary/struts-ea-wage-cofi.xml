<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="cofi-ntoken" namespace="/ea/cofi"   extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.salary.WageCofiAction" method="{1}">
		     <result name="itemList">/page/ea/main/human/salary/wageCofi.jsp</result>
		     <result name="success">/page/ea/success.jsp</result> 
		</action>
	</package>
	<package strict-method-invocation="false" name="cofi-jsonajax" namespace="/ea/cofi" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.salary.WageCofiAction" method="{1}">
            <result type="json">  
                <param name="root">result</param>
            </result>  
		</action>
	</package>
</struts>

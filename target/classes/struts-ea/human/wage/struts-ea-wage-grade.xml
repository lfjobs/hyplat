<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="wgrade-ntoken" namespace="/ea/wgrade"   extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.wage.WageGradeAction" method="{1}">
		     <result name="wageGrade">/page/ea/main/human/wage/wageGrade.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="wgrade-jsonajax" namespace="/ea/wgrade" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.wage.WageGradeAction" method="{1}">
            <result type="json">  
                <param name="root">result</param>  
            </result>
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!-- 人事-正式员工汇总 -->
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="staffappraisal-token" namespace="/ea/staffappraisal"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.human.action.StaffAppraisalAction" method="{1}">
		  <result name="list">/page/ea/main/human/office/personal_department/personal_staffappraisal.jsp</result>
		  <result name="success">/page/ea/success.jsp</result>
		  <result name="fail">/page/ea/fail.jsp</result>
		</action>
	</package> 
	<package strict-method-invocation="false" name="staffappraisal-ntoken" namespace="/ea/staffappraisal"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.StaffAppraisalAction" method="{1}">
			  <result name="list">/page/ea/main/human/office/personal_department/personal_staffappraisal.jsp</result>
			  <result name="success">/page/ea/success.jsp</result>
			  <result name="fail">/page/ea/fail.jsp</result>
		<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="logbook.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="staffappraisal-jsonajax" namespace="/ea/staffappraisal" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.human.action.StaffAppraisalAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="staffappraisal-njsonajax" namespace="/ea/staffappraisal" extends="json-default">
		<action name="sajax_n_ea_*" class="hy.ea.human.action.StaffAppraisalAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

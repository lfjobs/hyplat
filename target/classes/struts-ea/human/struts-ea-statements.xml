<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="statements-ntoken" namespace="/ea/statements"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.StaffSumStatementsAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
			<result name="list">/page/ea/main/human/cstaff/sum_info/statements.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="statementsc" namespace="/ea/statements"   extends="jfreechart-default">
		<action name="jfreechart_ea_*" class="hy.ea.human.action.StaffSumStatementsAction" method="{1}">
		       <result name="success" type="chart">
			   <param name="height">600</param> 
               <param name="width">1100</param> 
			  </result>
		</action>
	</package>
</struts>

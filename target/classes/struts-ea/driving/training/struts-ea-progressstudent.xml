<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="progressstudent-ntoken" namespace="/ea/progressstudent" extends="struts-default">
		<action name="ea_*" class="hy.ea.driving.action.ProgressStudentAction" method="{1}">
			<result name="list">/page/ea/main/driving/training/progressStudent.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="fail">/page/ea/fail.jsp</result>
			<result name="syserror">/page/ea/sys_error.jsp</result>
		    <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="drivingList.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="progressstudent-sajax" namespace="/ea/progressstudent" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.driving.action.ProgressStudentAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">results</param>  
            </result>  

		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="digitalmall-token" namespace="/ea/digitalmall" extends="struts-default">
		<action name="ea_*" class="com.tiantai.wfj.front.DigitalMallAction" method="{1}">
			<result name="digitalmall">/page/WFJClient/DigitalMall/DigitalMall_New.jsp</result>
			<result name="search_one">/page/WFJClient/DigitalMall/SearchList_One.jsp</result>
			<result name="search_two">/page/WFJClient/DigitalMall/SearchList_Two.jsp</result>
			<result name="digitalmallad">/page/WFJClient/DigitalMall/DigitalMallAD.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="digitalmall-jsonajax" namespace="/ea/digitalmall" extends="json-default">
		<action name="sajax_ea_*" class="com.tiantai.wfj.front.DigitalMallAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>
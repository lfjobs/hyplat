<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
 	 <include file="struts-constant.xml"></include>  
	<package strict-method-invocation="false" name="android-sajax" namespace="/ea/android" extends="json-default">
		<action name="sajax_ea_*" class="androidAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
  				<param name="contentType">text/html</param>
                <param name="root">result</param>  
            </result>
		</action>
		<action name="stock_*" class="mobile.tiantai.android.action.StockAndroidAction" method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>
			</result>
			<!--<result name="success">/page/ea/test.jsp</result>-->
		</action>
		<action name="stockTest_*" class="mobile.tiantai.android.action.StockAndroidAction" method="{1}">
			<result name="success">/page/ea/test.jsp</result>
		</action>
		<action name="product_sajax_*" class="mobile.tiantai.android.action.ProductAndroidAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
  				<param name="contentType">text/html</param>
                <param name="root">result</param>  
            </result>
		</action>
		<action name="shop_ajax_*" class="shopAction" method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>  
			</result>
		</action>
		<action name="huiyuan_ajax_*" class="huiyuanAction" method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>  
			</result>
		</action>
		<action name="mobileNews_*" class="mobileNewsAction"  method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>  
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="test" namespace="/ea/android" extends="json-default">
        <action name="androidAction_*" class="androidAction"  method="{1}">  
         	<result name="images" type="json">list</result>
            <result name="uploadfile"></result>  
        </action>
		<action name="stockAction_*" class="mobile.tiantai.android.action.StockAndroidAction"  method="{1}">
			<result name="uploadfile"></result>
		</action>
	</package>
	<package strict-method-invocation="false" name="videocon-sajaxs" namespace="/ea/android" extends="json-default">
		<action name="video_*" class="mobile.tiantai.android.action.VideoConfreAction" method="{1}">
	<!-- 返回类型为json 在sjon-default中定义 -->  
			<result type="json">  
				<!-- root的值对应要返回的值的属性 -->    
				<!-- 这里的result值即是 对应action中的 result -->  
				<param name="root">result</param>  
			</result>
		</action>
	</package>
	
</struts>

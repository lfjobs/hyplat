<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="namecard-sajax" namespace="/ea/namecard"
		extends="json-default">
		<action name="sajax_ea_*" class="nameCardAction"
			method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>
			</result>
		</action>

		<action name="personal_ajax_*" class="mobile.tiantai.android.action.PersonalAction" method="{1}">
			<result type="json">
				<param name="contentType">text/html</param>
				<param name="root">result</param>
			</result>	
		</action>
	</package>	
</struts>

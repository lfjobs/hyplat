			<result name="arvbox">/page/ea/main/office_ea/contract/archiveBoxView.jsp</result>
			<result name="pdfaudit">/page/ea/main/office_ea/contract/pdfViewAd.jsp</result>
			<result name="toall">/page/WFJClient/pc/5l5C/office/documentListNew.jsp</result>

		</action>
	</package>
</struts>

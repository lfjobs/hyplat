<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
 	 <include file="struts-constant.xml"></include>
	<package strict-method-invocation="false" name="elkc-sajax" namespace="/ea/elkc" extends="json-default">
		<action name="sajax_ea_*" class="elkcAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
  				<param name="contentType">text/html</param>
                <param name="root">result</param>  
            </result>
		</action>

    </package>
</struts>

            <result name="selectCompany">/page/WFJClient/pc/5l5C/selectCompanyActivity.jsp</result>
            <result name="work5l5c">/page/WFJClient/pc/5l5C/menuFunclayer.jsp</result>

        </action>
    </package>
    <package strict-method-invocation="false" name="5l5c-jsonajax" namespace="/ea/5l5c" extends="json-default">
        <action name="sajax_ea_*" class="com.tiantai.wfj.front.Office5L5CAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>

        </action>
    </package>

</struts>

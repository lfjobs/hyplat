<struts>
    <package strict-method-invocation="false" name="5l5c-token" namespace="/ea/5l5c" extends="struts-default">

        <action name="ea_*" class="com.tiantai.wfj.front.Office5L5CAction" method="{1}">
            <result name="success">/page/ea/success.jsp</result>
            <result name="index5l5c">/page/WFJClient/pc/5l5C/5l5cindex.jsp</result>
            <!--<result name="work5l5c">/page/WFJClient/pc/5l5C/5l5cwork.jsp</result>
            <result name="0">/page/WFJClient/pc/5l5C/funclayer.jsp</result>
            <result name="1">/page/WFJClient/pc/5l5C/funclayer.jsp</result>
            <result name="2">/page/WFJClient/pc/5l5C/funclayer.jsp</result>
            <result name="3">/page/WFJClient/pc/5l5C/funclayer.jsp</result>
            <result name="4">/page/WFJClient/pc/5l5C/funclayer.jsp</result>
            <result name="5">/page/WFJClient/pc/5l5C/funclayergys.jsp</result>

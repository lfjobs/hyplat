<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="carapply-token" namespace="/ea/carapply"   extends="struts-default">
		<action name="ea_*" class="com.mysl.action.administrative.CarApplyAction" method="{1}">
		      <result name="carapplylist">/page/mysl/administrative/carapply.jsp</result>
		      <result name="printcarapply">/page/mysl/administrative/carapply_print.jsp</result>
		      <result name="tocarapplyDetail">/page/mysl/administrative/carapply_detail.jsp</result>
		      <result name="carapplylistysh">/page/mysl/administrative/carapplyyb.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		      <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="carapply.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			 <result name="showexcelcarlog" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="carlog.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="carapply-jsonajax" namespace="/ea/carapply" extends="json-default">
		<action name="sajax_ea_*" class="com.mysl.action.administrative.CarApplyAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

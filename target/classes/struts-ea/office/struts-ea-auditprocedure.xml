<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="procedure-ntoken" namespace="/ea/procedure"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.AuditProcedureAction" method="{1}">
			 <result name="procedurelist">/page/ea/main/office_ea/audits/procedure.jsp</result>
			 <result name="savesuc">/page/ea/main/office_ea/audits/savesuccess.jsp</result>
			 <result name="edit">/page/ea/main/office_ea/audits/editprocedure.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			 <result name="auditlist">/page/ea/main/office_ea/audits/auditFrame.jsp</result>
			 <result name="unaudit">/page/ea/main/office_ea/audits/unAudit.jsp</result>
			
		</action>
	</package>

	<package strict-method-invocation="false" name="procedure-njsonajax" namespace="/ea/procedure"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.office.action.AuditProcedureAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

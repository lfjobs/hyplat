<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
    <struts>
    <constant name="struts.i18n.encoding" value="gb2312" /> 
    <package strict-method-invocation="false" name="carsafeinformation-token" namespace="/ea/carsafeinformation"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.office.action.CarSafeInformationAction" method="{1}">
		      <result name="getCarsafeinformationList">/page/ea/main/office_ea/car_safeinfo.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="carsafeinformation-ntoken" namespace="/ea/carsafeinformation"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.CarSafeInformationAction" method="{1}">
			 <result name="getCarsafeinformationList">/page/ea/main/office_ea/car_safeinfo.jsp</result>
			 <result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="CarSafeInformation.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="carsafeinformation-jsonajax" namespace="/ea/carsafeinformation" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.office.action.CarSafeInformationAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="carsafeinformation-njsonajax" namespace="/ea/carsafeinformation"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.office.action.CarSafeInformationAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
    </struts>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>

	<package strict-method-invocation="false" name="documentsummary-ntoken" namespace="/ea/documentsummary" extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.DocSummaryAction" method="{1}">			
			<result name="tosummarylist">/page/ea/main/office_ea/docSummary/summaryDocList.jsp</result>
			<result name="tooverduelist">/page/ea/main/office_ea/docSummary/overdueDocList.jsp</result>
			<result name="toPreview">/page/ea/main/office_ea/docSummary/printPreview.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			
		</action>
	</package>
	<package strict-method-invocation="false" name="documentsummary-jsonajax" namespace="/ea/documentsummary" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.DocSummaryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

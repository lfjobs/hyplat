<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>

	<package strict-method-invocation="false" name="photomanager-ntoken" namespace="/ea/photomanager" extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.PhotoManagerAction" method="{1}">
			<result name="corPhotoBoxlist">/page/ea/main/office_ea/fileCabinet/photoManager.jsp</result>
			<result name="corPhotoBoxSortlist">/page/ea/main/office_ea/fileCabinet/photoBoxSort.jsp</result>
			<result name="toPhotolist">/page/ea/main/office_ea/fileCabinet/photoList.jsp</result>
			<result name="toPhotoSortlist">/page/ea/main/office_ea/fileCabinet/photoListSort.jsp</result>
			<result name="toSlidelist">/page/ea/main/office_ea/fileCabinet/photoSlideList.jsp</result>
			<result name="toWalllist">/page/ea/main/office_ea/fileCabinet/photoWallList.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="photomanager-jsonajax" namespace="/ea/photomanager" extends="json-default">
		<action name="sajax_n_ea_*" class="hy.ea.office.action.PhotoManagerAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="enterprisestamp-token" namespace="/ea/enterprisestamp"   extends="struts-default">
		<action name="t_ea_*" class="hy.ea.office.action.EnterpriseStampAction" method="{1}">
		      <result name="enterprisestamp">/page/ea/main/office_ea/corporationcode/EnterpriseStamp.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="enterprisestamp-ntoken" namespace="/ea/enterprisestamp"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.EnterpriseStampAction" method="{1}">
			 <result name="enterprisestamp">/page/ea/main/office_ea/corporationcode/EnterpriseStamp.jsp</result>
			 <result name="generalstamp">/page/ea/main/office_ea/corporationcode/GeneralStamp.jsp</result>
			  <result name="pswlog">/page/ea/main/office_ea/corporationcode/ModifyStampPswLog.jsp</result>
			<result name="stampm">/page/ea/main/office_ea/contract/stampManage.jsp</result>
			<result name="stampu">/page/ea/main/office_ea/contract/stampUpload.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="enterprisestamp-jsonajax" namespace="/ea/enterprisestamp" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.office.action.EnterpriseStampAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="enterprisestamp-njsonajax" namespace="/ea/enterprisestamp"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.office.action.EnterpriseStampAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

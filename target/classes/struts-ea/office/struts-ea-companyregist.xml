<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="comregist-ntoken" namespace="/ea/comregist"
		extends="ea-ntoken">
		<action name="ea_*"
			class="hy.ea.office.action.CompanyRegistAction" method="{1}">
			<result name="companyRegistlist">
				/page/ea/main/office_ea/companyRegist/comRegist_list.jsp
			</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="no_authority">
				/page/ea/no_authority.jsp
			</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="companyRegist.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="staffMeeting-token" namespace="/ea/smeeting"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.office.action.StaffMeetingAction" method="{1}">
		      <result name="meetinglist">/page/ea/main/office_ea/staffMeeting/staffMeeting.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="staffMeeting-ntoken" namespace="/ea/smeeting"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.StaffMeetingAction" method="{1}">
			 <result name="smeetinglist">/page/ea/main/office_ea/staffmeeting/staffMeeting.jsp</result>
		     <result name="listuser">/page/ea/main/office_ea/staffmeeting/partiStaff.jsp</result>
		     <result name="record">/page/ea/main/office_ea/staffmeeting/meetingRecord.jsp</result>
			 <result name = "succ">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="staffMeeting-jsonajax" namespace="/ea/smeeting" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.StaffMeetingAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	
</struts>

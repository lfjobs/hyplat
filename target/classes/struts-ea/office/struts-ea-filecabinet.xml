<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>

	<package strict-method-invocation="false" name="filecabinet-ntoken" namespace="/ea/filecabinet" extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.office.action.FileCabinetAction" method="{1}">
			<result name="filecabinetlist">/page/ea/main/office_ea/fileCabinet/fileCabinetList.jsp</result>
			<result name="fileFolderlist">/page/ea/main/office_ea/fileCabinet/fileFolderList.jsp</result>
			<result name="fileUploadlist">/page/ea/main/office_ea/fileCabinet/fileUploadList.jsp</result>
			<result name="globalSearchlist">/page/ea/main/office_ea/fileCabinet/globalSearchList.jsp</result>
			
		</action>
	</package>
	<package strict-method-invocation="false" name="filecabinet-jsonajax" namespace="/ea/filecabinet" extends="json-default">
		<action name="sajax_n_ea_*" class="hy.ea.office.action.FileCabinetAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

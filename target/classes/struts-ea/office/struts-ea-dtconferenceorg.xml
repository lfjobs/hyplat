<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="dtconferenceorg-token" namespace="/ea/dtconferenceorg"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.office.action.DtconferenceOrgAction" method="{1}">
		      <result name="getAllDtconOrg">/page/ea/main/office_ea/dtconferenceorg_list.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="dtconferenceorg-ntoken" namespace="/ea/dtconferenceorg"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.DtconferenceOrgAction" method="{1}">
			 <result name="getAllDtconOrg">/page/ea/main/office_ea/dtconferenceorg_list.jsp</result>
			 <result name="staffForCashier">/page/ea/main/finance/personal_department/congress_jqm_cstaffs.jsp</result>
			 <result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="dtconferenceorg.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="dtconferenceorg-jsonajax" namespace="/ea/dtconferenceorg" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.DtconferenceOrgAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

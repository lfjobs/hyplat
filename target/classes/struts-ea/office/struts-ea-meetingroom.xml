<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="meetingRoom-token" namespace="/ea/meetingroom"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.office.action.MeetingRoomAction" method="{1}">
		      <result name="roomlist">/page/ea/main/office_ea/staffMeeting/meetingRoom.jsp</result>
		      <result name="myroomorder">/page/ea/main/office_ea/staffmeeting/myRoomOrder.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="meetingRoom-ntoken" namespace="/ea/meetingroom"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.MeetingRoomAction" method="{1}">
			 <result name="roomlist">/page/ea/main/office_ea/staffmeeting/meetingRoom.jsp</result>
		      <result name="myroomorder">/page/ea/main/office_ea/staffmeeting/myRoomOrder.jsp</result>
		     <result name="order">/page/ea/main/office_ea/staffmeeting/meetingRoomOrder.jsp</result>
			 <result name = "succ">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="meetingRoom-jsonajax" namespace="/ea/meetingroom" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.MeetingRoomAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	
</struts>

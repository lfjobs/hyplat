<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="coachreservationrecordcontent-ntoken" namespace="/ea/coachreservationrecordcontent"  extends="struts-default">
		<action name="ea_*" class="hy.ea.ddsr.action.CoachReservationRecordContentAction" method="{1}">
			 <result name="coachreservationrecordcontent_List">/page/ea/main/ddsr/coachreservationrecordcontent.jsp</result>
			 <result name="reservationRecordSummary_List">/page/ea/main/ddsr/coachreservationrecordsummary.jsp</result>
			 <result name="reservationRecordSummary_List_Print">/page/ea/main/ddsr/coachreservationrecordsummary_print.jsp</result>
			 <result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
		<action name="ref_*" class="hy.ea.ddsr.action.DdsrStudentManagerAction" method="{1}">			
			<result name="showDdsrStudentList">/page/ea/main/ddsr/ddsrStudentManager_list.jsp</result>
		</action>
		<action name="refprimary_*" class="hy.ea.ddsr.action.DdsrStudentManagerAction" method="{1}">			
			<result name="showDdsrStudentList">/page/ea/main/ddsr/ddsrStudentManager_list_primary.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="coachreservationrecordcontent-njsonajax" namespace="/ea/coachreservationrecordcontent"
		extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.ddsr.action.CoachReservationRecordContentAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

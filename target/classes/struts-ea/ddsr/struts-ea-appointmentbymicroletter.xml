<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="appointmentbymicroletter-ntoken" namespace="/ea/appointmentbymicroletter"  extends="struts-default">
		<action name="ea_*" class="hy.ea.ddsr.action.AppointmentByWeChatAction" method="{1}">
			 <result name="toLogin">/page/ea/main/ddsr/login.jsp</result>
			 <result name="toRegistered">/page/ea/main/ddsr/registered.jsp</result>
			 <result name="success">/page/ea/main/ddsr/index.jsp</result>
			 <result name="fail">/page/ea/main/ddsr/fail.jsp</result>
			 <result name="toSearchPage">/page/ea/main/ddsr/search.jsp</result>
			 <result name="coachreservationrecordOfWeChatList">/page/ea/main/ddsr/coachreservationrecordOfWeChat.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="appointmentbymicroletter-sajax" namespace="/ea/appointmentbymicroletter" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.ddsr.action.AppointmentByWeChatAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>
		</action>	
	</package>
	<package strict-method-invocation="false" name="appointmentbymicroletterrecord-ntoken" namespace="/ea/appointmentbymicroletterrecord"  extends="struts-default">
		<action name="ea_*" class="hy.ea.ddsr.action.AppointmentRecordByWeChatAction" method="{1}">
			 <result name="coachreservationrecordcontentOfWeChatOfList">/page/ea/main/ddsr/coachreservationrecordcontentOfWeChat.jsp</result>
			 <result name="recordcontentOfWeChatOfList">/page/ea/main/ddsr/coachreservationrecordcontentOfPersonalOfWeChat.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="appointmentbymicroletterrecord-sajax" namespace="/ea/appointmentbymicroletterrecord" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.ddsr.action.AppointmentRecordByWeChatAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>
		</action>	
	</package>
</struts>

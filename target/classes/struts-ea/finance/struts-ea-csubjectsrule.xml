<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="csubjectsrule-token" namespace="/ea/csubjectsrule"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.finance.action.CSubjectsRuleAction" method="{1}">
			  <result name="checkCSubjectsRule">/page/ea/main/finance/production/csubejsts/csubjectrule_add.jsp?</result>
		      <result name="invalid.token">/page/ea/main/finance/production/csubejsts/csubjectrule_add.jsp?</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="csubjectsrule-ntoken" namespace="/ea/csubjectsrule"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.finance.action.CSubjectsRuleAction" method="{1}">
			<result name="checkCSubjectsRule">/page/ea/main/finance/production/csubejsts/csubjectrule_add.jsp?</result>
			<result name="showExcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="Address.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="csubjectsrule-jsonajax" namespace="/ea/csubjectsrule" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.finance.action.CSubjectsRuleAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="csubjectsrule-njsonajax" namespace="/ea/csubjectsrule" extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.finance.action.CSubjectsRuleAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

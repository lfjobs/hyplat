<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="splitbillcompany-ntoken" namespace="/ea/splitbillcompany"  extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.SplitBillCompanyAction" method="{1}">
			<result name="list">/page/ea/main/finance/production/splitbillComplay_list.jsp</result>
            <result name="edit">/page/ea/main/finance/production/splitbill_edit.jsp</result>
            <result name="edit2">/page/ea/main/finance/production/splitbill_edit2.jsp</result>
            <result name="toprintCashierServiceAll">/page/ea/main/finance/company/cashierbillsServiceprintAll.jsp</result>
            <result name="sprins">/page/ea/main/finance/production/CashdayStatements2s_sprin.jsp</result>
            <result name="toPage">/page/ea/main/finance/production/CashdayStatements2_search.jsp</result>
            <result name="toPagenum" type="freemarker">/page/ea/main/finance/production/toPageNum.html</result>
            <result name="detail">/page/ea/main/finance/production/goodscashierdetail_list.jsp</result>
            <result name="success">/page/ea/success.jsp</result>
		    <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="cashiertally.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="splitbillcompany-sajax" namespace="/ea/splitbillcompany" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.finance.action.SplitBillCompanyAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
		</action>
	</package>
</struts>

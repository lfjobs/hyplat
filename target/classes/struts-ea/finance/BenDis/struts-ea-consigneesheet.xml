<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="consignee-token" namespace="/ea/consignee"   extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.BenDis.ConsigneeSheetAction" method="{1}">
		      <result name="success">/page/ea/success.jsp</result>
		      <result name="list">/page/ea/main/finance/BenDis/consigneeSheet_list.jsp</result>
		      <result name="seepage">/page/ea/main/finance/BenDis/consigneeSheet_see.jsp</result>
		      <result name="printprev">/page/ea/main/finance/BenDis/consigneeSheet_print.jsp</result>
		      <result name="buyer">/page/conacts/receipt/consignee_buyer.jsp</result>
		      <result name="seller">/page/conacts/receipt/consignee_seller.jsp</result>
		      <result name="tovipcenter">/page/WFJClient/VipCenter/VipCenter.jsp</result>
		      <result name="login">/page/WFJClient/pc/pc_login.jsp</result>

		      <result name="consigList">/page/conacts/receipt/consignee_buyer.jsp</result>

		      <result name="forgetPassWord">/page/WFJClient/PersonalJoining/forgetPassword.jsp</result>
		      <result name="confirmPassWord">/page/WFJClient/PersonalJoining/confirmPassWord.jsp</result>

		     
		      <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="consigneesheet.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="consignee-jsonajax" namespace="/ea/consignee" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.finance.action.BenDis.ConsigneeSheetAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

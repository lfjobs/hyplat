<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="cashStock-ntoken" namespace="/ea/cashStock"
		extends="struts-default">
		<action name="ea_*"
			class="hy.ea.finance.action.BenDis.CashStockOperationAction" method="{1}">
			<result name="inPageData">/page/ea/main/finance/BenDis/cashInStorage_list.jsp</result>
			<result name="inPrevie">/page/ea/main/finance/BenDis/cashInStorage_print.jsp</result>
			<result name="inToSee">/page/ea/main/finance/BenDis/cashInStorage_see.jsp</result>
			<result name="outPageData">/page/ea/main/finance/BenDis/cashOutWarehouse_list.jsp</result>
			<result name="outPrevie">/page/ea/main/finance/BenDis/cashOutWarehouse_print.jsp</result>
			<result name="outToSee">/page/ea/main/finance/BenDis/cashOutWarehouse_see.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="CashStock.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cashStock-jsonajax" namespace="/ea/cashStock"
		extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.finance.action.BenDis.CashStockOperationAction" method="{1}">
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
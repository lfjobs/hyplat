<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="reports-sajaxs" namespace="/ea/reports" extends="json-default">
		<action name="sajax_*" class="hy.ea.finance.action.BenDis.reports.reportsAction" method="{1}">
	<!-- 返回类型为json 在sjon-default中定义 -->  
			<result type="json">  
				<!-- root的值对应要返回的值的属性 -->    
				<!-- 这里的result值即是 对应action中的 result -->  
				<param name="root">result</param>  
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="reports-ntoken" namespace="/ea/reports" extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.BenDis.reports.reportsAction" method="{1}">
			<result name="grossprostate">/page/ea/main/finance/BenDis/reports/grossProState.jsp</result>
			<result name="reFingoodsSold">/page/ea/main/finance/BenDis/reports/ReFingoodsSold.jsp</result>
			<result name="salesOrder">/page/ea/main/finance/BenDis/reports/salesOrder.jsp</result>
			<result name="salesRevenue">/page/ea/main/finance/BenDis/reports/salesRevenue.jsp</result>

			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="report.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

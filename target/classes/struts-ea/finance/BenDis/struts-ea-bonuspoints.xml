<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>	
	<package strict-method-invocation="false" name="bonuspoints-ntoken" namespace="/ea/bonuspoints" extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.BenDis.BonusPointsAction" method="{1}">
			<result name="getbonusPoints">/page/ea/main/finance/BenDis/BonusPoints/sign.jsp</result>
		    <result name="signface">/page/ea/main/human/attence/signface.jsp</result>
			<result name="getbpDetail">/page/ea/main/finance/BenDis/Gold_Pool/integral_bills.jsp</result>		<!--bonuspoints.jsp-->
		    <result name="integralRecharge">/page/ea/main/finance/BenDis/BonusPoints/IntegralRecharge.jsp</result>
			<result name="jifenchongzhi">/page/ea/main/finance/BenDis/Gold_Pool/wfj_scoreCoin.jsp</result>
			<result name="scoreDetail">/page/ea/main/finance/BenDis/Gold_Pool/bonuspoints.jsp</result>
			
			
			<!-- 过度页面 -->
			<result name = "return">/page/ea/main/finance/BenDis/Gold_Pool/return.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="bonuspoints-sajaxs" namespace="/ea/bonuspoints" extends="json-default">
		<action name="sajax_*" class="hy.ea.finance.action.BenDis.BonusPointsAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
			<result type="json">  
				<!-- root的值对应要返回的值的属性 -->    
				<!-- 这里的result值即是 对应action中的 result -->  
				<param name="root">result</param>  
			</result>
		</action>
	</package>
</struts>

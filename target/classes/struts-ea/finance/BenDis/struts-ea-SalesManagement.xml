<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="salesman-ntoken" namespace="/ea/salesman"
		extends="struts-default">
		<action name="ea_*"
			class="hy.ea.finance.action.BenDis.SalesManagementAction" method="{1}">
			<result name="pageData">/page/ea/main/finance/BenDis/salesManagement_list.jsp</result>
			<result name="previe">/page/ea/main/finance/BenDis/salesManagement_print.jsp</result>
			<result name="piliangdayin">/page/ea/main/finance/BenDis/salesManagement_piliang.jsp</result>
			<result name="toSee">/page/ea/main/finance/BenDis/salesManagement_see.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="SalesManagement.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="salesman-jsonajax" namespace="/ea/salesman"
		extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.finance.action.BenDis.SalesManagementAction" method="{1}">
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
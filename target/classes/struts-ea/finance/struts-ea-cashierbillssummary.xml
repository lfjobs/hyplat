<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="cashiersummary-token" namespace="/ea/cashiersummary"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.finance.action.CashierBillsSummaryAction" method="{1}">
		    <result name="companylist">/page/ea/main/finance/company/cashierbillssummary_list.jsp</result>
		       <result name="edit">/page/ea/main/finance/company/cashierbillssummary_edit.jsp</result>
		       <result name="printcashier">/page/ea/main/finance/company/cashierbillsprint.jsp</result>
		       <result name="printcashier4CashAccept">/page/ea/main/finance/company/cashierBillsPrint4CashAccept.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cashiersummary-ntoken" namespace="/ea/cashiersummary"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.finance.action.CashierBillsSummaryAction" method="{1}">
			 <result name="companylist">/page/ea/main/finance/company/cashierbillssummary_list.jsp</result>
			    <result name="edit">/page/ea/main/finance/company/cashierbillssummary_edit.jsp</result>
			    <result name="printcashier">/page/ea/main/finance/company/cashierbillsprint.jsp</result>
			     <result name="printcashiers">/page/ea/main/finance/company/cashierbillsprint.jsp</result>
			    <result name="printcashier4CashAccept">/page/ea/main/finance/company/cashierBillsPrint4CashAccept.jsp</result>
			    <result name="xp">/page/ea/main/finance/company/smallTicketsprint.jsp</result>
			    <result name="Rxp">/page/ea/main/finance/company/smallRestaurantsprint.jsp</result>
		    <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="cashierbills.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="print-ntoken" namespace="/ea/printcashierbills"  extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.CashierBillsSummaryAction" method="{1}">
			     <result name="printcashier">/page/ea/main/finance/company/cashierbillsprint.jsp</result>
			     <result name="printcashier2">/page/ea/main/finance/company/statements_sprint.jsp</result>
			     <result name="printcashier4CashAccept">/page/ea/main/finance/company/cashierBillsPrint4CashAccept.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cashiersummary-sajax" namespace="/ea/cashiersummary" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.finance.action.CashierBillsSummaryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>

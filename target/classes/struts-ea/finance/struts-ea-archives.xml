<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="archivest-ntoken" namespace="/ea/archivest"  extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.ArchivesAction" method="{1}">
			 <result name="list">/page/ea/main/finance/production/statements_list.jsp</result>
			 <result name="list1">/page/ea/main/finance/production/statements_list1.jsp</result>
			 <result name="listc">/page/ea/main/finance/production/ReceiptFile.jsp</result>
			 <result name="tostatements">/page/ea/main/finance/production/statements_sprin.jsp</result>
			 <result name="edit">/page/ea/main/finance/production/statements_edit.jsp</result>
			 <result name="edit1">/page/ea/main/finance/production/statements_edit1.jsp</result>
             <result name="success">/page/ea/success.jsp</result>
              <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="cashiertally.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="archivest-sajax" namespace="/ea/archivest" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.finance.action.ArchivesAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>

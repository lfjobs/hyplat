<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="cgoodsmanage-token" namespace="/ea/cgoodsmanage"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.ccompany.action.CGoodsManageAction" method="{1}">
			<result name="list">/page/ea/ccompany/goodsmanage/goodsmanage_list.jsp</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="cgoodsmanage-ntoken" namespace="/ea/cgoodsmanage" extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.ccompany.action.CGoodsManageAction" method="{1}">
			<result name="succ">/page/ea/success.jsp</result>
			<result name="list">/page/ea/ccompany/goodsmanage/goodsmanage_list.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cgoodsmanage-sajax" namespace="/ea/cgoodsmanage" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.ccompany.action.CGoodsManageAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
	
</struts>

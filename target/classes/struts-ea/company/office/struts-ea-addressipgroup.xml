<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
    <!--办公室人员ip地址 -->
<struts>
	<package strict-method-invocation="false" name="addressIpGroup-ntoken" namespace="/ea/addressIpGroup"  extends="struts-default">
		<action name="ea_*" class="hy.ea.company.action.office.AddressIPGroupAction" method="{1}">
			<result name="addressip">/page/ea/main/company/office_ea/addressIPGroup.jsp</result>
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="addressIpGroup.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

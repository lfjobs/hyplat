<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
<!-- 企业理念公司汇总 -->
	<package strict-method-invocation="false" name="manageC-ntoken" namespace="/ea/manageC"  extends="struts-default">
		<action name="ea_*" class="hy.ea.company.action.office.EnterpriseManageCAction" method="{1}">
			 <result name="managelist">/page/ea/main/company/office_ea/EnterpriseManageCompany.jsp</result>
			 <result name = "succ">/page/ea/success.jsp</result>
			 <result name = "tologin">/page/ea/index.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

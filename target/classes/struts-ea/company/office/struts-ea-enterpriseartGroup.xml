<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
<!--文化艺术 集团汇总 -->
	<package strict-method-invocation="false" name="artG-ntoken" namespace="/ea/enterpriseartgroup"  extends="struts-default">
		<action name="ea_*" class="hy.ea.company.action.office.EnterpriseArtGAction" method="{1}">
			 <result name="artlist">/page/ea/main/company/office_ea/EnterpriseArtGroup.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			 <result name="tologin">/page/ea/index.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

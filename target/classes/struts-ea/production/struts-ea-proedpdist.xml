<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="proedpdist-default" namespace="/ea/proedpdist"   extends="struts-default">
		<interceptors>
			<interceptor-stack name="ea-proedpdist">
				<interceptor-ref name="defaultStack" />
				<interceptor-ref name="token" >
					<param name="includeMethods">ea_save*,ea_delete*</param>
				</interceptor-ref>
			</interceptor-stack>
		</interceptors>
		<default-interceptor-ref name="ea-proedpdist" />
		<action name="ea_*" class="proedpdistAction" method="{1}">
		      <result name="list">/page/ea/main/production/cprocedure/proedpList.jsp</result>
		      <result name="toPage">/page/ea/main/production/cprocedure/proedpedit.jsp</result>
		      <result name="toprint">/page/ea/main/production/cprocedure/proedp_print.jsp</result>
		      <result name="toList" type="redirectAction">ea_findList</result>
		      <result name="success">/page/ea/success.jsp</result>
		      <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="proedpdist.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="proedpdist-jsonajax" namespace="/ea/proedpdist" extends="json-default">
		<action name="sajax_ea_*" class="proedpdistAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="finished-token" namespace="/ea/finished"   extends="struts-default">
		<action name="ea_*" class="hy.ea.production.action.finishproduct.FinishedProductAction" method="{1}">
			<result name="addPageData">/page/ea/main/production/finishproduct/finishedProduct_add.jsp</result>
			<result name="editPageData">/page/ea/main/production/finishproduct/finishedProduct_edit.jsp</result>
			<result name="toPrint">/page/ea/main/production/finishproduct/finishedProduct_toprint.jsp</result>
			<result name="pageData">/page/ea/main/production/finishproduct/finishedProduct_list.jsp</result>
			<result name="ReviewAudit">/page/ea/main/production/finishproduct/finishedProduct_print.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="finished-jsonajax" namespace="/ea/finished" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.production.action.finishproduct.FinishedProductAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="resultInv-token" namespace="/ea/resultInv"   extends="struts-default">
		<action name="ea_*" class="hy.ea.production.action.finishproduct.ResultInventoryAction" method="{1}">
			  <result name="list">/page/ea/main/production/finishproduct/resultInventory_list.jsp</result>
			  <result name="libList">/page/ea/main/production/finishproduct/resultInventory_libList.jsp</result>
			  <result name="add">/page/ea/main/production/finishproduct/resultInventory_add.jsp</result>
			  <result name="invPrint">/page/ea/main/production/finishproduct/resultInventory_invPrint.jsp</result>
			  <result name="print">/page/ea/main/production/finishproduct/resultInventory_print.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="resultInv-jsonajax" namespace="/ea/resultInv" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.production.action.finishproduct.ResultInventoryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

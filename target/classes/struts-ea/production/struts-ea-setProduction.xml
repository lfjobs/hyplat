<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="setpro-token" namespace="/ea/setpro"   extends="struts-default">
		<action name="ea_*" class="hy.ea.production.action.cprocedure.process.SetProductionAction" method="{1}">
		      <result name="list">/page/ea/main/production/cprocedure/process/setProduction_list.jsp</result>
		      <result name="print">/page/ea/main/production/cprocedure/process/setProduction_print.jsp</result>
		      <result name="see">/page/ea/main/production/cprocedure/process/setProduction_see.jsp</result>
		      <result name="data">/page/ea/main/production/cprocedure/process/setProduction_data.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="setpro-jsonajax" namespace="/ea/setpro" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.production.action.cprocedure.process.SetProductionAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

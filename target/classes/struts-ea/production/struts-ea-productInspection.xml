<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="inspection-token" namespace="/ea/inspection"   extends="struts-default">
		<action name="ea_*" class="hy.ea.production.action.dcheck.ProductInspectionAction" method="{1}">
		      <result name="list">/page/ea/main/production/dcheck/productInspection_list.jsp</result>
		      <result name="data">/page/ea/main/production/dcheck/productInspection_data.jsp</result>
		      <result name="page">/page/ea/main/production/dcheck/productInspection_page.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="inspection-jsonajax" namespace="/ea/inspection" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.production.action.dcheck.ProductInspectionAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="cashtime-ntoken"  namespace="/ea/cashtime"  extends="struts-default">
		<action name="ea_*" class="hy.ea.invoicing.action.cashtimeAction" method="{1}">
			<result name="topage">/page/ea/main/finance/invoicing/cashtime.jsp</result>
			<result name="complete">/page/ea/main/finance/invoicing/complete_print.jsp</result>
			<result name="completes">/page/ea/main/finance/invoicing/complete.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cashtime-jsonajax" namespace="/ea/cashtime" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.invoicing.action.cashtimeAction" method="{1}">
		<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

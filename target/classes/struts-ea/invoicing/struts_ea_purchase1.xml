<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="purchase1-token"  namespace="/ea/purchase1" extends="ea-ntoken">
		<action name="t_ea_*" class="hy.ea.invoicing.action.PurchaseAction1" method="{1}">
			<result name="list">/page/ea/main/finance/invoicing/Purchase_list.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="purchase1-ntoken"  namespace="/ea/purchase1"  extends="struts-default">
		<action name="ea_*" class="hy.ea.invoicing.action.PurchaseAction1" method="{1}">
		    <!--入库单页面-->
			<result name="toinvoicingstorage">
				/page/ea/main/finance/invoicing/chooseWarehousingnew.jsp
			</result>
			<!-- 采购管理 -->
			<result name="list">/page/ea/main/finance/invoicing/Purchase_list.jsp</result>
			<result name="add">/page/ea/main/finance/invoicing/Purchase_add1.jsp</result>
			<result name="edit">/page/ea/main/finance/invoicing/Purchase_edit.jsp</result>
			<result name="printpurchase">/page/ea/main/finance/invoicing/purchase_print.jsp</result>
			<result name="login">/page/ea/not_login.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="RankPublicreceipts.xls"
				</param>
			</result>
			
			<!-- 市场调查 -->
			<result name="marketlist">/page/ea/main/finance/invoicing/marketResearch_list.jsp</result>
			<result name="marketadd">/page/ea/main/finance/invoicing/marketResearch_add.jsp</result>
			<result name="marketedit">/page/ea/main/finance/invoicing/marketResearch_edit.jsp</result>
			<result name="marketprint">/page/ea/main/finance/invoicing/marketResearch_print.jsp</result>
			<result name="accptlist">/page/ea/main/finance/invoicing/accept_list.jsp</result>
			<result name="inspectlist">/page/ea/main/finance/invoicing/inspect_list1.jsp</result>
			<result name="inspectlistBill">/page/ea/main/finance/invoicing/inspect_bill.jsp</result>
			<!--验货单添加  -->
			<result name="toinspectdanframe">/page/ea/main/finance/invoicing/inspect_danframe.jsp</result>
			<result name="toinspectdan">/page/ea/main/finance/invoicing/inspect_danbill.jsp</result>
			<!--验货误差-->
			<result name="deviationList">/page/ea/main/finance/invoicing/deviation_list.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="purchase1-jsonajax" namespace="/ea/purchase1" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.invoicing.action.PurchaseAction1" method="{1}">
		<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

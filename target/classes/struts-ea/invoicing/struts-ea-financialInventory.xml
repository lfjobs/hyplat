<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="fininv-ntoken" namespace="/ea/fininv"
		extends="struts-default">
		<action name="ea_*" class="hy.ea.invoicing.action.FinancialInventoryAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
			<result name="pageHome">/page/ea/main/finance/invoicing/financialInventory_list.jsp</result>
			<result name="stocking">/page/ea/main/finance/invoicing/financialInventory_stocking.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="fininv-jsonajax" namespace="/ea/fininv"
		extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.invoicing.action.FinancialInventoryAction" method="{1}">
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
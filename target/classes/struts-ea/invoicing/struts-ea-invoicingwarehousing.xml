<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="warehousing-token" namespace="/ea/warehousing"
		extends="ea-token">
		<action name="t_ea_*"
			class="hy.ea.invoicing.action.InvoicingWarehousingAction" method="{1}">
			<result name="warelist">/page/ea/main/finance/invoicing/wareManagement_list.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>

	<package strict-method-invocation="false" name="warehousing-ntoken" namespace="/ea/warehousing"
		extends="struts-default">
		<action name="ea_*"
			class="hy.ea.invoicing.action.InvoicingWarehousingAction" method="{1}">
			<!--出库管理-->
			<result name="warelist">/page/ea/main/finance/invoicing/wareManagement_list.jsp</result>
			<result name="wareedit">/page/ea/main/finance/invoicing/wareManagement_edit.jsp</result>
			<result name="wareeditprint">/page/ea/main/finance/invoicing/wareManagement_print.jsp</result>
			<result name="wareadd">/page/ea/main/finance/invoicing/wareManagement_add.jsp</result>
			<result name="failed">/page/ea/fail.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<!--库房管理-->
			<result name="inventoryManagement">/page/ea/main/finance/invoicing/InventoryManagement.jsp</result>
			<result name="inventoryDetail">/page/ea/main/finance/invoicing/InventoryDetail.jsp</result>
			<result name="inventoryDetailBill">/page/ea/main/finance/invoicing/InventoryDetailBill.jsp</result>
			<result name="inventoryPool">/page/ea/main/finance/invoicing/InventoryPool.jsp</result>
			<result name="inventoryPoolBill">/page/ea/main/finance/invoicing/InventoryPoolBill.jsp</result>
			<result name="invprintss">/page/ea/main/finance/invoicing/inventory_print.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="Address.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="warehousing-jsonajax" namespace="/ea/warehousing"
		extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.invoicing.action.InvoicingWarehousingAction" method="{1}">
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="public-jsp" extends="struts-default">
        <global-results>
            <result name="404">/page/ea/404.jsp</result>
            <result name="500">/page/ea/500.jsp</result>
        </global-results>

        <!-- 定义全局异常-->
        <global-exception-mappings>
            <exception-mapping result="500" exception="java.lang.Exception"/>
        </global-exception-mappings>
    </package>

    <package strict-method-invocation="false" name="public-ajax" extends="json-default">
        <interceptors>
            <interceptor name="ea_ajax_exception" class="hy.ea.interceptor.JsonExceptionMappingInterceptor"/>
            <interceptor-stack name="eaAjaxStack">
                <interceptor-ref name="ea_ajax_exception" />
            </interceptor-stack>
        </interceptors>

        <!-- 这里是默认的拦截器栈 -->
        <default-interceptor-ref name="eaAjaxStack" />

        <global-results>
            <!-- ajax请求的返回视图 -->
            <result name="500" type="json">
                <param name="root">result</param>
                <param name="errorCode">500</param>
                <param name="statusCode">500</param>
            </result>
            <result type="json">
                <param name="root">result</param>
            </result>
        </global-results>

        <!-- 定义全局异常-->
        <global-exception-mappings>
            <exception-mapping result="500" exception="hy.ea.interceptor.JsonHandlerException"/>
        </global-exception-mappings>
    </package>

    <package strict-method-invocation="false" name="signin-ntoken" namespace="/ea/signin" extends="public-jsp">
        <action name="ea_*" class="hy.ea.signin.action.SignInAction" method="{1}">
            <result name="signin">/page/ea/signin/signin.jsp</result>
        </action>
    </package>

    <package strict-method-invocation="false" name="signin-sajax" namespace="/ea/signin" extends="public-ajax">
        <action name="sajax_*" class="hy.ea.signin.action.SignInAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
        </action>
    </package>
</struts>

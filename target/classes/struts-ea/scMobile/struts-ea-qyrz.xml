<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="qyrz-ntoken" namespace="/ea/qyrz" extends="struts-default">
		<action name="ea_*" class="mobile.tiantai.android.action.qyrz.QyrzAction" method="{1}">
			<result name="toPeriphery">/page/scMobile/qyrz/toPeriphery.jsp</result><!--周边列表页-->
			<result name="MyjiaruCompany">/page/scMobile/qyrz/qyrzBusinessList.jsp</result>
			<result name="rl">/page/scMobile/qyrz/toRl.jsp</result>
			<result name="toSuccess">/page/scMobile/qyrz/toSuccess.jsp</result>
			<result name="todetail">/page/scMobile/qyrz/detail.jsp</result>
			<result name="login">/page/WFJClient/NewLogin.jsp?loginPage=login</result>
			<result name="zbstatis">/page/scMobile/qyrz/zbstatis.jsp</result>
		</action>
	</package>

	<package strict-method-invocation="false"  name="qyrz-jsonajax" namespace="/ea/qyrz" extends="json-default">
		<action name="sajax_ea_*" class="mobile.tiantai.android.action.qyrz.QyrzAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>

	<package strict-method-invocation="false"  name="qyrz-ajax" namespace="/ea/qyrz" extends="json-default">
		<action name="p_*" class="mobile.tiantai.android.action.qyrz.QyrzAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">results</param>
			</result>
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
    <package strict-method-invocation="false" name="cRMShortMessagingTemplatePO-ntoken"
             namespace="/ea/cRMShortMessagingTemplatePO"
             extends="struts-default">
        <action name="ea_*"
                class="mobile.tiantai.android.action.storeProduction.budgetSheet.CRMShortMessagingTemplatePOAction"
                method="{1}">
            <result name="crmShortMessagingTemplatePO">/page/pc/5L5C/marketing/visitorMessagesCreate1.jsp</result>
            <result name="bh">/page/pc/5L5C/marketing/companys.jsp?type=bh</result>
            <result name="dx">/page/pc/5L5C/marketing/companys.jsp?type=dx</result>
        </action>
    </package>
    <package strict-method-invocation="false" name="cRMShortMessagingTemplatePO-jsonajax"
             namespace="/ea/cRMShortMessagingTemplatePO" extends="json-default">
        <action name="sajax_ea_*"
                class="mobile.tiantai.android.action.storeProduction.budgetSheet.CRMShortMessagingTemplatePOAction"
                method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
        </action>
    </package>
</struts>
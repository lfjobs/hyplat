<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package name="queryUtil-inter" namespace="/ea/queryUtil" extends="struts-default">
		<!--自定义拦截器 -->
		<interceptors>
			<!-- 定义权限拦截器 -->
			<interceptor name="admin_interceptor" class="mobile.tiantai.android.common.PayBudget_Interceptor"></interceptor>
			<!-- 定义拦截器栈,所谓拦截器栈,是指由一个或多个拦截器组成 -->
			<interceptor-stack name="admin_interceptor_stack">
				<interceptor-ref name="defaultStack"></interceptor-ref>
				<interceptor-ref name="admin_interceptor"></interceptor-ref>
			</interceptor-stack>
		</interceptors>
		<!-- 为此包下的所有action应用拦截器 -->
		<default-interceptor-ref name="admin_interceptor_stack"></default-interceptor-ref>
		<!--全局result(global-results)-->
		<global-results>
			<result name="logout" >/page/WFJClient/Login/Login.jsp</result>
		</global-results>
	</package>

	<package strict-method-invocation="false" name="queryUtil-ntoken" namespace="/ea/queryUtil" extends="struts-default,queryUtil-inter">
		<action name="ea_*" class="mobile.tiantai.android.util.QueryForMobileUtil" method="{1}">
			<result name="toQuery">/page/scMobile/util/toQuery/toQuery.jsp</result><!--查询页面-->
			<result name="toCostBudgetQuery">/page/scMobile/util/toQuery/toCostBudgetQuery.jsp</result><!--查询页面-->
			<result name="toPlanCostBudgetQuery">/page/scMobile/util/toQuery/toPlanCostBudgetQuery.jsp</result><!--项目计划查询页面-->
		</action>
	</package>
</struts>

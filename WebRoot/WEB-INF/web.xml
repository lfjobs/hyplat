			org.apache.struts2.views.JspSupportServlet
		</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>

	<servlet>
		<servlet-name>barbecue</servlet-name>
		<servlet-class>
			net.sourceforge.barbecue.BarcodeServlet
		</servlet-class>
		<load-on-startup>1</load-on-startup>
	</servlet>
	<servlet-mapping>
		<servlet-name>barbecue</servlet-name>
		<url-pattern>/CreateBarCode</url-pattern>
	</servlet-mapping>


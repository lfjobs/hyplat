	<context:component-scan base-package="
										hy.base.action.**,
										hy.ea.**,
										hy.plat.**,
										hy.tel.**,
										mobile.tiantai.android.**,
										com.tiantai.webservice.**,
										com.tiantai.wfj.**,
										hy.webservice.**,
										com.mysl.**,
										com.wechat.**"/>


	<!--jbpm4.4е·ҘдҪңжөҒ  -->
	<bean id="springHelper" class="org.jbpm.pvm.internal.processengine.SpringHelper">
		<property name="jbpmCfg" value="spring-jbpm4.cfg.xml" />
	</bean>
	<bean id="processEngine" factory-bean="springHelper" factory-method="createProcessEngine" />
	<!-- 
		<bean id="jbpmConfiguration" class="org.jbpm.pvm.internal.cfg.SpringConfiguration">
		<constructor-arg value="jbpm.cfg.xml" />
		</bean> 
		
		<bean id="processEngine" factory-bean="jbpmConfiguration" factory-method="buildProcessEngine"></bean>
	-->
	<bean id="executionService" factory-bean="processEngine" factory-method="getExecutionService"></bean>

	<bean id="repositoryService" factory-bean="processEngine" factory-method="getRepositoryService"></bean>

	<bean id="taskService" factory-bean="processEngine" factory-method="getTaskService"></bean>

	<bean id="historyService" factory-bean="processEngine" factory-method="getHistoryService"></bean>

	<bean id="identityService" factory-bean="processEngine" factory-method="getIdentityService"></bean>

	<bean id="managementService" factory-bean="processEngine" factory-method="getManagementService"></bean>

	<!-- жөӢиҜ•пјҡ123.57.26.228 --><!--жң¬ең°: 192.168.3.9 -->
	<bean id="dataSource" class="com.mchange.v2.c3p0.ComboPooledDataSource" destroy-method="close">
		<property name="driverClass" value="oracle.jdbc.driver.OracleDriver" />
		<property name="jdbcUrl" value="jdbc:oracle:thin:@123.57.26.228:1521:ttsw?useUnicode=true&amp;characterEncoding=UTF-8" />
		<!--<property name="jdbcUrl" value="jdbc:oracle:thin:@60.205.156.248:1521:TTSW" />-->
		<!--иҝһжҺҘжұ дёӯдҝқз•ҷзҡ„жңҖе°ҸиҝһжҺҘж•°гҖӮ-->
		<property name="minPoolSize" value="5" />

		<!--иҝһжҺҘжұ дёӯдҝқз•ҷзҡ„жңҖеӨ§иҝһжҺҘж•°гҖӮDefault: 15 -->
		<property name="maxPoolSize" value="30" />

		<!--еҲқе§ӢеҢ–ж—¶иҺ·еҸ–зҡ„иҝһжҺҘж•°пјҢеҸ–еҖјеә”еңЁminPoolSizeдёҺmaxPoolSizeд№Ӣй—ҙгҖӮDefault: 3 -->
		<property name="initialPoolSize" value="10"/>

		<!--жңҖеӨ§з©әй—Іж—¶й—ҙ,60з§’еҶ…жңӘдҪҝз”ЁеҲҷиҝһжҺҘиў«дёўејғгҖӮиӢҘдёә0еҲҷж°ёдёҚдёўејғгҖӮDefault: 0 -->
		<property name="maxIdleTime" value="60"/>

		<!--еҪ“иҝһжҺҘжұ дёӯзҡ„иҝһжҺҘиҖ—е°Ҫзҡ„ж—¶еҖҷc3p0дёҖж¬ЎеҗҢж—¶иҺ·еҸ–зҡ„иҝһжҺҘж•°гҖӮDefault: 3 -->
		<property name="acquireIncrement" value="5" />

		<!--JDBCзҡ„ж ҮеҮҶеҸӮж•°пјҢз”Ёд»ҘжҺ§еҲ¶ж•°жҚ®жәҗеҶ…еҠ иҪҪзҡ„PreparedStatementsж•°йҮҸгҖӮдҪҶз”ұдәҺйў„зј“еӯҳзҡ„statements
            еұһдәҺеҚ•дёӘconnectionиҖҢдёҚжҳҜж•ҙдёӘиҝһжҺҘжұ гҖӮжүҖд»Ҙи®ҫзҪ®иҝҷдёӘеҸӮж•°йңҖиҰҒиҖғиҷ‘еҲ°еӨҡж–№йқўзҡ„еӣ зҙ гҖӮ
            еҰӮжһңmaxStatementsдёҺmaxStatementsPerConnectionеқҮдёә0пјҢеҲҷзј“еӯҳиў«е…ій—ӯгҖӮDefault: 0-->
		<property name="maxStatements" value="0" />

		<!--жҜҸ60з§’жЈҖжҹҘжүҖжңүиҝһжҺҘжұ дёӯзҡ„з©әй—ІиҝһжҺҘгҖӮDefault: 0 -->
		<property name="idleConnectionTestPeriod" value="60" />

		<!--е®ҡд№үеңЁд»Һж•°жҚ®еә“иҺ·еҸ–ж–°иҝһжҺҘеӨұиҙҘеҗҺйҮҚеӨҚе°қиҜ•зҡ„ж¬Ўж•°гҖӮDefault: 30 -->
		<property name="acquireRetryAttempts" value="5" />
		<property name="maxIdleTimeExcessConnections" value="600"/>

		<property name="maxConnectionAge" value="3600"></property>
		<!-- й…ҚзҪ®з”ЁжҲ·еҗҚе’ҢеҜҶз Ғ -->
		<property name="properties" ref="dataSourceProperties" />
		<!-- жЈҖжөӢиҝһжҺҘжңүж•ҲжҖ§ -->
		<property name="testConnectionOnCheckin" value="true" />
		<property name="preferredTestQuery" value="SELECT 1 FROM DUAL" />
	</bean>
	<bean id="dataSourceProperties" class="hy.ea.util.MyBasicDataSource">
		<property name="properties">
			<props>
				<prop key="user">*****</prop>
				<prop key="password">******</prop>
			</props>
		</property>
	</bean>

	<bean id="sessionFactory" class="org.springframework.orm.hibernate3.LocalSessionFactoryBean">
		<property name="dataSource" ref="dataSource" />

		<property name="mappingDirectoryLocations">
			<list>
				<value>classpath:hy/ea/bo</value>
				<value>classpath:hy/ea/office/bo</value>
				<value>classpath:hy/plat/bo</value>
				<value>classpath:com/tiantai/telrec/bo</value>
				<value>classpath:hy/tel/bo</value>
				<value>classpath:com/tiantai/nwa/tbank/bo</value>
				<value>classpath:mobile/tiantai/android/bo</value>
				<value>classpath:hy/ea/marketing/bo</value>
				<value>classpath:com/tiantai/wfj/bo</value>
				<value>classpath:com/tiantai/wfj/edmandServe/bo</value>
				<value>classpath:com/mysl/bo</value>
				<value>classpath:com/wechat/bo/sft</value>
			</list>
		</property>
		<property name="mappingLocations">
			<list>
				<value>classpath:jbpm.execution.hbm.xml</value>
				<value>classpath:jbpm.history.hbm.xml</value>
				<value>classpath:jbpm.identity.hbm.xml</value>
				<value>classpath:jbpm.repository.hbm.xml</value>
				<value>classpath:jbpm.task.hbm.xml</value>
			</list>
		</property>
		<property name="hibernateProperties">

			<props>
				<prop key="hibernate.dialect">hy.ea.util.OracletDialect_ttsw</prop>
				<prop key="hibernate.hbm2ddl.auto">update</prop>
				<prop key="hibernate.show_sql">true</prop>
				<prop key="hibernate.format_sql">true</prop>
				<prop key="hibernate.use_outer_join">true</prop>
				<!-- <prop key="hibernate.connection.pool_size">100</prop> -->
				<prop key="hibernate.connection.release_mode">auto</prop>
				<prop key="hibernate.autoReconnect">true</prop>
				<prop key="hibernate.bytecode.use_reflection_optimizer">true</prop>
				<prop key="hibernate.cache.use_second_level_cache">false</prop>
				<prop key="hibernate.cache.use_query_cache">false</prop>

				<prop key="Connection.useUnicode">true</prop>
				<prop key="connection.characterEncoding">UTF-8</prop>
				<prop key="jdbc.batch_size">30</prop>
				<prop key="jdbc.fetch_size">50</prop>
				<prop key="hibernate.connection.url">jdbc:oracle:thin:@192.168.3.9:1521:ttsw</prop>
				<prop key="hibernate.connection.driver_class">oracle.jdbc.OracleDriver</prop>


			</props>
		</property>
	</bean>

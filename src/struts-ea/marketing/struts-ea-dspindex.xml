<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
		"-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
		"http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="dsp-ntoken" namespace="/ea/dsp"  extends="struts-default">
		<action name="ea_*" class="hy.ea.collage.action.DspIndexAction" method="{1}">
			<result name="sharelist">/page/ea/collage/dsp/dspshare.jsp</result>
			<result name="goodslist">/page/ea/collage/dsp/dspgoodslist.jsp</result>
			<result name="viewlist">/page/ea/collage/dsp/dspviewlist.jsp</result>
			<result name="view-list">/page/ea/collage/dsp/dsp-view-list.jsp</result>
			<result name="fullscreen">/page/ea/collage/dsp/dsp-fullscreen.jsp</result>
			<result name="my-homepage">/page/ea/collage/dsp/dsp-my-homepage.jsp</result>
			<result name="author-homepage">/page/ea/collage/dsp/dsp-author-homepage.jsp</result>
			<result name="issue">/page/ea/collage/dsp/dsp-issue.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="dsp-jsonajax" namespace="/ea/dsp"  extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.collage.action.DspIndexAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>	
	<package strict-method-invocation="false" name="marketingCrmCustomer-ntoken" namespace="/ea/marketingCrmCustomer"  extends="struts-default">
		<action name="ea_*" class="hy.ea.marketing.action.CrmCustomerAction" method="{1}">
			 <result name="list">/page/ea/main/marketing/crmcustomer/crmcustomer_list.jsp</result>
		     <result name="add">/page/ea/main/marketing/crmcustomer/crmcustomer_info.jsp</result>
		     <result name="edit">/page/ea/main/marketing/crmcustomer/crmcustomer_info.jsp</result>
		     <result name="view">/page/ea/main/marketing/crmcustomer/crmcustomer_info.jsp</result>
		     <result name="nologin">/page/ea/not_login.jsp</result>		     
		     <result name="syserror">/page/ea/sys_error.jsp</result>	
		     <result name="01jdwh">/page/ea/main/marketing/crmcustomer/crmcustomer_01jdwh.jsp</result>
		     <result name="02yxcp">/page/ea/main/marketing/crmcustomer/crmcustomer_02yxcp.jsp</result>
		     <result name="03bjjl">/page/ea/main/marketing/crmcustomer/crmcustomer_03bjjl.jsp</result>
		     <result name="04jpzl">/page/ea/main/marketing/crmcustomer/crmcustomer_04jpzl.jsp</result>
		     
		     <result name="success">/page/ea/success.jsp</result>	    
		</action>
	</package>	
	<package strict-method-invocation="false" name="marketingCrmCustomer-jsonajax" namespace="/ea/marketingCrmCustomer"  extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.marketing.action.CrmCustomerAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>
            
            <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			
		</action>
	</package>
</struts>

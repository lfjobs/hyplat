<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>	
	<package strict-method-invocation="false" name="marketingWfj-ntoken" namespace="/ea/marketingWfj"  extends="struts-default">
		<action name="ea_*" class="com.tiantai.wfj.action.WfjEshopAction" method="{1}">
			 <result name="eshop.list">/page/ea/main/marketing/wfjeshop/eshop_list.jsp</result>		          
		     <result name="syserror">/page/ea/sys_error.jsp</result>
		     <result name="success">/page/ea/success.jsp</result>	
		     <result name="wfjshops_list" >/page/ea/main/marketing/wfjeshop/wfjeshop_list.jsp</result>   
		</action> 
	</package>	
	<package strict-method-invocation="false" name="marketingWfj-jsonajax" namespace="/ea/marketingWfj"  extends="json-default">
		<action name="sajax_ea_*" class="com.tiantai.wfj.action.WfjEshopAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>
            
            <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			
		</action>
	</package>
</struts>

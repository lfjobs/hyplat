<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<!-- q系人脸设备 人员获取 -->
	<package strict-method-invocation="false" name="qfacerec-personnelAcquisition" namespace="/person"
			 extends="json-default">
		<action name="cmd" class="hy.ea.office.action.QFaceAction" method="personnelAcquisition">
			<result type="json">
				<param name="root">result</param>
			</result>
		</action>
	</package>
	<!-- 人脸图片推送 -->
	<package strict-method-invocation="false" name="qfacerec-recordPicture" namespace="/ea/qfacerec"
			 extends="json-default">
		<action name="/record/picture" class="hy.ea.office.action.QFaceAction" method="recordPicture">
			<result type="json">
				<param name="root">result</param>
			</result>
		</action>
	</package>

</struts>

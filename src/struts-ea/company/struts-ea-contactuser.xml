<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="contactuser-token" namespace="/ea/contactuser"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.company.action.ContactUserAction" method="{1}">
			<result name="list">/page/ea/main/office_ea/contactuser/contactuser.jsp</result>
			
		</action>
	</package>
	<package strict-method-invocation="false" name="contactuser-ntoken" namespace="/ea/contactuser" extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.company.action.ContactUserAction" method="{1}">
			<result name="list">/page/ea/main/office_ea/contactuser/contactuser.jsp</result>
			<result name="relation">/page/ea/main/office_ea/information/querycontactuser.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="contactcompany.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			<result name="success">/page/ea/success.jsp</result> 
		</action>
	</package>
	<package strict-method-invocation="false" name="contactuser-sajax" namespace="/ea/contactuser" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.company.action.ContactUserAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
	
</struts>

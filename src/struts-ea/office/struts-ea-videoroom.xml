<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="videoroom-ntoken" namespace="/ea/videoroom"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.VideoMeetingAction" method="{1}">
			 <result name="roomlist">/page/ea/main/office_ea/staffmeeting/videoRoom.jsp</result>
			 <result name="myroomlist">/page/ea/main/office_ea/staffmeeting/myVideoRoom.jsp</result>
			 <result name="invent">/page/ea/main/office_ea/staffmeeting/inventMeeting.jsp</result>
			 <result name = "succ">/page/ea/success.jsp</result>
			 <result name="not_login">/page/ea/not_login.jsp</result>
			 
		
		</action>
	</package>
	<package strict-method-invocation="false" name="videoroom-jsonajax" namespace="/ea/videoroom" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.VideoMeetingAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	
</struts>

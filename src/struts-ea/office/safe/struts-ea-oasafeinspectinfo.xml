<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="safeinspect-token" namespace="/ea/safeinspect"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.office.action.OASafeInspectInfoAction" method="{1}">
			 <result name="list">/page/ea/main/office_ea/safe/OASafeInspectInfo_list.jsp</result>
			 <result name="edit">/page/ea/main/office_ea/safe/OASafeInspectInfo_edit.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="safeinspect-sajax" namespace="/ea/safeinspect" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.OASafeInspectInfoAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>

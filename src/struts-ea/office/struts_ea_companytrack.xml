<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="companytrack-ntoken" namespace="/ea/companytrack"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.office.action.CompanyTrackAction" method="{1}">
			 <result name="cListpage">/page/ea/main/marketing/CFileCustomerAdvisory.jsp</result>
			 <result name="gListpage">/page/ea/main/marketing/GFileCustomerAdvisory.jsp</result>
			 <result name="listpage">/page/ea/main/marketing/FileCustomerAdvisory.jsp</result>
			 <result name="list">/page/ea/main/office_ea/contactcompany/contactcompany_collect.jsp</result>
			 <result name="getcompanyForCashier">/page/ea/main/finance/personal_department/trackRelation_jqm_company.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			 <result name="aksList">/page/ea/main/office_ea/contactcompany/customerAsk.jsp</result>
			 <result name="checkCustomerAsk">/page/ea/main/office_ea/contactcompany/checkCustomerAsk.jsp</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="companytrack-jsonajax" namespace="/ea/companytrack" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.CompanyTrackAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
		</action>
	</package>
</struts>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="email-token" namespace="/ea/email"   extends="struts-default">
		<action name="t_ea_*" class="hy.ea.office.action.EmailAction" method="{1}">
		      <result name="emailList">/page/ea/main/office_ea/email/reciveEmail_list.jsp</result>
			  <result name="topage">/page/ea/main/office_ea/email/email_manger.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		      <result name="succ">/page/ea/main/office_ea/email/email_add.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="emailc" namespace="/ea/email"   extends="jfreechart-default">
		<action name="jfreechart_ea_*" class="hy.ea.office.action.EmailAction" method="{1}">
		       <result name="success" type="chart">
			   <param name="height">600</param> 
               <param name="width">1100</param> 
			  </result>
		</action>
	</package>
	<package strict-method-invocation="false" name="email-ntoken" namespace="/ea/email"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.EmailAction" method="{1}">
			 <result name="recive">/page/ea/main/office_ea/email/reciveEmail_list.jsp</result>
			  <result name="del">/page/ea/main/office_ea/email/delEmail_list.jsp</result>
			   <result name="send">/page/ea/main/office_ea/email/sendEmail_list.jsp</result>
			    <result name="draft">/page/ea/main/office_ea/email/draftEmail_list.jsp</result>
			  <result name="topage">/page/ea/main/office_ea/email/email_manger.jsp</result>
			  <result name="succ">/page/ea/main/office_ea/email/email_add.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="email-jsonajax" namespace="/ea/email" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.EmailAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	<package strict-method-invocation="false" name="email-njsonajax" namespace="/ea/email"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.office.action.EmailAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

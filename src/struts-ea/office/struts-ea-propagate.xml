<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="propagate-token" namespace="/ea/propagate"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.office.action.PropagateAction" method="{1}">
		      <result name="propagatelist">/page/ea/main/office_ea/information/Propagate.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="propagate-ntoken" namespace="/ea/propagate"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.office.action.PropagateAction" method="{1}">
			 <result name="propagatelist">/page/ea/main/office_ea/information/Propagate.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="responsibilities.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
</struts>

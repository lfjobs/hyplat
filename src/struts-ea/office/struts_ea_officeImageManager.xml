<struts>
<!--办公室形象管理 -->
	<package strict-method-invocation="false" name="officeImageManager-ntoken" namespace="/ea/image"  extends="struts-default">
		<action name="ea_*" class="hy.ea.office.action.OfficeImageManagerAction" method="{1}">
			 <result name="getofficeImageManagerList">/page/ea/main/office_ea/officeImageManager.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			<!--  <result name="information">/page/ea/main/office_ea/</result> -->
			 <!-- <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="piaowuInformation.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result> -->
		</action>
	</package>
	
	<package strict-method-invocation="false" name="officeImageManager-jsonajax" namespace="/ea/image" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.office.action.OfficeImageManagerAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
               <!--  root的值对应要返回的值的属性   这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
            <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
</struts>
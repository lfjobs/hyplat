<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="publicreceipts-ntoken"  namespace="/ea/publicreceipts"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.PublicreceiptsAction" method="{1}">
			<result name="ranklist">/page/ea/main/office_ea/StaffRank.jsp</result>
			<result name="rankedit">/page/ea/main/office_ea/StaffRank_edit.jsp</result>
			<result name="printrank">/page/ea/main/office_ea/staffRankPrint.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<result name="showrankexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="RankPublicreceipts.xls"
				</param>

			</result>
			
			
			<result name="overlist">/page/ea/main/office_ea/OverTime.jsp</result>
			<result name="overedit">/page/ea/main/office_ea/OverTime_edit.jsp</result>
			<result name="printover">/page/ea/main/office_ea/OverTimeSprint.jsp</result>
			<result name="showoverexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="OverPublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			
			<!-- 请假单 -->
			<result name="leaveBillslist">/page/ea/main/office_ea/LeaveBills.jsp</result>
			<result name="leavedit">/page/ea/main/office_ea/LeaveBill_edit.jsp</result> 
			<result name="printLeaveBill">/page/ea/main/office_ea/leavebillprint.jsp</result>
			<result name="showleaveexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="LeavePublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result> 
			
				<!-- 奖励单/扣分单 -->
			<result name="rewardPunishment">/page/ea/main/office_ea/GamJeom.jsp</result>
			<result name="showrewardexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="OverPublicreceipts.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			<!-- 审核 -->
			<result name="auditPunishment">/page/ea/main/office_ea/Publicreceipts.jsp</result>
			<!-- 审核查看 -->
			<result name="editRew">/page/ea/main/office_ea/GamJeomEdit.jsp</result>
			<!-- 将罚单打印 -->
			<result name="printRew">/page/ea/main/office_ea/GamJeomPrint.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="publicreceipts-jsonajax" namespace="/ea/publicreceipts" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.PublicreceiptsAction" method="{1}">
		<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>
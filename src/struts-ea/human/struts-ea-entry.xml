<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="entry-ntoken" namespace="/ea/entry"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.entry.EntryAction" method="{1}">
			<result name="emplyment">/page/WFJClient/pc/5l5C/human/entry/e_emplyment.jsp</result>
			<result name="emplydetail">/page/WFJClient/pc/5l5C/human/entry/e_emplydetail.jsp</result>
			<result name="emplyopr">/page/WFJClient/pc/5l5C/human/entry/e_emplyopr.jsp</result>
			<result name="emplyexam">/page/WFJClient/pc/5l5C/human/entry/e_emplyexam.jsp</result>
			<result name="emplynot">/page/WFJClient/pc/5l5C/human/entry/e_emplynot.jsp</result>
			<result name="human">/page/WFJClient/pc/5l5C/human/entry/e_societhuman.jsp</result>
			<result name="sbaseinfo">/page/WFJClient/pc/5l5C/human/entry/e_sbasedata.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="entry-jsonajax" namespace="/ea/entry" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.entry.EntryAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

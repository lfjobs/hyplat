<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="mobilecstaff-token" namespace="/ea/mobilecstaff"  extends="struts-default">
		<action name="t_ea_*" class="hy.ea.human.action.MobileCStaffAction" method="{1}">
		      <result name="list">/page/ea/main/human/cstaff/cstaff_info.jsp</result>
		      <result name="success">/page/ea/success.jsp</result> 
		</action>
	</package>
	
	<package strict-method-invocation="false" name="mobilecstaff-ntoken" namespace="/ea/mobilecstaff"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.MobileCStaffAction" method="{1}">
			<result name="list">/page/mobile/main/human/cstaff/cstaff_info1.jsp</result>
			<result name="to_cstaff">/page/ea/main/human/cstaff/cstaff_information.jsp</result>
			<result name="tochoseperson">/page/ea/main/human/attendance_work/leave_add_choseperson.jsp</result>
			<result name="tochosepersongoout">/page/ea/main/human/attendance_work/go_out_add_choseperson.jsp</result>
			<result name="tochosepersonbussiness">/page/ea/main/human/attendance_work/travel_add_choseperson.jsp</result>
			<result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="staff.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>

	<package strict-method-invocation="false" name="mobilecstaff-jsonajax" namespace="/ea/mobilecstaff" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.human.action.CStaffAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
           <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
	
	<package strict-method-invocation="false" name="mobilecstaff-njsonajax" namespace="/ea/mobilecstaff" extends="json-default">
		<action name="sajax_n_ea_*" class="hy.ea.human.action.CStaffAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
           <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>

</struts>

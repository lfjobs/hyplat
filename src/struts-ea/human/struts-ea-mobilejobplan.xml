<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="mobilejobplan-token" namespace="/ea/mobilejobplan"   extends="ea-token">
		<action name="t_ea_*" class="hy.ea.human.action.COSJobPlanAction" method="{1}">
		     <result name="list">/page/ea/main/human/cstaff/cstaff_jobplan.jsp</result>
		      <result name="invalid.token">/page/ea/main/human/cstaff/cstaff_jobplan.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<!-- <package strict-method-invocation="false" name="jobplan-ntoken" namespace="/ea/jobplan"  extends="ea-ntoken"> -->
	<package strict-method-invocation="false" name="mobilejobplan-ntoken" namespace="/ea/mobilejobplan"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.MobileCOSJobPlanAction" method="{1}">
		<result name="listSummary">/page/mobile/main/human/office/production/jobplansummary.jsp</result>
		<result name="companySummary">/page/mobile/main/human/office/company/jobplansummary.jsp</result>
			<result name="list">/page/mobile/main/human/cstaff/cstaff_jobplan.jsp</result>
			<result name="joblists">/page/mobile/main/person/cstaff_jobplan.jsp</result>
			<result name="fail">/page/ea/sys_error.jsp</result>
			<result name="logplanPing">/page/mobile/main/human/office/production/printLogjobplan.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="jobplan.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="mobilejobplan-jsonajax" namespace="/ea/mobilejobplan" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.human.action.COSJobPlanAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="wagestaff-ntoken" namespace="/ea/wagestaff"   extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.wage.WageStaffAction" method="{1}">
		     <result name="itemList">/page/ea/main/human/wage/wageStaff.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="wagestaff-jsonajax" namespace="/ea/wagestaff" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.wage.WageStaffAction" method="{1}">
            <result type="json">  
                <param name="root">result</param>
            </result>  
		</action>
	</package>
</struts>

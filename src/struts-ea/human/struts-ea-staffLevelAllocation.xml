<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="staffLevelAllocation-ntoken" namespace="/ea/staffLevelAllocation"  extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.StaffLevelAllocationAction" method="{1}">
			<result name="query">/page/WFJClient/pc/5l5C/human/staff/levelAllocationDetail.jsp?type=query</result>
			<result name="edit">/page/WFJClient/pc/5l5C/human/staff/levelAllocationDetail.jsp?type=edit</result>
			<result name="examine">/page/WFJClient/pc/5l5C/human/staff/levelAllocationDetail.jsp?type=examine</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="staffLevelAllocation-jsonajax" namespace="/ea/staffLevelAllocation" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.StaffLevelAllocationAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>
		</action>
	</package>
</struts>

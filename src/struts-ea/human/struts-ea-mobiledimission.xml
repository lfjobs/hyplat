<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="mobilecosdimission-ntoken" namespace="/ea/mobilecosdimission" extends="struts-default">
		<action name="ea_*" class="hy.ea.human.action.MobileCOSDimissionAction" method="{1}">
			<result name="list">/page/mobile/main/human/office/production/cstaff_dimission.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="contactcompany.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
			<result name="success">/page/ea/success.jsp</result> 
		</action>
	</package>

</struts>

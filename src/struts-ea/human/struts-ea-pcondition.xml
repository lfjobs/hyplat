<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="pcondition-token" namespace="/ea/pcondition"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.human.action.PConditionAction" method="{1}">
			<result name="list">/page/ea/main/human/cstaff/cstaff_pcondition.jsp</result>
			<result name="invalid.token">/page/ea/main/human/cstaff/cstaff_pcondition.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="pcondition-ntoken"  namespace="/ea/pcondition" extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.PConditionAction" method="{1}">
			<result name="list">/page/ea/main/human/cstaff/cstaff_pcondition.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="pcondition.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="pcondition-jsonajax" namespace="/ea/pcondition" extends="ea-sajax">
		<action name="sajax_ea_*" class="hy.ea.human.action.PConditionAction" method="{1}">
            <result type="json">  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="personalarchive-ntoken" namespace="/ea/personalarchive"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.human.action.PersonalArchiveAction" method="{1}">
			<result name="list">/page/ea/main/human/cstaff/cstaff_personalsheet.jsp</result>
			<result name="staffinfo">/page/ea/main/human/cstaff/cstaff_personalinfo.jsp</result>
		    <result name="printpa">/page/ea/main/human/cstaff/cstaff_pabillsprint.jsp</result>
			<result name="add">/page/ea/main/human/cstaff/cstaff_personalarchive_add.jsp</result>
			<result name="edit">/page/ea/main/human/cstaff/cstaff_personalarchive_edit.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="personalrecord.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="personalarchive-jsonajax" namespace="/ea/personalarchive" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.human.action.PersonalArchiveAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

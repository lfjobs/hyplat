<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="deborrow-token" namespace="/ea/deborrow"   extends="struts-default">
		<action name="ea_*" class="com.mysl.action.administrative.DeviceBorrowAction" method="{1}">
		      <result name="deborrowlist">/page/mysl/administrative/deviceborrow.jsp</result>
		      <result name="printdevice">/page/mysl/administrative/deviceborrow_print.jsp</result>
		      <result name="todeviceDetail">/page/mysl/administrative/deviceborrow_detail.jsp</result>
		      <result name="success">/page/ea/success.jsp</result>
		      <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="deviceborrow.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="deborrow-jsonajax" namespace="/ea/deborrow" extends="json-default">
		<action name="sajax_ea_*" class="com.mysl.action.administrative.DeviceBorrowAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="dcheck-token" namespace="/ea/dcheck" extends="struts-default">
		<action name="ea_*" class="hy.ea.production.action.dcheck.DCheckAction"
			method="{1}">
			<result name="dchecklist">/page/ea/main/production/dcheck/dcheck_list.jsp</result>
			<result name="yieldlist">/page/ea/main/production/dcheck/yield_list.jsp</result>
			<result name="yieldprintPreview">/page/ea/main/production/dcheck/yieldPrintPreview.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="printPreview">/page/ea/main/production/dcheck/dcheckPrintPreview.jsp</result>
			<result name="agreed">/page/ea/main/production/dcheck/dcheckAgreed.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="dcheck.xls"
				</param>
			</result>
			<result name="showexcelyield" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="yield.xls"
				</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="dcheck-jsonajax" namespace="/ea/dcheck" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.production.action.dcheck.DCheckAction"
			method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>


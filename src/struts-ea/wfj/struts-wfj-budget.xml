<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
    <struts>
    	<package strict-method-invocation="false" name="wfjbudget-token" namespace="/ea/wfjbudget" extends="struts-default">
    		<action name="ea_*" class="budgetAction" method="{1}">
    			<result name="toBudget">/page/WFJClient/Budget/budgetList.jsp</result>
    			<result name="toAddBudget">/page/WFJClient/Budget/budgetAdd.jsp</result>
    			<result name="budgetDetail">/page/WFJClient/Budget/budgetDetail.jsp</result>
    			<result name="searchPro">/page/WFJClient/Budget/searchPro.jsp</result>
    			<result name="login">/page/WFJClient/NewLogin.jsp?loginPage=login</result>
    		</action>
    	</package>
    	
    	<package strict-method-invocation="false" name="wfjbudget-jsonajax" namespace="/ea/wfjbudget" extends="json-default">
    		<action name="sajax_ea_*" class="budgetAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            	<result type="json">  
                	<!-- root的值对应要返回的值的属性 -->  
                	<!-- 这里的result值即是 对应action中的 result -->  
                	<param name="root">result</param>  
           	 	</result>  
			</action>
    	</package>
    </struts>
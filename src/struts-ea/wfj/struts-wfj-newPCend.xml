	<package strict-method-invocation="false" name="wfjnewpcend-jsonajax" namespace="/ea/newpcend" extends="json-default">
		<action name="sajax_ea_*" class="com.tiantai.wfj.front.NewPCendAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
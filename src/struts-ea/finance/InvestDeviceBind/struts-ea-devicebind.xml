<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>	
	<package strict-method-invocation="false" name="devicebind-ntoken" namespace="/ea/devicebind" extends="struts-default">
		<action name="ea_*" class="hy.ea.finance.action.InvestDeviceBind.DeviceBindAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
			<result name="nologin">/page/ea/not_login.jsp</result>
			<result name="investdevicebind">/page/ea/main/finance/BenDis/InvestDeviceBind/investDeviceBind.jsp</result>
			<result name="addYeWuYuan">/page/ea/main/finance/BenDis/InvestDeviceBind/addYeWuYuan.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="deviceBind.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="devicebind-sajaxs" namespace="/ea/devicebind" extends="json-default">
		<action name="sajax_*" class="hy.ea.finance.action.InvestDeviceBind.DeviceBindAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
			<result type="json">  
				<!-- root的值对应要返回的值的属性 -->    
				<!-- 这里的result值即是 对应action中的 result -->  
				<param name="root">result</param>  
			</result>
		</action>
	</package>
</struts>

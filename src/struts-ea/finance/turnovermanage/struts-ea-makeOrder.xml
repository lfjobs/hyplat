<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="ordermanage-sajax" namespace="/ea/turnovermanage"
             extends="json-default">
        <action name="sajax_*" class="hy.ea.finance.action.turnovermanage.MakeOrderAction" method="{1}">
            <result type="json">
                <param name="root">result</param>
            </result>
        </action>
    </package>

    <package strict-method-invocation="false" name="ordermanage-ea" namespace="/ea/turnovermanage"
             extends="json-default">
        <action name="ea_*" class="hy.ea.finance.action.turnovermanage.MakeOrderAction" method="{1}">
            <result type="json">
                <param name="root">detail</param>
            </result>
        </action>
    </package>

</struts>
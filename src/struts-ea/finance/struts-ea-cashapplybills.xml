<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="cashapplyforbills-ntoken"
		namespace="/ea/cashapplybills" extends="struts-default">
		<action name="ea_*"
			class="hy.ea.finance.action.CashApplyBillsAction" method="{1}">
			<result name="cash">
			/page/ea/main/finance/production/examine/accountant_edit.jsp
				<!-- /page/ea/main/finance/production/accountant_edit.jsp -->
			</result>
			<result name="cashList">
				/page/ea/main/finance/production/cashapplybills_list.jsp
			</result>
			<result name="cashPrint">
				/page/ea/main/finance/production/printcashapplybill.jsp
			</result>
			<result name="cashPrintother">
				/page/ea/main/finance/production/printcashqapplybill.jsp
			</result>
			<result name="edit">
				/page/ea/main/finance/production/cashapplybills_edit.jsp
			</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="cashierbills.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="cashapplyforbills-sajax"
		namespace="/ea/cashapplyforbills" extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.finance.action.CashApplyforBillsAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="cashapplybills-sajax"
		namespace="/ea/cashapplybills" extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.finance.action.CashApplyBillsAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>

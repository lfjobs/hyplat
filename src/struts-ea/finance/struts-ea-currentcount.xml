<?xml version="1.0" encoding="UTF-8" ?>
<!--部门日记账 -->
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="currentcount-token" namespace="/ea/currentcount"
		extends="ea-token">
		<action name="t_ea_*"
			class="hy.ea.finance.action.CurrentcountAction" method="{1}">
			<result name="to_currentcount">
				/page/ea/main/finance/personal_department/journal_list.jsp
			</result>
			
		</action>
	</package>
	<package strict-method-invocation="false" name="currentcount-ntoken" namespace="/ea/currentcount"
		extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.finance.action.CurrentcountAction" method="{1}">
			<param name="args">98_10_01_01_01_01</param>
			<result name="to_currentcount">
				/page/ea/main/finance/personal_department/journal_list.jsp
			</result>
			<result name="to_update">
				/page/ea/main/finance/personal_department/journal_add.jsp
			</result>
			<result name="showExcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="cu.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="currentcount-jsonajax" namespace="/ea/currentcount"
		extends="ea-sajax">
		<action name="sajax_ea_*"
			class="hy.ea.finance.action.CurrentcountAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="currentcount-njsonajax" namespace="/ea/currentcount"
		extends="json-default">
		<action name="sajax_n_ea_*"
			class="hy.ea.finance.action.CurrentcountAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>



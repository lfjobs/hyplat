    </package>
    <package strict-method-invocation="false" name="wholesale-sajax" namespace="/ea/wholesale" extends="json-default">
        <action name="sajax_ea_*" class="hy.ea.finance.action.brokerage.WholesaleAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>
        </action>
    </package>
    <!--批发价佣金模块终-->

    <!--VIP价佣金模块始-->
    <package strict-method-invocation="false" name="vip-token" namespace="/ea/vip" extends="struts-default">
        <action name="ea_*" class="hy.ea.finance.action.brokerage.VipAction" method="{1}">
            <result name="vip_list">/page/ea/main/finance/brokerage/vip/vip_list.jsp</result>
            <result name="vip_add">/page/ea/main/finance/brokerage/vip/vip_add.jsp</result>
            <result name="vip_update">/page/ea/main/finance/brokerage/vip/vip_update.jsp</result>
            <result name="failed">/page/ea/not_login.jsp</result>
            <result name="showexcel" type="stream">
                <param name="contentType">
                    application/vnd.ms-excel
                </param>
                <param name="inputName">excelStream</param>
                <param name="contentDisposition">
                    filename="vip.xls"
                </param>
                <param name="bufferSize">1024</param>
            </result>
        </action>
    </package>
    <package strict-method-invocation="false" name="vip-sajax" namespace="/ea/vip" extends="json-default">
        <action name="sajax_ea_*" class="hy.ea.finance.action.brokerage.VipAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->

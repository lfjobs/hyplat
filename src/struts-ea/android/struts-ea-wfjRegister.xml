<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="wfj-token" namespace="/ea/wfj" extends="struts-default">
		
		<action name="ea_*" class="com.tiantai.wfj.front.WfjEcusRegisterAction" method="{1}">
			<result name="tianyang">/page/WFJClient/Login.jsp?loginPage=login</result>
			<result name="cusInf">/page/WFJClient/Customer/CustomerInfo.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="companyReg">/page/WFJClient/Customer/CompanyReg.jsp</result>
			<result name="shopReg">/page/WFJClient/Customer/ShopReg.jsp</result>
			<result name="logOff"></result>
		</action>
	</package>
	<package strict-method-invocation="false" name="wfj-sajax" namespace="/ea/wfj" extends="json-default">
		<action name="sajax_ea_*" class="com.tiantai.wfj.front.WfjEcusRegisterAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
</struts>

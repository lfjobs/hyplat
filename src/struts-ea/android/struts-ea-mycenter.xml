<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="mycente-token" namespace="/ea/mycenter" extends="struts-default">

        <action name="ea_*" class="com.tiantai.wfj.front.MyCenterAction" method="{1}">
            <result name="success">/page/ea/success.jsp</result>
            <result name="mycenter">/page/WFJClient/pc/my/me.jsp</result>
            <result name="tocardinfo">/page/ea/main/office_ea/contract/percardinfo.jsp</result>
            <result name="mycode">/page/WFJClient/pc/my/mycode.jsp</result>
            <result name="baseinfo">/page/WFJClient/pc/my/basedata.jsp</result>
            <result name="login">/page/WFJClient/pc/pc_login.jsp</result>
            <result name="ascurity">/page/WFJClient/pc/my/set/accountSecurity.jsp</result>
            <result name="setlist">/page/WFJClient/pc/my/set/setlist.jsp</result>

            <!--个人认证-->
            <result name="myAuthentication">/page/ea/main/office_ea/contract/myAuthentication.jsp</result>


        </action>
    </package>
    <package strict-method-invocation="false" name="mycente-jsonajax" namespace="/ea/mycenter" extends="json-default">
        <action name="sajax_ea_*" class="com.tiantai.wfj.front.MyCenterAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>

        </action>
    </package>

</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="wfjhandle-token" namespace="/ea/wfjhandle" extends="struts-default">
		
		<action name="ea_*" class="com.tiantai.wfj.front.WfjDataHandle" method="{1}">
		<result name="selete">/page/ea/ccompany/company/WfjAccountData_edit.jsp</result>
		<result name="">/page/WFJClient/ShopOwner/ShopShow.jsp</result>
		
		</action>
	</package>
	<package strict-method-invocation="false" name="wfjhandle-jsonajax" namespace="/ea/wfjhandle" extends="json-default">
		<action name="sajax_ea_*" class="com.tiantai.wfj.front.WfjDataHandle" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
	
</struts>

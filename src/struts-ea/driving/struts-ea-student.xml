<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="student-ntoken" namespace="/ea/student" extends="struts-default">
		<action name="ea_*" class="hy.ea.driving.action.StudentAction" method="{1}">
			<result name="pjList">/page/WFJClient/Student/StudentAppraise.jsp</result>
			<result name="addApprise">/page/WFJClient/Student/AddApprise.jsp</result>
			<result name="tealist">/page/WFJClient/Student/teacherlist.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="student-sajax" namespace="/ea/student" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.driving.action.StudentAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">results</param>  
            </result>  

		</action>
	</package>
</struts>

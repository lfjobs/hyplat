<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <package strict-method-invocation="false" name="elkcInform-ntoken" namespace="/ea/elkcInform" extends="struts-default">
        <action name="ea_*" class="hy.ea.driving.action.elkc.ElkcInformAction" method="{1}">
            <result name="mobileLogin">/page/ea/BuildPlatform/MobileOfficeLogin.jsp</result>
            <result name="traineeInformation">/page/ea/main/driving/elkc/traineeInformation.jsp</result>
            <result name="detailsOfStudentInformation">/page/ea/main/driving/elkc/detailsOfStudentInformation.jsp</result>
            <result name="coachNews">/page/ea/main/driving/elkc/coachNews.jsp</result>
            <result name="coachMessageSend">/page/ea/main/driving/elkc/coachMessageSend.jsp</result>
            <result name="coachMessageSendDetails">/page/ea/main/driving/elkc/coachMessageSendDetails.jsp</result>
            <result name="addAMessage">/page/ea/main/driving/elkc/addAMessage.jsp</result>
        </action>
    </package>
    <package strict-method-invocation="false" name="elkcInform-sajax" namespace="/ea/elkcInform" extends="json-default">
        <action name="sajax_ea_*" class="hy.ea.driving.action.elkc.ElkcInformAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>

        </action>
    </package>
</struts>

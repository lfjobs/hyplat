<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="reservmode-ntoken" namespace="/ea/reservmode"  extends="struts-default">
		<action name="ea_*" class="hy.ea.driving.action.elkc.ElkcReservationModeAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
			<result name="login">/page/ea/not_login.jsp</result>
			<result name="modeadd">/page/ea/main/driving/elkc/reservationModeAdd.jsp</result>
			<result name="modelist">/page/ea/main/driving/elkc/reservationModeList.jsp</result>

		</action>
	</package>
	
	<package strict-method-invocation="false" name="reservmode-sajax" namespace="/ea/reservmode" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.driving.action.elkc.ElkcReservationModeAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
  
</struts>

<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
        "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
        "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <package strict-method-invocation="false" name="complaint-ntoken" namespace="/ea/complaint"  extends="struts-default">
        <action name="ea_*" class="hy.ea.driving.action.elkc.ComplaintSchoolAction" method="{1}">
            <result name="detailsComplaints">/page/ea/main/driving/elkc/detailsComplaints.jsp</result>
            <result name="complaintSchool">/page/ea/main/driving/elkc/complaintSchool.jsp</result>
            <result name="complaint">/page/ea/main/driving/elkc/schoolReply.jsp</result>
            <result name="allteacher">/page/ea/main/driving/elkc/complaint.jsp</result>
            <result name="teachers">/page/ea/main/driving/elkc/schoolReplys.jsp</result>

        </action>
    </package>

    <package strict-method-invocation="false" name="complaint-sajax" namespace="/ea/complaint" extends="json-default">
        <action name="sajax_ea_*" class="hy.ea.driving.action.elkc.ComplaintSchoolAction" method="{1}">
            <!-- 返回类型为json 在sjon-default中定义 -->
            <result type="json">
                <!-- root的值对应要返回的值的属性 -->
                <!-- 这里的result值即是 对应action中的 result -->
                <param name="root">result</param>
            </result>

        </action>
    </package>

</struts>
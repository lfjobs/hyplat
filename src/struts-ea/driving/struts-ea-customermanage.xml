<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<package strict-method-invocation="false" name="customermanage-ntoken" namespace="/ea/customermanage"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.driving.action.CustomerManageAction" method="{1}">
			 <result name="list">/page/ea/main/driving/customerManage.jsp</result>
			 <result name="potentiallist">/page/ea/main/driving/potentialCustomer.jsp</result>
			 <result name="potentiallistSummary">/page/ea/main/driving/potentialCustomerSummary.jsp</result>
			 <result name="sortlist">/page/ea/main/driving/customerSort.jsp</result>
			 <result name="messagelist">/page/ea/main/driving/customerMessage.jsp</result>
			 <result name="success">/page/ea/success.jsp</result>
			 <result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="customermanage.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="customermanage-jsonajax" namespace="/ea/customermanage" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.driving.action.CustomerManageAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>
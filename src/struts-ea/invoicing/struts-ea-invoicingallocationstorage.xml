<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="allocationsto-token" namespace="/ea/allocationsto"
		extends="ea-token">
		<action name="t_ea_*"
			class="hy.ea.invoicing.action.AllocationStorageAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="allocationsto-ntoken" namespace="/ea/allocationsto"
		extends="struts-default">
		<action name="ea_*"
			class="hy.ea.invoicing.action.AllocationStorageAction" method="{1}">
			<result name=""></result>
			<!--调拨 入库单列表 -->
			<result name="toallostoragelist">/page/ea/main/finance/invoicing/transfersBill_dan.jsp</result>
			<!--打印预览  -->
			<result name="toSeegbprint">/page/ea/main/finance/invoicing/allocationstorage_print.jsp</result>
			<!--查看-->
			<result name="toSeegb">/page/ea/main/finance/invoicing/allocationstorage_see.jsp</result>
			<!--单据更改-->
			<result name="toinvoicingstorage">
				/page/ea/main/finance/invoicing/allocationstorage_edit.jsp
			</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="allocationsto.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="allocationsto-jsonajax" namespace="/ea/allocationsto"
		extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.invoicing.action.AllocationStorageAction" method="{1}">
			<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="vaccount-token" namespace="/ea/vaccount"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.invoicing.action.voucher.VoucherAccountAction" method="{1}">
			<result name="list">/page/ea/main/finance/invoicing/voucher/vaccount_search.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="vaccount-ntoken" namespace="/ea/vaccount"  extends="struts-default">
		<action name="ea_*" class="hy.ea.invoicing.action.voucher.VoucherAccountAction" method="{1}">
			 <result name="list">/page/ea/main/finance/invoicing/voucher/vaccount_search.jsp</result>
			 <result name="clist">/page/ea/main/finance/invoicing/voucher/cvaccount_search.jsp</result>
			 <result name="print">/page/ea/main/finance/invoicing/voucher/vaccount_print.jsp</result>
			 <result name="printz">/page/ea/main/finance/invoicing/voucher/vaccount_prints.jsp</result>
			 <result name="printmoney">/page/ea/main/finance/invoicing/voucher/moneyAccount_prints.jsp</result>
			 <result name="login">/page/ea/not_login.jsp</result>
			 <result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="Account.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="vaccount-njsonajax" namespace="/ea/vaccount" extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.invoicing.action.voucher.VoucherAccountAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	
	<package strict-method-invocation="false" name="warehouse-token" namespace="/ea/warehouse"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.invoicing.action.WareHouseAction" method="{1}">
			<result name="warehouselist">/page/ea/main/warehouse/warehouse_list.jsp</result>
		</action>
	</package>
	
	<package strict-method-invocation="false" name="warehouse-ntoken" namespace="/ea/warehouse" extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.invoicing.action.WareHouseAction" method="{1}">
			<result name="success">/page/ea/success.jsp</result>
			<result name="warehouselist">/page/ea/main/warehouse/warehouse_list.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="warehouse.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="warehouse-sajax" namespace="/ea/warehouse" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.invoicing.action.WareHouseAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  

		</action>
	</package>
	
</struts>

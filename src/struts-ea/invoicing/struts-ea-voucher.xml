<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
	<package strict-method-invocation="false" name="voucher-token" namespace="/ea/voucher"  extends="ea-token">
		<action name="t_ea_*" class="hy.ea.invoicing.action.voucher.VoucherAction" method="{1}">
			<result name="list">/page/ea/main/finance/invoicing/voucher/voucher.jsp</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="voucher-ntoken" namespace="/ea/voucher"  extends="struts-default">
		<action name="ea_*" class="hy.ea.invoicing.action.voucher.VoucherAction" method="{1}">
			 <result name="tovoucherinput">/page/ea/main/finance/invoicing/voucher/voucher.jsp</result>			 
			 <result name="add">/page/ea/main/finance/invoicing/voucher/voucher_add.jsp</result>
			 <result name="see">/page/ea/main/finance/invoicing/voucher/voucher_see.jsp</result>
			 <result name="print">/page/ea/main/finance/invoicing/voucher/voucher_print.jsp</result>
			 <result name="jiezhang">/page/ea/main/navigation/finace_n.jsp</result>
			 <result name="login">/page/ea/not_login.jsp</result>
			 <result name="voucherExamine">/page/ea/main/finance/invoicing/voucher/examine_list.jsp</result>
			 <result name="voucherAccounting">/page/ea/main/finance/invoicing/voucher/accounting_list.jsp</result>
			 <result name="printing">/page/ea/main/finance/invoicing/voucher/printing_print.jsp</result>
			 <result name="trialBalance">/page/ea/main/finance/invoicing/voucher/trial_print.jsp</result>
			 <result name="examinePrint">/page/ea/main/finance/invoicing/voucher/examine_print.jsp</result>
			 <result name="success">/page/ea/success.jsp</result> 
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="voucher.xls"
				</param>
				<param name="bufferSize">1024</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="voucher-njsonajax" namespace="/ea/voucher" extends="json-default">
		<action name="sajax_ea_*"
			class="hy.ea.invoicing.action.voucher.VoucherAction" method="{1}">
			<!-- 返回类型为json 在sjon-default中定义 -->
			<result type="json">
				<!-- root的值对应要返回的值的属性 -->
				<!-- 这里的result值即是 对应action中的 result -->
				<param name="root">result</param>
			</result>
		</action>
	</package>
</struts>
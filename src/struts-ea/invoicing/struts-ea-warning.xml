<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>	
	<package strict-method-invocation="false" name="warning-ntoken"  namespace="/ea/warning"  extends="ea-ntoken">
		<action name="ea_*" class="hy.ea.invoicing.action.WarningAction" method="{1}">
			<result name="list">/page/ea/main/finance/invoicing/warning_list.jsp</result>
			<result name="success">/page/ea/success.jsp</result>
			<result name="showexcel" type="stream">
				<param name="contentType">
					application/vnd.ms-excel
				</param>
				<param name="inputName">excelStream</param>
				<param name="contentDisposition">
					filename="RankPublicreceipts.xls"
				</param>
			</result>
		</action>
	</package>
	<package strict-method-invocation="false" name="warning-jsonajax" namespace="/ea/warning" extends="json-default">
		<action name="sajax_ea_*" class="hy.ea.invoicing.action.WarningAction" method="{1}">
		<result name="syserror">/page/ea/sys_error.jsp</result>
			<!-- 返回类型为json 在sjon-default中定义 -->  
            <result type="json">  
                <!-- root的值对应要返回的值的属性 -->  
                <!-- 这里的result值即是 对应action中的 result -->  
                <param name="root">result</param>  
            </result>  
		</action>
	</package>
</struts>


<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="mobile.tiantai.android.bo">
    <class name="CompanyDetail" table="DT_ad_companydetail" schema="HYPLAT">
        <id name="key" type="java.lang.String">
            <column name="key" length="50" />
            <generator class="uuid" />
        </id>
        <property name="id" type="java.lang.String">
            <column name="id" length="50" />
        </property>
        <property name="companyID" type="java.lang.String">
            <column name="companyID" length="50" />
        </property>
         <property name="logourl" type="java.lang.String">
            <column name="logourl" length="200" />
        </property>
             <property name="qrcodeurl" type="java.lang.String">
            <column name="qrcodeurl" length="200" />
        </property>
          <property name="title" type="java.lang.String">
            <column name="title" length="100" />
        </property>
          <property name="industry" type="java.lang.String">
            <column name="industry" length="50" />
        </property>
          <property name="brief" type="java.lang.String">
            <column name="brief" length="250" />
        </property>
          <property name="eculture" type="java.lang.String">
            <column name="eculture" length="250" />
        </property>
        <property name="telphone" type="java.lang.String">
            <column name="telphone" length="11" />
        </property>
        <property name="email" type="java.lang.String">
            <column name="email" length="50" />
        </property>
        <property name="remarks" type="java.lang.String">
            <column name="remarks"  length="250"/>
        </property>
        <property name="website" type="java.lang.String">
            <column name="website" length="100"/>
        </property>
        <property name="address" type="java.lang.String">
            <column name="address" length="100" />
        </property>
         <property name="type" type="java.lang.String">
            <column name="type" length="200" />
        </property>
        <property name="pic1" type="java.lang.String">
            <column name="pic1" length="200" />
        </property>
           <property name="pic2" type="java.lang.String">
            <column name="pic2" length="200" />
        </property>
           <property name="pic3" type="java.lang.String">
            <column name="pic3" length="200" />
        </property>
           <property name="pic4" type="java.lang.String">
            <column name="pic4" length="200" />
        </property>
           <property name="pic5" type="java.lang.String">
            <column name="pic5" length="200" />
        </property>
           <property name="pic6" type="java.lang.String">
            <column name="pic6" length="200" />
        </property>
           <property name="pic7" type="java.lang.String">
            <column name="pic7" length="200" />
        </property>
           <property name="pic8" type="java.lang.String">
            <column name="pic8" length="200" />
        </property>
    </class>
</hibernate-mapping>

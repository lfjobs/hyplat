<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="mobile.tiantai.android.bo.TrilateralDataAudit" table="TRILATERAL_DATA_AUDIT" schema="HYPLAT">
        <id name="id" type="java.lang.String">
            <column name="id" length="50" not-null="true"/>
        </id>
        <property name="auditStaffId" type="java.lang.String">
            <column name="audit_Staff_Id" length="100"/>
        </property>
        <property name="sendStaffId" type="java.lang.String">
            <column name="send_Staff_Id" length="100"/>
        </property>
        <property name="sendStaffName" type="java.lang.String">
            <column name="send_Staff_Name" length="100"/>
        </property>
        <property name="trilateralDataId" type="java.lang.String">
            <column name="trilateral_Data_Id" length="100"/>
        </property>
        <property name="auditStaffName" type="java.lang.String">
            <column name="audit_Staff_Name" length="100"/>
        </property>
        <property name="auditOpinion" type="java.lang.String">
            <column name="audit_Opinion" length="100"/>
        </property>
        <property name="auditStatus" type="java.lang.String">
            <column name="audit_Status" length="100"/>
        </property>
        <property name="auditTime" type="java.lang.String">
            <column name="audit_Time" length="100"/>
        </property>
        <property name="updateTime" type="java.lang.String">
            <column name="update_Time" length="100"/>
        </property>


    </class>
</hibernate-mapping>
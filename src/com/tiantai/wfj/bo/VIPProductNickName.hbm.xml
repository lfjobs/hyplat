<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
	<class name="com.tiantai.wfj.bo.VIPProductNickName" schema="HYPLAT"
		table="dtVIPProductNickName">
		<id name="vpkey" type="java.lang.String">
			<column length="50" name="vpkey" />
			<generator class="uuid" />
		</id>
		<property name="vpId" type="java.lang.String">
			<column length="50" name="vpId">
				<comment>ID</comment>
			</column>
		</property>
		<property name="companyID" type="java.lang.String">
			<column length="50" name="companyID">
				<comment>公司ID</comment>
			</column>
		</property>
		<property name="ccompanyID" type="java.lang.String">
			<column length="50" name="ccompanyID">
				<comment>往来单位ID</comment>
			</column>
		</property>
		<property name="nickname" type="java.lang.String">
			<column length="50" name="nickname">
				<comment>会员昵称</comment>
			</column>
		</property>
		<property name="ppID" type="java.lang.String">
			<column length="50" name="ppID">
				<comment>会员产品ID</comment>
			</column>
		</property>
		<property name="updateDate" type="java.util.Date">
			<column name="updateDate">
				<comment>修改昵称时间</comment>
			</column>
		</property>
		<property name="comstate" type="java.lang.String">
			<column length="50" name="comstate">
				<comment>20大型；21：中型；22:小型 30：微型；40：微小型 50小微 60:省级
					// 61：县级，62：村级</comment>
			</column>
		</property>

	</class>
</hibernate-mapping>

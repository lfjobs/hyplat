<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.tiantai.wfj.bo">
	<class name="BindDevice" table="DT_BindDevice" schema="HYPLAT" dynamic-insert="true">
	<comment>一个商户绑定多个设备</comment>
		<id length="50" name="bdKey" type="java.lang.String">
			<column length="50" name="bdKey" />
			<generator class="uuid" />
		</id>
		<property name="bdID" type="java.lang.String">
			<column length="50" name="bdID" >
			</column>
		</property>
		<property name="subCompanyID" type="java.lang.String">
			<column length="50" name="subCompanyID" >
			</column>
		</property>
		<property name="sn" type="java.lang.String">
			<column name="sn" length="50">
				<comment>设备序列号</comment>
			</column>
		</property>
		<property name="pfdID" type="java.lang.String">
			<column name="pfdID" length="50">
				<comment>设备ID</comment>
			</column>
		</property>
		<property name="bindDate" type="java.util.Date">
			<column name="bindDate" >
				<comment>绑定日期</comment>
			</column>
		</property>
		<property name="bindID" type="java.lang.String">
			<column length="50" name="bindID" >
				<comment>绑定人ID</comment>
			</column>
		</property>
		<property name="bindName" type="java.lang.String">
			<column length="50" name="bindName" >
				<comment>绑定人姓名</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>

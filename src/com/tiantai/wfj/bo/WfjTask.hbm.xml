<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.tiantai.wfj.bo">
	<class name="WfjTask" table="DT_WFJ_TASK" schema="HYPLAT" dynamic-insert="true">
	<comment>任务完成表</comment>
		<id length="50" name="wfjTaskKey" type="java.lang.String">
			<column length="50" name="WFJ_TASK_KEY" />
			<generator class="uuid" />
		</id>
		<property name="wfjTaskId" type="java.lang.String">
			<column length="50" name="WFJ_TASK_ID" >
			</column>
		</property>
		<property name="staffId" type="java.lang.String">
			<column name="STAFF_ID" length="50">
			<comment>人员Id</comment>
			</column>
		</property>
		<property name="wfjGuizeId" type="java.lang.String">
			<column length="50" name="WFJ_GUIZE_ID" >
			<comment>规则外键</comment>
			</column>
		</property>
		<property name="wfjTaskDate" type="java.util.Date">
			<column length="50" name="WFJ_TASK_DATE" default="sysdate">
			<comment>日期</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>

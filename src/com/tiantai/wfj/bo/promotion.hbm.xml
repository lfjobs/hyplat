<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.tiantai.wfj.bo">
	<class name="Promotion" table="DT_promotion" schema="HYPLAT"
		dynamic-insert="true">
		<comment>促销品</comment>
		<id length="50" name="promotionKey" type="java.lang.String">
			<column length="50" name="promotionKey" />
			<generator class="uuid" />
		</id>
		<property name="promotionId" type="java.lang.String">
			<column length="50" name="promotionId">
			</column>
		</property>
		<property name="ppId" type="java.lang.String">
			<column length="50" name="ppId">
				<comment>产品Id</comment>
			</column>
		</property>
		<property name="ptppId" type="java.lang.String">
			<column length="50" name="ptppId">
				<comment>促销产品Id</comment>
			</column>
		</property>
		<property name="companyId" type="java.lang.String">
			<column length="50" name="companyId">
				<comment>产品公司Id</comment>
			</column>
		</property>
		<property name="ptcompanyId" type="java.lang.String">
			<column length="50" name="ptcompanyId">
				<comment>促销产品公司Id</comment>
			</column>
		</property>
		<property name="promotionDate">
			<column name="promotionDate">
				<comment>保存时间</comment>
			</column>
		</property>
		<property name="comboGenre" type="java.lang.Integer">
			<column length="2" name="comboGenre">
				<comment>套餐类型</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>	                                
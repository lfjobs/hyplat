<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.plat.bo">
	<class name="SRole" table="dtSRole">
		<id name="roleKey">
			<column length="50" name="roleKey" />
			<generator class="uuid" />
		</id>
		<property name="roleID">
			<column length="50" name="roleID" unique="true" not-null="true" />
		</property>
		<property name="roleName">
			<column length="50" name="roleName" not-null="true" />
		</property>
		<property name="roleDesc">
			<column length="256" name="roleDesc" />
		</property>
	</class>
</hibernate-mapping>

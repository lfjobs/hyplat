<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">


<hibernate-mapping>
    <class name="hy.ea.marketing.bo.InvestApply" table="DT_InvestApply" schema="HYPLAT">
        <id name="inapKey">
            <column name="inapKey" length="50" />
            <generator class="uuid" />
        </id>
        <property name="inapId">
            <column name="inapId" length="50" not-null="true" />
        </property>
        <property name="susid">
            <column name="susid" length="50"><comment>申请产品代理id</comment></column>
        </property>
        <property name="sccId">
            <column name="sccId" length="50"><comment>申请人sccid</comment></column>
        </property>
        <property name="agree">
            <column name="agree" length="10"><comment>审核00拒绝01同意</comment></column>
        </property>
        <property name="inapDate">
            <column name="inapDate"><comment>生成时间</comment></column>
        </property>
        <property name="areappid">
            <column name="areappid" length="50"><comment>区域产品id</comment></column>
        </property>
        <property name="areaName">
            <column name="areaName" length="50"><comment>区域名称</comment></column>
        </property>
    </class>
</hibernate-mapping>
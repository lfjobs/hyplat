<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.BuildPlatform">
	<class name="TeamBuild" table="dtteambuild">
		<id length="50" name="teamBuildKey">
			<column length="50" name="teamBuildKey" />
			<generator class="uuid" />
		</id>
		<property name="teamBuildId">
			<column length="50" name="teamBuildId" not-null="true" />
		</property>
		 <property name="staffId">
        	<column name="staffId" length="50"  not-null="true"/>
        </property>
        	<property name="companyId">
        	<column name="companyId" length="50" not-null="true"/>
        </property>	
	</class>
</hibernate-mapping>
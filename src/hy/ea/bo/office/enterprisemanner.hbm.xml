<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="EnterpriseManner" table="dtEnterpriseManner">
		<id length="50" name="mannerKey">
			<column length="50" name="mannerKey" />
			<generator class="uuid" />
		</id>
		<property name="mannerID">
			<column length="50" name="mannerID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="enterpriseName">
			<column length="250" name="enterpriseName" />
		</property>
		<property  name="mannerContent">
			<column length="256" name="mannerContent" />
		</property>
		<property  name="mannerNote">
			<column length="250" name="mannerNote" />
		</property>
	</class>
</hibernate-mapping>

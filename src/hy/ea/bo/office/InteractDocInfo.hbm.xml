<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="InteractDocInfo" table="DT_OA_DOCUMENT_ITR">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="intId" type="java.lang.String">
			<column name="intId" length="50" />
		</property>
		<property name="userName" type="java.lang.String">
			<column name="userName" length="50" />
		</property>
		<property name="password" type="java.lang.String">
			<column name="password" length="50" />
		</property>
		<property name="smId" type="java.lang.String">
			<column name="smId" length="50" />
		</property>
		<property name="docId" type="java.lang.String">
			<column name="docId" length="255" />
		</property>
		<property name="title" type="java.lang.String">
			<column name="title" length="50" />
		</property>
		<property name="wordUri" type="java.lang.String">
			<column name="wordUri" length="4000" />
		</property>
		<property name="web" type="java.lang.String">
			<column name="web" length="50" />
		</property>
		<property name="visitType" type="java.lang.String">
			<column name="visitType" length="50" />
		</property>
		<property name="passTime" type="java.util.Date">
			<column name="passTime" length="50" />
		</property>
		<property name="status" type="java.lang.String">
			<column name="status" length="50" />
		</property>
	</class>
</hibernate-mapping>

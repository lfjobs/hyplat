<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
    <class name="CarRelationMarket" table="DT_CAR_RELATIONMARKET">
        <id length="50" name="rmKey">
            <column length="50" name="rmKey" />
            <generator class="uuid" />
        </id>
        <property name="rmId">
            <column length="50" name="rmId"/>
        </property>
        <property name="carId">
            <column length="50" name="carId"/>
        </property>
        <property name="marketId">
            <column length="50" name="marketId" />
        </property>
    </class>
</hibernate-mapping>

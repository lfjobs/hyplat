<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="DoubaoSession" table="dtDoubaoSession">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="id">
			<column length="50" name="id"/>
		</property>
		<property name="sccId">
			<column length="50" name="sccId"/>
		</property>
		<property name="sessionId">
			<column length="50" name="sessionId"/>
		</property>
		<property name="isfile">
			<column  name="isfile" />
		</property>
		<property name="type">
			<column length="20" name="type" />
		</property>
		<property name="text">
			<column length="25000" name="text" />
		</property>

		<property  name="createDate">
			<column name="createDate" />
		</property>
	</class>
</hibernate-mapping>

		</property>
		<property name="site" type="java.lang.String">
			<column name="site" length="250" />
		</property>

		<property  name="managementFees">
			<column length="10" name="managementFees" >
				<comment>管理费</comment>
			</column>
		</property>
		<property  name="operatingFee">
			<column length="10" name="operatingFee" >
				<comment>操作费</comment>
			</column>
		</property>
		<property  name="dmanagementFees">
			<column length="50" name="dmanagementFees" >
				<comment>大写管理费</comment>
			</column>
		</property>

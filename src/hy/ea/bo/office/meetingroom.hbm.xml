<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="MeetingRoom" table="dtMeetingRoom">
		<id length="50" name="mroomKey">
			<column length="50" name="mroomKey" />
			<generator class="uuid" />
		</id>
		<property name="mroomID">
			<column length="50" name="mroomID"/>
		</property>
		<property name="roomName">
			<column length="50" name="roomName"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="zone">
			<column length="50" name="zone"/>
		</property>
		<property name="remark">
			<column length="250" name="remark"/>
		</property>
		<property name="capacity">
			<column length="50" name="capacity" />
		</property>
			<property name="adminID">
			<column length="50" name="adminID" />
		</property>
			<property name="adminName">
			<column length="50" name="adminName" />
		</property>
		<property name="adminTel">
			<column length="11" name="adminTel" />
		</property>
		
	</class>
</hibernate-mapping>

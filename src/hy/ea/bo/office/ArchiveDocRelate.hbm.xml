<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="ArchiveDocRelate" table="DT_OA_ArchiveDocRelate">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="adrId" type="java.lang.String">
			<column name="adrId" length="50" />
		</property>
		<property name="adtId" type="java.lang.String">
			<column name="adtId" length="50" />
		</property>

		<property name="docId" type="java.lang.String">
			<column name="docId" length="50" />
		</property>

		<property name="time" type="java.util.Date">
			<column name="time" length="7" />
		</property>
		<property name="createrID" type="java.lang.String">
			<column name="createrID" length="50" />
		</property>
		<property name="companyID" type="java.lang.String">
			<column name="companyID" length="50" />
		</property>

		<property name="seq" type="java.lang.Integer">
			<column name="seq" />
		</property>

		<property name="createrName" type="java.lang.String">
			<column name="createrName" length="50" />
		</property>
	</class>
</hibernate-mapping>

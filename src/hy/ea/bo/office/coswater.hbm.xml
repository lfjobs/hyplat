<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="COSWater" table="dtCOSWater">
		<id length="50" name="waterKey">
			<column length="50" name="waterKey" />
			<generator class="uuid" />
		</id>
		<property name="waterID">
			<column length="50" name="waterID" not-null="true"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID" not-null="true"/>
		</property>
		<property name="unit">
			<column length="250" name="unit"/>
		</property>
		<property name="logDate">
			<column length="210" name="logDate"/>
		</property>
		<property name="amount">
			<column length="250" name="amount"/>
		</property>
		<property name="usedAmount">
			<column length="250" name="usedAmount" />
		</property>
	</class>
</hibernate-mapping>

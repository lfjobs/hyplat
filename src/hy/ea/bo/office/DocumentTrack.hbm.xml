<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.office">
	<class name="DocumentTrack" table="DT_OA_DOCUMENT_TRACK">
		<id length="50" name="key">
			<column length="50" name="key" />
			<generator class="uuid" />
		</id>
		<property name="trackId" type="java.lang.String">
			<column name="trackId" length="50" />
		</property>
		<property name="docId" type="java.lang.String">
			<column name="docId" length="50" />
		</property>
		<property name="operateContent" type="java.lang.String">
			<column name="operateContent" length="200" />
		</property>
		<property name="operatorID" type="java.lang.String">
			<column name="operatorID" length="50" />
		</property>
		<property name="deptIDofOperator" type="java.lang.String">
			<column name="deptIDofOperator" length="50" />
		</property>
		<property name="compnayIDofOperator" type="java.lang.String">
			<column name="compnayIDofOperator" length="50" />
		</property>
		<property name="operaterTime" type="java.lang.String">
			<column name="operaterTime" length="20" />
		</property>

	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="EnterpriseMeritorious" table="dtEnterpriseMeritorious">
		<id length="50" name="meritoriouKey">
			<column length="50" name="meritoriouKey" />
			<generator class="uuid" />
		</id>
		<property name="meritoriouID">
			<column length="50" name="meritoriouID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="organizationID">
			<column length="50" name="organizationID"/>
		</property>
		<property name="staffName">
			<column length="250" name="staffName" />
		</property>
		<property  name="post">
			<column length="250" name="post" />
		</property>
		<property  name="rewardName">
			<column length="250" name="rewardName" />
		</property>
		<property  name="rewardContent">
			<column length="256" name="rewardContent" />
		</property>
		<property  name="allowance">
			<column length="250" name="allowance" />
		</property>
		<property  name="rewardYear">
			<column length="250" name="rewardYear" />
		</property>
		<property  name="picture">
			<column length="256" name="picture" />
		</property>
		<property  name="remark">
			<column length="256" name="remark" />
		</property>
	</class>
</hibernate-mapping>

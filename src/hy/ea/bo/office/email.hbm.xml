<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.office">
	<class name="Email" table="dtEmail">
		<id length="50" name="emailKey">
			<column length="50" name="emailKey" />
			<generator class="uuid" />
		</id>
		<property name="emailID">
			<column length="50" name="emailID"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID"/>
		</property>
		<property name="addresserID">
			<column length="50" name="addresserID"/>
		</property>
		<property name="addresseeID">
			<column length="50" name="addresseeID"/>
		</property>
		<property name="title">
			<column length="250" name="title" />
		</property>
		<property name="content">
			<column length="256" name="content" />
		</property>
		<property  name="emailDate">
			<column  name="emailDate" />
		</property>
		<property  name="addresserStatus">
			<column length="250" name="addresserStatus" />
		</property>
		<property  name="addresseeStatus">
			<column length="250" name="addresseeStatus" />
		</property>
		
		
	</class>
</hibernate-mapping>

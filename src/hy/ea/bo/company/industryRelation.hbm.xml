<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.company">
    <class name="IndustryRelation" table="dt_IndustryRelation">
        <id length="50" name="industryKey">
            <column length="50" name="industryKey">
                <comment>数据库主键</comment>
            </column>
            <generator class="uuid" />
        </id>
        <property name="industryId">
            <column length="50" name="industryId" >
                <comment>行业ID</comment>
            </column>
        </property>
        <property name="industryName">
            <column length="100" name="industryName">
                <comment>行业名称</comment>
            </column>
        </property>
        <property name="platforReturn">
            <column length="50" name="platforReturn">
                <comment>对应的平台返回值</comment>
            </column>
        </property>
        <property name="ppId">
            <column length="50" name="ppId" >
                <comment>产品ID</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.company">
    <class name="DepotManage" table="dtDepotManage">
        <id length="50" name="depotKey">
            <column length="50" name="depotKey"/>
            <generator class="uuid"/>
        </id>
        <property name="depotID">
            <column length="50" name="depotID" not-null="true"/>
        </property>
        <property name="depotPID">
            <column length="50" name="depotPID" not-null="true"/>
        </property>
        <property name="companyID">
            <column length="50" name="companyID"/>
        </property>
        <property name="depotNum">
            <column length="250" name="depotNum"/>
        </property>
        <property name="depotName">
            <column name="depotName" length="250"/>
        </property>
        <property name="usertype">
            <column name="usertype" length="250"/>
        </property>
        <property name="useraccount">
            <column name="useraccount" length="250"/>
        </property>
        <property name="itemID">
            <column name="itemID" length="250"/>
        </property>
        <property name="depotCoding">
            <column length="250" name="depotCoding"/>
        </property>
        <property name="useState">
            <column length="2" name="useState"/>
        </property>
        <property name="remark">
            <column length="256" name="remark"/>
        </property>
        <property name="depotState">
            <column length="2" name="depotState"/>
        </property>
        <property name="depotType">
            <column length="50" name="depotType"/>
        </property>
        <property name="depotAddress">
            <column length="250" name="depotAddress"/>
        </property>
        <property name="dwLnglatX">
            <column length="50" name="dwLnglatX"/>
        </property>
        <property name="dwLnglatY">
            <column length="50" name="dwLnglatY"/>
        </property>
        <property name="depotshare">
            <column length="50" name="depotshare">
                <comment>是否共享  0：共享  1：不共享</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

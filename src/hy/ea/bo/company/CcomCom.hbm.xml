<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.company">
	<class name="CcomCom" table="DT_ccom_com">
	<comment>往来单位公司关系表</comment>
		<id length="50" name="ccomRelationKey">
			<column length="50" name="ccom_relation_key" ><comment></comment></column>
			<generator class="uuid" />
		</id>
		<property name="ccomRelationId">
			<column length="50" name="ccom_relation_id" ><comment>业务主键</comment></column>
		</property>
		<property name="comanyId">
			<column length="50" name="compnay_id" ><comment>FK:公司表业务主键</comment></column>
		</property>
		<property name="ccompanyId">
			<column length="50" name="ccompany_Id" ><comment>FK:往来公司业务主键</comment></column>
		</property>
		<property name="state">
			<column length="2" name="state" ><comment>状态默认0正常</comment></column>
		</property>
	</class>
</hibernate-mapping>

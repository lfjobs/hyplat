<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
	"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.audits">
    <class name="Auditor" table="dt_au_Auditor">
        <id name="auditKey" length="50">
        	<column name="auditKey" length="50"/>
        	<generator class="uuid" />
        </id>
         <property name="auditId">
        	<column name="auditId" length="50" unique="true" not-null="true"/>
        </property>
           <property name="auditorName">
        	<column name="auditorName" length="250"  />
        </property>
             <property name="auditorID">
        	<column name="auditorID" length="50"  />
        </property>
        <property name="post" >
        	<column name="post" length="50" />
        </property>
        <property name="phaseId" >
        	<column name="phaseId" length="50" />
        </property>
         <property name="proId" >
        	<column name="proId" length="50"/>
        </property>
        <property name="orderNum" >
        	<column name="orderNum" length="50"  />
        </property>
          <property name="companyID">
        	<column name="companyID" length="50" />
        </property>
          <property name="organizationID">
        	<column name="organizationID" length="50" />
        </property>
    </class>
</hibernate-mapping>

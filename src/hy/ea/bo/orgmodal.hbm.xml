<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo">
	<class name="OrgModal"  table="dt_org_modal">
	<comment>自定义导航关联bo</comment>
		<id length="50" name="orgModalKey">
			<column length="50" name="org_modal_key" />
			<generator class="uuid" />
		</id>
		<property name="orgModalId">
			<column length="50" name="org_modal_id" >
			<comment>逻辑主键</comment></column>
		</property>
		<property name="orgnizationId">
			<column length="50" name="org_or_com_id" >
			<comment>CORGANIZATION组织机构或者公司逻辑主键</comment></column>
		</property>
		<property name="modalId">
			<column length="50" name="modal_id" >
			<comment>cmodal自定义导航模块逻辑主键</comment></column>
		</property>
		<property name="companyId">
			<column length="50" name="company_id" >
			<comment>company公司逻辑主键</comment></column>
		</property>
	</class>
</hibernate-mapping>
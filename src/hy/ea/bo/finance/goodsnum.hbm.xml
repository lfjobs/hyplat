<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="GoodsNum" table="dtgoodsnum">
		<id length="50" name="gnKey">
			<column length="50" name="gnKey" />
			<generator class="uuid" />
		</id>
		 <property name="gnID">
        	<column name="gnID" length="50"/>
        </property>
        <property name="gnPID">
        	<column name="gnPID" length="50"/>
        </property>
        <property name="companyID">
        	<column name="companyID" length="50"/>
        </property>
         <property name="goodsID">
        	<column name="goodsID" length="50"/>
        </property>
          <property name="cashierBillsID">
        	<column name="cashierBillsID" length="50"/>
        </property>
		<property name="goodsBillsID">
        	<column name="goodsBillsID" length="50"/>
        </property>
        <property name="phaseDate">
        	<column name="phaseDate" />
        </property>
        <property name="status">
        	<column name="status" length="50"/>
        </property>
         <property name="goodsnumber">
        	<column name="goodsnumber" length="50"/>
        </property>
        <property name="goodsCoding">
        	<column name="goodsCoding" length="250" />
        </property>
        <property name="productId">
        	<column name="productId" length="250" />
        </property>
        <property name="goodsBillsOldID">
        	<column name="goodsBillsOldID" length="250" />
        </property>
        <property name="startDate">
            <column name="startDate"  />
        </property>
        <property name="endDate">
            <column name="endDate" />
        </property>
	</class> 
	
</hibernate-mapping>

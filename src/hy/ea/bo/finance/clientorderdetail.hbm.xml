<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="ClientOrderDetail" table="dtClientOrderDetail">
		<id length="50" name="codkey" type="java.lang.String">
			<column length="50" name="codkey"  />
			<generator class="uuid" />
		</id>
		 <property name="codID" type="java.lang.String">
        	<column name="codID" length="50"/>
        </property>
        <property name="coID" type="java.lang.String">
        	<column name="coID" length="50">
        	<comment>总订单</comment>
        	</column>
        </property>
         <property name="waiterID" type="java.lang.String">
        	<column name="waiterID" length="50">
        	<comment>服务人员ID</comment>
        	</column>
        </property>
          <property name="waiterName" type="java.lang.String">
        	<column name="waiterName" length="50">
        	<comment>人员名称</comment>
        	</column>
        </property>
		<property name="orderDate" type="java.util.Date">
			<column name="orderDate" >
				<comment>下单时间</comment>
			</column>
		</property>
		<property name="remark" type="java.lang.String">
			<column name="remark" length="500">
				<comment>备注</comment>
			</column>
		</property>
		<property name="sn" type="java.lang.String">
			<column name="sn" length="20">
				<comment>顺序号取餐号</comment>
			</column>
		</property>
		<property name="dtotalMoney" type="java.lang.String">
			<column name="dtotalMoney" length="50">
				<comment>单次点金额</comment>
			</column>
		</property>
		<property name="eatType" type="java.lang.String">
			<column name="eatType" length="11">
				<comment>就餐类型 堂食 打包</comment>
			</column>
		</property>

	</class> 
	
</hibernate-mapping>

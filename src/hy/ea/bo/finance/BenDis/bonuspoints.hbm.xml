<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance.BenDis">
	<class name="BonusPoints" table="DT_WFJ_BonusPoints" schema="HYPLAT" dynamic-insert="true">
	<comment>积分明细表</comment>
		<id length="50" name="bonusPointsKey" type="java.lang.String">
			<column length="50" name="bonusPointsKey" />
			<generator class="uuid" />
		</id>
		<property name="bonusPointsId" type="java.lang.String">
			<column length="50" name="bonusPointsId" >
			</column>
		</property>
		<property name="sccid" type="java.lang.String">
			<column length="100" name="sccid" >
			<comment>公司或者个人</comment>
			</column>
		</property>		
		<property name="bonusPointScore" type="java.lang.String" >
			<column length="50" name="bonusPointScore" default="0" sql-type="NUMBER(20,10)">
			<comment>记录积分量</comment>
			</column>
		</property>															
	</class>
</hibernate-mapping>

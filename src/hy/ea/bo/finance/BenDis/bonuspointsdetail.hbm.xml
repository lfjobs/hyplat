<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance.BenDis">
	<class name="BonusPointsDetail" table="DT_WFJ_BONUSPOINTS_DETAIL" schema="HYPLAT" dynamic-insert="true">
	<comment>积分明细表</comment>
		<id length="50" name="bonusPointsDetailKey" type="java.lang.String">
			<column length="50" name="bonusPointsDetailKey" />
			<generator class="uuid" />
		</id>
		<property name="bonusPointsDetailId" type="java.lang.String">
			<column length="50" name="bonusPointsDetailId" >
			</column>
		</property>
		<property name="bonusPointsDetailName" type="java.lang.String">
			<column length="100" name="bonusPointsDetailName" >
			<comment>记录内容</comment>
			</column>
		</property>
		<property name="bonusPointsDetailDate" type="java.util.Date">
			<column name="bonusPointsDetailDate" sql-type="DATE">
			<comment>记录时间</comment>
			</column>
		</property>
		<property name="bonusPointsDetailScore" type="java.lang.String">
			<column length="50" name="bonusPointsDetailScore" default="0" sql-type="NUMBER(20,10)">
			<comment>记录积分量</comment>
			</column>
		</property>							
		<property name="wfjGuizeId" type="java.lang.String">
			<column length="50" name="wfjGuizeId" >
			<comment>规则外键</comment>
			</column>
		</property>
		<property name="bonusPointsId" type="java.lang.String">
			<column length="50" name="bonusPointsId" >
			<comment>积分外键</comment>
			</column>
		</property>
		<property name="wfjCashId" type="java.lang.String">
			<column length="50" name="wfjCashId" >
			<comment>金币出入库单据id</comment>
			</column>
		</property>
		<property name="wfjOrderId" type="java.lang.String">
			<column length="50" name="wfjOrderId" >
				<comment>订单ID</comment>
			</column>
		</property>
		<property name="wfjGoodId" type="java.lang.String">
			<column length="50" name="wfjGoodId" >
			<comment>订单物品单据id</comment>
			</column>
		</property>
		<property name="ppid" type="java.lang.String">
			<column length="50" name="ppid" >
			<comment>产品表id</comment>
			</column>
		</property>
	</class>
</hibernate-mapping>

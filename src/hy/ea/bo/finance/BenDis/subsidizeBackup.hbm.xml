<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.finance.BenDis.subsidizeBackup" table="DT_SUBSIDIZE_BACKUP" schema="hyplat">
        <id name="sbKey">
            <column name="SB_KEY" sql-type="varchar2(50)" length="50"/>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.finance">
	<class name="hy.ea.bo.finance.GoodsBillsContactRecent" table="DTGOODSBILLSCONTACTRECENT">
		<id length="50" name="key">
			<column length="50" name="KEY" />
			<generator class="uuid" />
		</id>
		<property name="id">
			<column name="ID" length="50"/>
		</property>
        <property name="accountName">
        	<column name="ACCOUNTNAME" length="250"/>
        </property>
        <property name="accountNameId">
        	<column name="ACCOUNTNAMEID" length="50"><comment>往来单位/个人id</comment></column>
        </property>
		<property name="accountNum">
			<column name="ACCOUNTNUM" length="250"><comment>银行账号</comment></column>
		</property>
        <property name="accountPhone">
			<column length="50" name="ACCOUNTPHONE"><comment>联系方式</comment></column>
		</property>
		 <property name="accountFlag">
        	<column name="ACCOUNTFLAG" length="50"><comment>账户类型</comment></column>
        </property>
        <property name="openBank">
        	<column name="OPENBANK" length="250"><comment>开户行</comment></column>
        </property>
		<property name="staffId">
			<column name="STAFFID" length="50"><comment>最近联系人id</comment></column>
		</property>
		<property name="staffName">
			<column name="STAFFNAME" length="50"><comment>最近联系人姓名</comment></column>
		</property>
		<property name="createDate">
			<column name="CREATEDATE" length="50"><comment>时间</comment></column>
		</property>
	</class>
</hibernate-mapping>

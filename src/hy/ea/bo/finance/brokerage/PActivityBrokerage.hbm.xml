<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="hy.ea.bo.finance.brokerage.PActivityBrokerage" table="dt_pro_activity_brokerage">
        <id name="activitybroKey" type="java.lang.String">
            <column name="activitybroKey" length="50"/>
            <generator class="uuid"/>
        </id>
        <property name="activitybroId" type="java.lang.String">
            <column name="activitybroId" length="50">
            </column>
        </property>
        <property name="brokerage" type="java.lang.Double">
            <column name="brokerage" length="50">
                <comment>代理佣金</comment>
            </column>
        </property>
        <property name="ppid" type="java.lang.String">
            <column name="ppid" length="50">
                <comment>产品id</comment>
            </column>
        </property>
        <property name="typePpid" type="java.lang.String">
            <column name="typePpid" length="50">
                <comment>代理类别id</comment>
            </column>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId" length="50">
                <comment>公司id</comment>
            </column>
        </property>

        <property name="actPriceId" type="java.lang.String">
            <column name="actPriceId" length="50">
                <comment>活动价id</comment>
            </column>
        </property>
        <property name="state" type="java.lang.String">
            <column name="state" length="50">
                <comment>状态[00:正常 01:删除]</comment>
            </column>
        </property>

    </class>
</hibernate-mapping>

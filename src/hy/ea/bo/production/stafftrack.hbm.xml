<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.production">
	<class name="StaffTrack" table="dtStaffTrack">
		<id length="50" name="stkey">
			<column length="50" name="stkey" />
			<generator class="uuid" />
		</id>
		<property name="stId">
			<column length="50" name="stId"><comment>ID</comment></column>
		</property>
		<property name="cashierBillsID">
			<column length="50" name="cashierBillsID"><comment>单据ID</comment></column>
		</property>
		<property name="enrollDate">
			<column  name="enrollDate"><comment>报名时间即下单付款时间</comment></column>
		</property>
		<property name="ppID">
			<column length="50" name="ppID"><comment>主产品ID</comment></column>
		</property>
		<property name="ppName">
			<column length="50"  name="ppName"><comment>主产品名称</comment></column>
		</property>
		<property name="subID">
			<column  length="50"  name="subID"><comment>子产品ID</comment></column>
		</property>
		<property name="subName">
			<column length="50" name="subName"><comment>子产品Name</comment></column>
		</property>
		<property name="staffName">
			<column length="50" name="staffName"><comment>客户</comment></column>
		</property>
		<property name="staffID">
			<column length="50" name="staffID"><comment>客户ID</comment></column>
		</property>
		<property name="sex">
			<column length="5" name="sex"><comment>性别</comment></column>
		</property>
		<property name="tel">
			<column length="11" name="tel"><comment>电话</comment></column>
		</property>
		<property name="identiCard">
			<column length="18" name="identiCard"><comment>身份证</comment></column>
		</property>
		<property name="startDate">
			<column  name="startDate"><comment>开始时间</comment></column>
		</property>
		<property name="endDate">
			<column name="endDate"><comment>截止时间</comment></column>
		</property>
		<property name="companyID">
			<column length="50" name="companyId"><comment>公司ID</comment></column>
		</property>
		<property name="companyName">
			<column length="50" name="companyName"><comment>公司名称</comment></column>
		</property>
		<property name="responID">
			<column length="50" name="responID"><comment>责任人ID</comment></column>
		</property>
		<property name="responName">
			<column length="50" name="responName"><comment>责任人</comment></column>
		</property>
		<property name="remark">
			<column length="5000" name="remark"><comment>备注</comment></column>
		</property>
		<property name="status">
			<column length="50" name="status"><comment></comment></column>
		</property>
        <property name="fiveClear">
			<column length="1" name="fiveClear"><comment>1人事2办公室3财务4生产5营销</comment></column>
		</property>
			<property name="pronum">
			<column length="10" name="pronum"><comment>项目总数</comment></column>
		</property>
        <property name="completerate">
			<column length="10" name="completerate"><comment>完成率</comment></column>
		</property>
		  <property name="headimage">
			<column length="250" name="headimage"><comment>完成率</comment></column>
		</property>


	</class>
</hibernate-mapping>

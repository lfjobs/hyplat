<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="DepartmentPost" table="dt_hr_deptpost" >
		<id length="50" name="depPostKey">
			<column length="50" name="depPostKey" />
			<generator class="uuid" />
		</id>
		<property name="depPostID" >
			<column length="50" name="depPostID" />
		</property>
		<property name="companyID" >
			<column length="50" name="companyID" />
		</property>
		<property name="leveloneOrgID" >
			<column length="50" name="leveloneOrgID" />
		</property>
		<property name="SpecialpostNum" >
			<column length="50" name="SpecialpostNum" />
		</property>
		<property name="postName" >
			<column length="250" name="postName" />
		</property>
		<property name="postNum" >
			<column length="250" name="postNum" />
		</property>
		<property name="organizationID" >
			<column length="50" name="organizationID" />
		</property>
			<property name="adminNum" >
			<column length="250" name="adminNum" />
		</property>
			<property name="postSureNum">
			<column length="250" name="postSureNum" />
		</property>
		<property name="postResponsibility">
			<column length="2000" name="postResponsibility" />
		</property>
		<property name="responsibilityRequire">
			<column length="2000" name="responsibilityRequire" />
		</property>
		<property name="remark">
			<column length="2000" name="remark" />
		</property>
		<property name="omppostNum" >
			<column length="50" name="omppostNum" />
		</property>
	</class>
</hibernate-mapping>

<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="StaffEducation" table="dt_hr_staff_education">
		<id length="50" name="educationKey">
			<column length="50" name="educationKey" />
			<generator class="uuid" />
		</id>
		<property name="educationID">
			<column length="50" name="educationID" not-null="true"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="staffID">
			<column length="50" name="staffID" not-null="true"/>
		</property>
		<property name="educationEnd">
			<column length="250" name="educationEnd"/>
		</property>
		<property name="educationStart">
			<column length="250" name="educationStart"/>
		</property>
		<property name="educationName">
			<column length="250" name="educationName" />
		</property>
		<property  name="majorType">
			<column length="250" name="majorType" />
		</property>
		<property  name="educationHistory">
			<column length="250" name="educationHistory" />
		</property>
		<property  name="educationStyle">
			<column length="250" name="educationStyle" />
		</property>
		<property  name="educationType">
			<column length="250" name="educationType" />
		</property>
		<property  name="provePerson">
			<column length="250" name="provePerson" />
		</property>
		<property  name="provePhone">
			<column length="250" name="provePhone" />
		</property>
		<property  name="assessor">
			<column length="250" name="assessor" />
		</property>
		<property  name="assessorCode">
			<column length="250" name="assessorCode" />
		</property>
		<property  name="assessorDate">
			<column  name="assessorDate" />
		</property>
		<property  name="educationDesc">
			<column length="250" name="educationDesc" />
		</property>
		<property  name="photo">
			<column length="256" name="photo" />
		</property>
	</class>
</hibernate-mapping>

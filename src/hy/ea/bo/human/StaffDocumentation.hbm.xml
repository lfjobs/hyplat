<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="StaffDocumentation" table="dt_hr_staff_Documentation">
		<id length="50" name="documentationkey">
			<column length="50" name="documentationkey" />
			<generator class="uuid" />
		</id>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="staffID">
			<column length="50" name="staffID" not-null="true"/>
		</property>
		<property name="documentationID">
			<column length="50" name="documentationID" not-null="true"/>
		</property>
		<property name="documentationNumber">
			<column length="250" name="documentationNumber"/>
		</property>
		<property name="documentationName">
			<column length="250" name="documentationName"/>
		</property>
		<property name="documentationManagerStart">
			<column length="250" name="documentationManagerStart" />
		</property>
		<property  name="documentationManagerEnd">
			<column length="250" name="documentationManagerEnd" />
		</property>
		<property  name="documentationBoxNumber">
			<column length="250" name="documentationBoxNumber" />
		</property>
		<property  name="documentationBoxName">
			<column length="250" name="documentationBoxName" />
		</property>
		<property  name="auditor">
			<column length="250" name="auditor" />
		</property>
		<property  name="auditorNumber">
			<column length="250" name="auditorNumber" />
		</property>
		<property  name="auditorTime">
			<column length="250" name="auditorTime" />
		</property>
		<property  name="ddesc">
			<column length="256" name="ddesc" />
		</property>
		<property  name="photo">
			<column length="256" name="photo" />
		</property>
	</class>
</hibernate-mapping>

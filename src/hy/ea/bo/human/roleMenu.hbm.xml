<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">

	<class name="hy.ea.bo.human.RoleMenu" table="DT_ROLE_MENU">
		<id length="50" name="roleMenuKey" >
			<column length="50" name="ROLE_MENU_KEY" />
			<generator class="uuid" />
		</id>
		<property name="roleId" >
			<column length="50" name="ROLE_ID" not-null="true"/>
		</property>
		<property name="companyId" >
			<column length="50" name="COMPANY_ID" not-null="true"/>
		</property>
		<property name="menuId" >
			<column length="50" name="MENU_ID" not-null="true"/>
		</property>
	</class>
</hibernate-mapping>

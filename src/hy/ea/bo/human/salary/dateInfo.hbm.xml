<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="hy.ea.bo.human.salary.DateInfo" table="DT_DATE_INFO">
		<id length="50" name="id" >
			<column length="50" name="ID" />
			<generator class="uuid" />
		</id>
		<property name="date" >
			<column length="50" name="DATES" not-null="true"/>
		</property>

		<property name="week" >
			<column length="50" name="WEEK"/>
		</property>
		<property name="type" >
			<column length="50" name="TYPE"/>
		</property>

	</class>
</hibernate-mapping>

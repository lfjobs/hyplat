<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.human">
	<class name="StaffEncourage" table="dt_hr_staff_Encourage">
		<id length="50" name="encouragekey">
			<column length="50" name="encouragekey" />
			<generator class="uuid" />
		</id>
		<property name="encourageID">
			<column length="50" name="encourageID" not-null="true"/>
		</property>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true"/>
		</property>
		<property name="staffID">
			<column length="50" name="staffID" not-null="true"/>
		</property>
		<property name="encourageType">
			<column length="250" name="encourageType"/>
		</property>
		<property name="encourageName">
			<column length="250" name="encourageName"/>
		</property>
		<property name="encourageReason">
			<column length="250" name="encourageReason" />
		</property>
		<property  name="encourageDate">
			<column length="250" name="encourageDate" />
		</property>
		<property  name="encourageOrgan">
			<column length="250" name="encourageOrgan" />
		</property>
		<property  name="honoraryTitle">
			<column length="250" name="honoraryTitle" />
		</property>
		<property  name="encourageSanction">
			<column length="250" name="encourageSanction" />
		</property>
		<property  name="auditor">
			<column length="250" name="auditor" />
		</property>
		<property  name="auditorNumber">
			<column length="250" name="auditorNumber" />
		</property>
		<property  name="auditorTime">
			<column length="250" name="auditorTime" />
		</property>
		<property  name="appendix">
			<column length="250" name="appendix" />
		</property>
		<property  name="encourageDesc">
			<column length="250" name="encourageDesc" />
		</property>
		<property  name="photo">
			<column length="256" name="photo" />
		</property>
	</class>
</hibernate-mapping>

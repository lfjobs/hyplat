<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
                                   "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo">
	<class name="CAccountRecords"  table="DTCAccountRecords">
		<id length="50" name="caccountRecordsKey">
			<column length="50" name="caccountRecordsKey" />
			<generator class="uuid" />
		</id>
		<property name="caccountRecordsID">
			<column length="50" name="caccountRecordsID" not-null="true" />
		</property>
		<property name="companyID">
			<column length="50" name="companyID" not-null="true" />
		</property>
		<property  name="accountID">
			<column length="50" name="accountID" not-null="true" />
		</property>
		<property  name="startDate">
			<column  name="startDate" />
		</property>
		<property  name="endDate">
			<column  name="endDate"/>
		</property>
		<property  name="beforePeople">
			<column length="250" name="beforePeople" />
		</property>
		<property  name="afterPeople">
			<column length="50" name="afterPeople"  />
		</property>
	</class>
</hibernate-mapping>

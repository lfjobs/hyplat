<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="hy.ea.bo.DrivingSchool.elyc">
    <class name="TbElycTeacherRScheduling" table="Tb_Elyc_Teacher_RScheduling">
        <id length="50" name="trsKey">
            <column length="50" name="trsKey" />
            <generator class="uuid" />
        </id>
        <property name="trsId" type="java.lang.String">
            <column name="trsId"  length="50" ><comment>逻辑ID</comment></column>
        </property>
        <property name="companyId" type="java.lang.String">
            <column name="companyId"  length="50" ><comment>驾校ID</comment></column>
        </property>
        <property name="teacherId" type="java.lang.String">
            <column name="teacherId"  length="50" ><comment>教练ID</comment></column>
        </property>
        <property name="classId" type="java.lang.String">
            <column name="classId"  length="50"><comment>班次</comment></column>
        </property>
        <property name="createdate" type="java.util.Date">
            <column name="createdate"><comment>创建时间</comment></column>
        </property>
        <property name="updatedate" type="java.util.Date">
            <column name="updatedate"><comment>更新时间</comment></column>
        </property>
        <property name="createperson" type="java.lang.String">
            <column name="createperson"  length="50" ><comment>创建人ID</comment></column>
        </property>
        <property name="updateperson" type="java.lang.String">
            <column name="updateperson"  length="50" ><comment>修改人</comment></column>
        </property>
        <property name="status" type="java.lang.String">
            <column name="status"  length="2"><comment>01启用，00未启用</comment></column>
        </property>

    </class>
</hibernate-mapping>
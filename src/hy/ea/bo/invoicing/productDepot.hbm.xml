<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="hy.ea.bo.invoicing">
    <class name="productDepot" table="dt_pro_depot">
        <id length="50" name="pdkey">
            <column length="50" name="pdkey"/>
            <generator class="uuid"/>
        </id>
        <property name="pdid">
            <column length="50" name="pdid">
                <comment>业务主键</comment>
            </column>
        </property>
        <property name="ppid">
            <column length="50" name="ppid">
                <comment>产品id</comment>
            </column>
        </property>
        <property name="depotid">
            <column length="50" name="depotid">
                <comment>库房id</comment>
            </column>
        </property>
        <property name="depotcode">
            <column length="50" name="depotcode">
                <comment>库房编号</comment>
            </column>
        </property>
        <property name="depotname">
            <column length="50" name="depotname">
                <comment>库房名称</comment>
            </column>
        </property>
        <property name="proAddRem">
            <column length="50" name="proAddRem">
                <comment>上下架</comment>
            </column>
        </property>

        <property name="proComid">
            <column length="250" name="proComid">
                <comment>产品公司id</comment>
            </column>
        </property>
        <property name="deoptComid">
            <column length="50" name="deoptComid">
                <comment>库房公司id</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>

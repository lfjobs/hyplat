<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.invoicing.SendGoods" table="DT_SEND_GOODS" schema="HYPLAT">
        <id name="sendgoodkey">
            <column name="SENDGOODKEY" sql-type="varchar2(50)"/>
            <generator class="uuid" />
        </id>
        <property name="sendgoodid">
            <column name="SENDGOODID" sql-type="varchar2(50)" length="50"/>
        </property>
        <property name="sendid">
            <column name="SENDID" sql-type="varchar2(50)" length="50"/>
        </property>
        <property name="goodsid">
            <column name="GOODSID" sql-type="varchar2(50)" length="50"/>
        </property>
        <property name="goodname">
            <column name="GOODNAME" sql-type="varchar2(50)"/>
        </property>
        <property name="unit">
            <column name="UNIT" sql-type="varchar2(50)"/>
        </property>
        <property name="ordernum">
            <column name="ORDERNUM" sql-type="varchar2(50)"/>
        </property>
        <property name="quantity">
            <column name="QUANTITY" sql-type="varchar2(50)"/>
        </property>
        <property name="error">
            <column name="ERROR" sql-type="varchar2(50)"/>
        </property>
        <property name="unitprice">
            <column name="UNITPRICE" sql-type="varchar2(50)"/>
        </property>
        <property name="totalprices">
            <column name="TOTALPRICES" sql-type="varchar2(50)"/>
        </property>
        <property name="goodstype">
            <column name="GOODSTYPE" sql-type="varchar2(50)"/>
        </property>
        <property name="ppid">
            <column name="PPID" sql-type="varchar2(50)" length="50"/>
        </property>
    </class>
</hibernate-mapping>
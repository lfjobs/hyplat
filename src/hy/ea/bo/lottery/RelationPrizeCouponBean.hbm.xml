<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

    <class name="hy.ea.bo.lottery.RelationPrizeCouponBean" table="DT_RELATION_PRIZE_COUPON" schema="HYPLAT">
        <comment>优惠券奖品关联</comment>
        <id name="id">
            <column name="ID" sql-type="varchar2(50)" length="50"/>
            <generator class="uuid"></generator>
        </id>
        <property name="couponId">
            <column name="COUPON_ID" sql-type="varchar2(50)" length="50" not-null="true">
            <comment>优惠券ID</comment>
            </column>
        </property>
        <property name="prizeId">
            <column name="PRIZE_ID" sql-type="varchar2(50)" length="50" not-null="true">
                <comment>奖品池ID</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>